---
type BadgeTone = 'primary' | 'amber' | 'green' | 'neutral';

interface Props {
  title: string;
  description: string;
  href: string;
  image?: string;
  imageAlt?: string;
  icon?: string;
  iconAlt?: string;
  cta?: string;
  badge?: { label: string; tone?: BadgeTone };
}

const {
  title,
  description,
  href,
  image,
  imageAlt,
  icon,
  iconAlt,
  cta = 'Saber más',
  badge,
} = Astro.props;

const badgeTones: Record<BadgeTone, string> = {
  primary: 'bg-primary/10 text-primary-dark',
  amber: 'bg-amber-100 text-amber-800',
  green: 'bg-green-100 text-green-800',
  neutral: 'bg-gray-100 text-gray-700',
};
const badgeClass = badge ? badgeTones[badge.tone ?? 'primary'] : '';
---

<article
  class="group hover:border-primary/30 hover:shadow-primary/10 relative flex h-full flex-col overflow-hidden rounded-2xl border border-gray-100 bg-white shadow-sm transition-all duration-300 hover:shadow-lg motion-safe:hover:-translate-y-1 motion-reduce:transition-none"
>
  {
    badge && (
      <span
        class:list={[
          'absolute top-3 right-3 z-10 rounded-full px-3 py-1 text-xs font-bold tracking-wider uppercase shadow-sm backdrop-blur',
          badgeClass,
        ]}
      >
        {badge.label}
      </span>
    )
  }
  {
    image && (
      <a href={href} class="block aspect-[4/3] overflow-hidden bg-gray-100">
        <img
          src={image}
          alt={imageAlt ?? title}
          width="480"
          height="360"
          loading="lazy"
          decoding="async"
          class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
        />
      </a>
    )
  }
  <div class="flex flex-1 flex-col gap-3 p-6">
    {
      icon && !image && (
        <img
          src={icon}
          alt={iconAlt ?? ''}
          width="64"
          height="64"
          loading="lazy"
          class="h-14 w-14 object-contain"
        />
      )
    }
    <h3 class="font-heading text-xl font-bold">
      <a href={href} class="hover:text-primary">
        {title}
      </a>
    </h3>
    <p class="flex-1 text-sm text-gray-700">{description}</p>
    <a
      href={href}
      class="text-primary hover:text-primary-dark mt-2 inline-flex items-center gap-1 text-sm font-bold"
    >
      {cta}
      <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
        <path
          fill-rule="evenodd"
          d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z"
          clip-rule="evenodd"></path>
      </svg>
    </a>
  </div>
</article>
