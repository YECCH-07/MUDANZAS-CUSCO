---
/*
 * Lista de redes sociales de Expresos Ñan con iconos SVG inline.
 *
 * Variant:
 *  - 'dark'  → para fondos oscuros (footer). Botones con bg-white/10, text-white.
 *  - 'light' → para fondos claros (página de contacto, about). Botones con bg-gray-100.
 *
 * Size:
 *  - 'sm' → 36×36
 *  - 'md' → 40×40 (default)
 *  - 'lg' → 48×48
 *
 * Las URLs vienen de SITE.social; actualizar ahí para reflejar en todo el sitio.
 */
import { SITE } from '@lib/site';

interface Props {
  variant?: 'dark' | 'light';
  size?: 'sm' | 'md' | 'lg';
  label?: string;
  class?: string;
}

const { variant = 'dark', size = 'md', label, class: className = '' } = Astro.props;

const networks = [
  {
    name: 'Facebook',
    href: SITE.social.facebook,
    label: 'Facebook de Expresos Ñan',
    // Facebook "f" icon
    svg: `<path d="M9.198 21.5h4v-8.01h3.604l.396-3.98h-4V7.5a1 1 0 011-1h3v-4h-3a5 5 0 00-5 5v2.01h-2l-.396 3.98h2.396v8.01z"/>`,
  },
  {
    name: 'Instagram',
    href: SITE.social.instagram,
    label: 'Instagram de Expresos Ñan',
    svg: `<path d="M12 2.2c3.2 0 3.6 0 4.8.1 1.2 0 1.8.2 2.2.4.6.2 1 .5 1.4.9.4.4.7.8.9 1.4.2.4.4 1 .4 2.2.1 1.2.1 1.6.1 4.8s0 3.6-.1 4.8c0 1.2-.2 1.8-.4 2.2-.2.6-.5 1-.9 1.4-.4.4-.8.7-1.4.9-.4.2-1 .4-2.2.4-1.2.1-1.6.1-4.8.1s-3.6 0-4.8-.1c-1.2 0-1.8-.2-2.2-.4-.6-.2-1-.5-1.4-.9-.4-.4-.7-.8-.9-1.4-.2-.4-.4-1-.4-2.2-.1-1.2-.1-1.6-.1-4.8s0-3.6.1-4.8c0-1.2.2-1.8.4-2.2.2-.6.5-1 .9-1.4.4-.4.8-.7 1.4-.9.4-.2 1-.4 2.2-.4 1.2-.1 1.6-.1 4.8-.1zm0 2.2c-3.2 0-3.5 0-4.7.1-1.1 0-1.7.2-2 .4-.5.2-.9.4-1.2.8-.3.3-.6.7-.8 1.2-.2.3-.4.9-.4 2C2.8 9.9 2.8 10.2 2.8 12s0 2.1.1 3.3c0 1.1.2 1.7.4 2 .2.5.4.9.8 1.2.3.3.7.6 1.2.8.3.2.9.4 2 .4 1.2.1 1.5.1 4.7.1s3.5 0 4.7-.1c1.1 0 1.7-.2 2-.4.5-.2.9-.4 1.2-.8.3-.3.6-.7.8-1.2.2-.3.4-.9.4-2 .1-1.2.1-1.5.1-3.3s0-2.1-.1-3.3c0-1.1-.2-1.7-.4-2-.2-.5-.4-.9-.8-1.2-.3-.3-.7-.6-1.2-.8-.3-.2-.9-.4-2-.4C15.5 4.4 15.2 4.4 12 4.4zm0 3.7a3.9 3.9 0 110 7.8 3.9 3.9 0 010-7.8zm0 6.4a2.5 2.5 0 100-5 2.5 2.5 0 000 5zm5-6.8a.9.9 0 11-1.8 0 .9.9 0 011.8 0z"/>`,
  },
  {
    name: 'TikTok',
    href: SITE.social.tiktok,
    label: 'TikTok de Expresos Ñan',
    svg: `<path d="M19.6 6.3a5 5 0 01-3-.9v9.3a5.9 5.9 0 11-5.9-5.9v2.8a3.1 3.1 0 103.1 3.1V2h2.8a5 5 0 003 4.3z"/>`,
  },
];

const sizeMap = {
  sm: 'h-9 w-9',
  md: 'h-10 w-10',
  lg: 'h-12 w-12',
};
const iconSizeMap = {
  sm: 'h-4 w-4',
  md: 'h-[18px] w-[18px]',
  lg: 'h-5 w-5',
};

const variantBtn =
  variant === 'dark'
    ? 'bg-white/10 text-white hover:bg-primary'
    : 'bg-gray-100 text-gray-700 hover:bg-primary hover:text-white';
---

<div class:list={['flex flex-col gap-2', className]}>
  {
    label && (
      <p
        class:list={[
          'text-xs font-bold tracking-wider uppercase',
          variant === 'dark' ? 'text-gray-400' : 'text-gray-500',
        ]}
      >
        {label}
      </p>
    )
  }
  <ul class="flex gap-3" aria-label="Redes sociales de Expresos Ñan">
    {
      networks.map((n) => (
        <li>
          <a
            href={n.href}
            target="_blank"
            rel="noopener noreferrer"
            class:list={[
              'inline-flex items-center justify-center rounded-full transition-colors',
              sizeMap[size],
              variantBtn,
            ]}
            aria-label={n.label}
            title={n.name}
          >
            <svg
              class:list={iconSizeMap[size]}
              viewBox="0 0 24 24"
              fill="currentColor"
              aria-hidden="true"
              set:html={n.svg}
            />
          </a>
        </li>
      ))
    }
  </ul>
</div>
