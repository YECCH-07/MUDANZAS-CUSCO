---
/*
 * Avatar con iniciales y color de fondo determinístico (hash del nombre).
 * 8 paletas distintas para distinguir conductores en listas.
 */
interface Props {
  name: string;
  size?: 'xs' | 'sm' | 'md' | 'lg';
  className?: string;
}

const { name, size = 'sm', className = '' } = Astro.props;

function initials(s: string): string {
  const parts = s.trim().split(/\s+/);
  const first = parts[0]?.charAt(0) ?? '?';
  const last = parts.length > 1 ? (parts[parts.length - 1]?.charAt(0) ?? '') : '';
  return (first + last).toUpperCase().slice(0, 2);
}

function hashColor(s: string): string {
  // 8 fondos de paleta corporativa.
  const palette = [
    'bg-red-500',
    'bg-orange-500',
    'bg-amber-500',
    'bg-emerald-500',
    'bg-teal-500',
    'bg-blue-500',
    'bg-indigo-500',
    'bg-rose-500',
  ];
  let hash = 0;
  for (let i = 0; i < s.length; i++) hash = (hash * 31 + s.charCodeAt(i)) | 0;
  return palette[Math.abs(hash) % palette.length] ?? 'bg-gray-500';
}

const sizeClasses: Record<NonNullable<Props['size']>, string> = {
  xs: 'h-6 w-6 text-[9px]',
  sm: 'h-8 w-8 text-[11px]',
  md: 'h-10 w-10 text-sm',
  lg: 'h-14 w-14 text-base',
};

const bg = hashColor(name);
---

<span
  class:list={[
    'inline-flex shrink-0 items-center justify-center rounded-full font-bold text-white',
    sizeClasses[size],
    bg,
    className,
  ]}
  title={name}
  aria-hidden="true"
>
  {initials(name)}
</span>
