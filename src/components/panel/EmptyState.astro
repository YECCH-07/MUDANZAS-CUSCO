---
/*
 * Empty state ilustrado para listas vacías.
 * Usa SVG inline (sin librería) y mensaje + CTA opcional.
 */
interface Props {
  title: string;
  description?: string;
  ctaLabel?: string;
  ctaHref?: string;
  iconHref?: string; // path d= de heroicons
}

const { title, description, ctaLabel, ctaHref, iconHref } = Astro.props;
---

<div
  class="rounded-2xl border-2 border-dashed border-gray-200 bg-gradient-to-br from-gray-50 to-white p-8 text-center"
>
  <div class="bg-primary-50 mx-auto mb-3 flex h-12 w-12 items-center justify-center rounded-full">
    <svg
      class="text-primary-500 h-6 w-6"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d={iconHref ?? 'M9.5 14.5L3 21M3 21h6m-6 0v-6M14.5 9.5L21 3m0 0h-6m6 0v6'}></path>
    </svg>
  </div>
  <p class="font-heading text-base font-bold text-gray-900">{title}</p>
  {description && <p class="mx-auto mt-1 max-w-sm text-sm text-gray-600">{description}</p>}
  {
    ctaHref && ctaLabel && (
      <a
        href={ctaHref}
        class="bg-primary hover:bg-primary-dark mt-4 inline-block rounded-full px-5 py-2 text-xs font-bold text-white transition-colors"
      >
        {ctaLabel}
      </a>
    )
  }
</div>
