---
/*
 * Header de sección con título y acción opcional a la derecha.
 * Estandariza el espaciado entre secciones del panel.
 */
interface Props {
  title: string;
  subtitle?: string;
  actionLabel?: string;
  actionHref?: string;
}

const { title, subtitle, actionLabel, actionHref } = Astro.props;
---

<div class="mb-3 flex flex-wrap items-end justify-between gap-3">
  <div>
    <h2 class="font-heading text-lg font-bold tracking-tight text-gray-900 md:text-xl">{title}</h2>
    {subtitle && <p class="mt-0.5 text-xs text-gray-500">{subtitle}</p>}
  </div>
  {
    actionHref && actionLabel && (
      <a
        href={actionHref}
        class="text-primary inline-flex items-center gap-1 text-xs font-bold hover:underline"
      >
        {actionLabel}
        <svg
          class="h-3.5 w-3.5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M5 12h14M12 5l7 7-7 7" />
        </svg>
      </a>
    )
  }
</div>
