---
/*
 * Diálogo modal de confirmación (reemplaza window.confirm() nativo)
 * y mejora visual de botones submit con estado "Procesando…".
 *
 * Uso desde cualquier página del panel:
 *   <button data-confirm="¿Eliminar?">…</button>
 *
 * El click es interceptado, se muestra el modal con el mensaje,
 * y al confirmar se re-dispara el click para que el form submitee.
 *
 * Estado loading: cualquier <button type="submit"> sin
 * data-no-loading entra en modo "deshabilitado + spinner" tras submit.
 * Personalizar con data-loading-text="Eliminando…".
 */
---

<dialog
  id="panel-confirm-dialog"
  class="m-auto w-[min(92vw,26rem)] rounded-2xl border border-gray-200 p-0 shadow-2xl backdrop:bg-gray-900/40 backdrop:backdrop-blur-sm"
  aria-labelledby="panel-confirm-title"
  aria-describedby="panel-confirm-message"
>
  <div class="p-6">
    <h2
      id="panel-confirm-title"
      class="font-heading text-lg font-bold tracking-tight text-gray-900"
    >
      Confirmar acción
    </h2>
    <p id="panel-confirm-message" class="mt-3 text-sm leading-relaxed text-gray-700">
      ¿Estás seguro?
    </p>
    <div class="mt-6 flex flex-col-reverse gap-2 sm:flex-row sm:justify-end">
      <button
        type="button"
        data-confirm-cancel
        class="rounded-full border border-gray-300 bg-white px-4 py-2 text-sm font-bold text-gray-700 transition-colors hover:bg-gray-100 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-gray-400"
      >
        Cancelar
      </button>
      <button
        type="button"
        data-confirm-ok
        class="bg-primary-600 hover:bg-primary-700 focus-visible:outline-primary-600 rounded-full px-4 py-2 text-sm font-bold text-white transition-colors focus-visible:outline-2 focus-visible:outline-offset-2"
      >
        Confirmar
      </button>
    </div>
  </div>
</dialog>

<script>
  (() => {
    if (window.__panelEnhancementsInit) return;
    window.__panelEnhancementsInit = true;

    const dialog = document.getElementById('panel-confirm-dialog') as HTMLDialogElement | null;
    const messageEl = document.getElementById('panel-confirm-message');
    const okBtn = dialog?.querySelector('[data-confirm-ok]') as HTMLButtonElement | null;
    const cancelBtn = dialog?.querySelector('[data-confirm-cancel]') as HTMLButtonElement | null;

    let pendingTarget: HTMLElement | null = null;

    function ask(message: string, target: HTMLElement): void {
      if (!dialog || !messageEl) return;
      messageEl.textContent = message;
      pendingTarget = target;
      dialog.showModal();
      cancelBtn?.focus();
    }

    cancelBtn?.addEventListener('click', () => {
      pendingTarget = null;
      dialog?.close('cancel');
    });

    okBtn?.addEventListener('click', () => {
      const target = pendingTarget;
      pendingTarget = null;
      dialog?.close('ok');
      if (target) {
        target.dataset.confirmed = '1';
        target.click();
      }
    });

    // Cierre con Escape: el <dialog> lo maneja nativamente, solo limpiamos el state.
    dialog?.addEventListener('close', () => {
      pendingTarget = null;
    });

    // Delegación global: intercepta clicks con [data-confirm]
    document.addEventListener(
      'click',
      (e) => {
        const target = e.target as HTMLElement | null;
        if (!target) return;
        const trigger = target.closest('[data-confirm]') as HTMLElement | null;
        if (!trigger) return;

        // Re-dispatch tras confirmación: dejar pasar y limpiar marca.
        if (trigger.dataset.confirmed === '1') {
          delete trigger.dataset.confirmed;
          return;
        }

        e.preventDefault();
        e.stopPropagation();
        ask(trigger.dataset.confirm || '¿Estás seguro?', trigger);
      },
      true,
    );

    // ──────────────────────────────────────────────────────────────────
    // Loading state global en formularios POST
    // ──────────────────────────────────────────────────────────────────
    document.addEventListener(
      'submit',
      (e) => {
        const form = e.target as HTMLFormElement;
        if (!form || form.dataset.noLoading === '1') return;
        const submitter =
          (e.submitter as HTMLButtonElement | null) ||
          (form.querySelector('button[type="submit"]') as HTMLButtonElement | null);
        if (!submitter || submitter.dataset.loadingApplied === '1') return;
        submitter.dataset.loadingApplied = '1';
        const loadingText = submitter.dataset.loadingText || 'Procesando…';
        submitter.disabled = true;
        submitter.setAttribute('aria-busy', 'true');
        submitter.innerHTML =
          '<span class="inline-flex items-center justify-center gap-2">' +
          '<svg class="h-4 w-4 animate-spin" viewBox="0 0 24 24" fill="none" aria-hidden="true">' +
          '<circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" stroke-opacity="0.25"/>' +
          '<path d="M22 12a10 10 0 00-10-10" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>' +
          '</svg>' +
          loadingText +
          '</span>';
      },
      true,
    );
  })();
</script>

<style>
  dialog#panel-confirm-dialog[open] {
    animation: panel-confirm-in 0.15s ease-out;
  }
  dialog#panel-confirm-dialog[open]::backdrop {
    animation: panel-confirm-backdrop-in 0.15s ease-out;
  }
  @keyframes panel-confirm-in {
    from {
      opacity: 0;
      transform: translateY(8px) scale(0.98);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }
  @keyframes panel-confirm-backdrop-in {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    dialog#panel-confirm-dialog[open],
    dialog#panel-confirm-dialog[open]::backdrop {
      animation: none;
    }
  }
</style>
