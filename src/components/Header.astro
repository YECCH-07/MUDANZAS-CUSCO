---
import Container from '@components/Container.astro';
import WhatsAppButton from '@components/WhatsAppButton.astro';
import LanguageSwitcher from '@components/LanguageSwitcher.astro';
import { SITE, NAV } from '@lib/site';
import { getLangFromUrl } from '@/i18n/config';

const lang = getLangFromUrl(Astro.url);
const items = NAV[lang];
---

{
  /*
  Header sticky con identidad corporativa carmesí.
  - Fondo gradient rojo + sombra branded.
  - Logo sobre tarjeta blanca redondeada para máximo contraste.
  - Nav items en blanco con hover translúcido + underline animado.
  - Mobile menu con fondo blanco para legibilidad.
*/
}
<header class="bg-brand-gradient shadow-brand-lg site-header sticky top-0 z-30 w-full">
  <Container as="nav" size="wide" class="flex items-center justify-between gap-4 py-3">
    <a
      href={lang === 'es' ? '/' : '/en/'}
      class="group/logo inline-flex shrink-0 items-center gap-3 rounded-xl bg-white px-3 py-1.5 shadow-md transition-all hover:shadow-xl focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white"
      aria-label={SITE.name}
    >
      <img
        src={SITE.logo.icon}
        alt=""
        width="40"
        height="40"
        class="h-9 w-9 shrink-0 object-contain transition-transform group-hover/logo:scale-110"
        aria-hidden="true"
      />
      <span class="hidden sm:flex sm:flex-col sm:items-start sm:leading-none">
        <span class="text-primary-700 font-heading text-base font-bold tracking-tight"
          >Expresos Ñan</span
        >
        <span class="text-primary-600 mt-0.5 text-[9px] font-bold tracking-widest uppercase"
          >Mudanzas Cusco</span
        >
      </span>
    </a>

    {/* Nav desktop (lg+) */}
    <ul class="hidden items-center gap-0.5 lg:flex">
      {
        items.map((item) => (
          <li class="relative">
            {'children' in item && item.children ? (
              <details class="group/nav">
                <summary class="nav-link group/sum flex cursor-pointer list-none items-center gap-1 rounded-lg px-3 py-2 text-sm font-bold text-white/95 transition-all hover:bg-white/15 hover:text-white focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white [&::-webkit-details-marker]:hidden">
                  {item.label}
                  <svg
                    class="h-4 w-4 transition-transform group-open/nav:rotate-180"
                    viewBox="0 0 20 20"
                    fill="currentColor"
                    aria-hidden="true"
                  >
                    <path
                      fill-rule="evenodd"
                      d="M5.23 7.21a.75.75 0 011.06.02L10 11.06l3.71-3.83a.75.75 0 111.08 1.04l-4.25 4.39a.75.75 0 01-1.08 0L5.21 8.27a.75.75 0 01.02-1.06z"
                      clip-rule="evenodd"
                    />
                  </svg>
                </summary>
                <ul class="absolute top-full left-0 z-20 mt-2 w-72 overflow-hidden rounded-xl border border-gray-100 bg-white py-2 shadow-2xl ring-1 ring-black/5">
                  <li>
                    <a
                      href={item.href}
                      class="text-primary-700 hover:bg-primary-50 block px-4 py-2 text-sm font-bold transition-colors"
                    >
                      {`→ ${item.label}`}
                    </a>
                  </li>
                  {item.children.map((child) => (
                    <li>
                      <a
                        href={child.href}
                        class="text-dark hover:bg-primary-50 hover:text-primary-700 hover:border-primary-500 block border-l-2 border-transparent px-4 py-2 text-sm transition-all hover:pl-5"
                      >
                        {child.label}
                      </a>
                    </li>
                  ))}
                </ul>
              </details>
            ) : (
              <a
                href={item.href}
                class="nav-link relative block rounded-lg px-3 py-2 text-sm font-bold text-white/95 transition-all hover:bg-white/15 hover:text-white focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white"
              >
                {item.label}
              </a>
            )}
          </li>
        ))
      }
    </ul>

    <div class="flex items-center gap-2">
      <LanguageSwitcher />
      <div class="hidden md:block">
        <WhatsAppButton variant="inline" size="sm" />
      </div>

      {/* Menú hamburguesa (móvil y tablet) */}
      <details class="group relative lg:hidden">
        <summary
          class="flex cursor-pointer list-none items-center justify-center rounded-lg p-2 text-white transition-all hover:bg-white/15 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white [&::-webkit-details-marker]:hidden"
          aria-label="Abrir menú"
        >
          <svg
            class="h-6 w-6 group-open:hidden"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            aria-hidden="true"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
          <svg
            class="hidden h-6 w-6 group-open:block"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            aria-hidden="true"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </summary>
        <div
          class="fixed inset-x-0 top-[var(--header-h,72px)] z-20 max-h-[calc(100vh-var(--header-h,72px))] overflow-y-auto bg-white shadow-2xl"
          style="--header-h: 72px;"
        >
          <ul class="px-4 py-4">
            {
              items.map((item) => (
                <li class="border-b border-gray-100 last:border-0">
                  {'children' in item && item.children ? (
                    <details class="group/sub">
                      <summary class="text-dark hover:text-primary-700 flex cursor-pointer list-none items-center justify-between py-3 text-base font-bold transition-colors [&::-webkit-details-marker]:hidden">
                        {item.label}
                        <svg
                          class="h-5 w-5 transition-transform group-open/sub:rotate-180"
                          viewBox="0 0 20 20"
                          fill="currentColor"
                          aria-hidden="true"
                        >
                          <path
                            fill-rule="evenodd"
                            d="M5.23 7.21a.75.75 0 011.06.02L10 11.06l3.71-3.83a.75.75 0 111.08 1.04l-4.25 4.39a.75.75 0 01-1.08 0L5.21 8.27a.75.75 0 01.02-1.06z"
                            clip-rule="evenodd"
                          />
                        </svg>
                      </summary>
                      <ul class="pb-2 pl-4">
                        <li>
                          <a
                            href={item.href}
                            class="text-primary-700 block py-2 text-sm font-bold transition-colors hover:underline"
                          >
                            {`→ ${item.label}`}
                          </a>
                        </li>
                        {item.children.map((child) => (
                          <li>
                            <a
                              href={child.href}
                              class="text-dark hover:text-primary-700 hover:border-primary-500 block border-l-2 border-transparent py-2 pl-3 text-sm transition-all hover:pl-4"
                            >
                              {child.label}
                            </a>
                          </li>
                        ))}
                      </ul>
                    </details>
                  ) : (
                    <a
                      href={item.href}
                      class="text-dark hover:text-primary-700 block py-3 text-base font-bold transition-colors"
                    >
                      {item.label}
                    </a>
                  )}
                </li>
              ))
            }
          </ul>
          <div class="px-4 pb-4">
            <WhatsAppButton variant="inline" size="md" class="w-full" />
          </div>
        </div>
      </details>
    </div>
  </Container>
</header>

<style>
  /* Underline animado de izquierda a derecha en hover sobre nav-link.
     Solo aplica a links de primer nivel (no a los del dropdown). */
  .nav-link::after {
    content: '';
    position: absolute;
    left: 0.75rem;
    right: 0.75rem;
    bottom: 0.35rem;
    height: 2px;
    background: rgb(255 255 255);
    border-radius: 999px;
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform 0.25s ease;
  }
  .nav-link:hover::after {
    transform: scaleX(1);
  }

  /* Sombra sutil al hacer scroll para reforzar separación */
  @media (prefers-reduced-motion: no-preference) {
    .site-header {
      transition: padding 0.2s ease;
    }
  }
</style>
