---
/*
 * Calculadora interactiva de espacio de almacenaje.
 * Lógica 100% cliente (cero servidor).
 *
 * Tarifas MENSUALES confirmadas por el cliente (2026-04-24):
 *   - Solo cajas:                         S/  60 /mes
 *   - Cuarto pequeño:                     S/ 100 /mes
 *   - Departamento 1 ambiente:            S/ 250 /mes
 *   - Departamento 2-3 ambientes:         S/ 350 /mes
 *   - Casa completa:                      S/ 440 /mes
 *
 * Tarifas diarias y anuales derivadas:
 *   - Día = mensual / 30 (redondeado)     → tarifa diaria sin descuento
 *   - Año = mensual × 10                  → 12 meses con ~2 meses de descuento
 *
 * Si el cliente confirma tarifas distintas para día/año, ajustar DAY_DIVISOR y
 * YEAR_MULTIPLIER sin tocar el resto del componente.
 */
import { SITE } from '@lib/site';
---

<div
  class="rounded-2xl border border-gray-200 bg-gray-50 p-6 md:p-8"
  data-whatsapp-number={SITE.whatsapp}
>
  <h3 class="font-heading mb-4 text-2xl font-bold md:text-3xl">Calcula tu espacio</h3>
  <p class="mb-6 text-sm text-gray-700">
    Selecciona qué quieres almacenar y por cuánto tiempo. La cotización final la confirmamos por
    WhatsApp.
  </p>

  <div class="grid gap-4 md:grid-cols-2">
    <label class="block">
      <span class="mb-1 block text-sm font-bold">¿Qué quieres almacenar?</span>
      <select
        id="storage-type"
        class="focus:border-primary focus:ring-primary/20 w-full rounded-lg border border-gray-300 bg-white px-4 py-2 focus:ring-2 focus:outline-none"
      >
        <option value="cajas">Solo cajas (≈ 5 m³)</option>
        <option value="cuarto">Cuarto pequeño (≈ 10 m³)</option>
        <option value="depto1" selected>Departamento 1 ambiente (≈ 25 m³)</option>
        <option value="depto23">Departamento 2-3 ambientes (≈ 40 m³)</option>
        <option value="casa">Casa completa (≈ 80 m³)</option>
      </select>
    </label>

    <label class="block">
      <span class="mb-1 block text-sm font-bold">¿Por cuánto tiempo?</span>
      <select
        id="storage-time"
        class="focus:border-primary focus:ring-primary/20 w-full rounded-lg border border-gray-300 bg-white px-4 py-2 focus:ring-2 focus:outline-none"
      >
        <option value="days">Por días (corto plazo)</option>
        <option value="months" selected>Por mes</option>
        <option value="years">Por año (con descuento)</option>
      </select>
    </label>
  </div>

  <div class="mt-6 rounded-xl bg-white p-5">
    <p class="text-xs font-bold tracking-wider text-gray-500 uppercase">Estimación</p>
    <p id="storage-result" class="text-primary mt-1 text-2xl font-bold md:text-3xl">—</p>
    <p id="storage-result-meta" class="mt-2 text-sm text-gray-600">—</p>
  </div>

  <a
    id="storage-cta"
    href={`https://wa.me/${SITE.whatsapp}`}
    target="_blank"
    rel="noopener noreferrer"
    class="bg-whatsapp hover:bg-whatsapp-dark mt-4 inline-flex items-center justify-center gap-2 rounded-full px-6 py-3 font-bold text-white transition-colors"
    data-track="storage_calc_whatsapp_click"
  >
    <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path
        d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347"
      ></path>
    </svg>
    Cotizar este espacio por WhatsApp
  </a>
</div>

<script>
  // Tarifas mensuales confirmadas (S/ por mes).
  const MONTH_PRICE: Record<string, number> = {
    cajas: 60,
    cuarto: 100,
    depto1: 250,
    depto23: 350,
    casa: 440,
  };

  const LABELS: Record<string, string> = {
    cajas: 'solo cajas',
    cuarto: 'cuarto pequeño',
    depto1: 'departamento de 1 ambiente',
    depto23: 'departamento de 2-3 ambientes',
    casa: 'casa completa',
  };

  // Derivadas desde la tarifa mensual.
  const DAY_DIVISOR = 30; // tarifa diaria = mensual / 30
  const YEAR_MULTIPLIER = 10; // 12 meses con ~2 meses de descuento por contrato anual

  const root = document.querySelector<HTMLElement>('[data-whatsapp-number]');
  if (root) {
    const phone = root.dataset.whatsappNumber ?? '51925671052';
    const typeSelect = document.getElementById('storage-type') as HTMLSelectElement | null;
    const timeSelect = document.getElementById('storage-time') as HTMLSelectElement | null;
    const resultEl = document.getElementById('storage-result');
    const metaEl = document.getElementById('storage-result-meta');
    const cta = document.getElementById('storage-cta') as HTMLAnchorElement | null;

    if (typeSelect && timeSelect && resultEl && metaEl && cta) {
      function update() {
        if (!typeSelect || !timeSelect || !resultEl || !metaEl || !cta) return;

        const typeId = typeSelect.value;
        const time = timeSelect.value;
        const monthly = MONTH_PRICE[typeId] ?? 0;
        const typeLabel = LABELS[typeId] ?? 'espacio seleccionado';

        let price = 0;
        let unit = '';
        let meta = '';

        if (time === 'days') {
          price = Math.round(monthly / DAY_DIVISOR);
          unit = 'por día';
          meta = `Tarifa diaria estimada. Equivale a S/ ${monthly} al mes.`;
        } else if (time === 'months') {
          price = monthly;
          unit = 'por mes';
          meta = 'Tarifa mensual fija para este tipo de carga.';
        } else {
          price = monthly * YEAR_MULTIPLIER;
          unit = 'por año';
          meta = `Tarifa anual con descuento (equivale a ~${YEAR_MULTIPLIER} meses pagados).`;
        }

        resultEl.textContent = `S/ ${price} ${unit}`;
        metaEl.textContent = meta;

        const message = `Hola, calculé en su web almacenaje para ${typeLabel} ${unit}: S/ ${price}. ¿Me confirman disponibilidad y detalles?`;
        cta.href = `https://wa.me/${phone}?text=${encodeURIComponent(message)}`;
      }

      typeSelect.addEventListener('change', update);
      timeSelect.addEventListener('change', update);
      update();
    }
  }
</script>
