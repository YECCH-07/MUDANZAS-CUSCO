---
/*
 * Hero con imagen de portada al TOP en aspect-ratio natural (3:1) y bloque
 * de texto debajo sobre sección oscura.
 *
 * Decisión de diseño: el cliente pidió ver la imagen completa. Con object-cover
 * recortábamos parte de la foto (especialmente los lados en viewports anchos y
 * la parte baja en móvil). Con este layout apilado la imagen se muestra al
 * 100% en cualquier viewport — sin crop, sin overlay por encima. El texto ya
 * tiene contraste garantizado al estar en bg oscuro.
 *
 * Las 3 imágenes procesadas (home, about, services) tienen ratio 3:1 — un
 * solo aspect-ratio sirve para todas. Si se añaden más fotos con otros
 * ratios, habría que parametrizarlo.
 */
import Container from '@components/Container.astro';
import WhatsAppButton from '@components/WhatsAppButton.astro';
import Button from '@components/Button.astro';

type HeroSlug = 'home' | 'about' | 'services';

interface Stat {
  value: string;
  label: string;
}

interface Props {
  image: HeroSlug;
  title: string;
  subtitle?: string;
  eyebrow?: string;
  imageAlt: string;
  whatsappMessage?: string;
  secondaryCta?: { label: string; href: string };
  stats?: Stat[];
  as?: 'h1' | 'h2';
}

const {
  image,
  title,
  subtitle,
  eyebrow,
  imageAlt,
  whatsappMessage,
  secondaryCta,
  stats,
  as: HeadingTag = 'h1',
} = Astro.props;

const basePath = `/hero/${image}-hero`;
const srcsetWebp = `${basePath}-mobile.webp 768w, ${basePath}-tablet.webp 1280w, ${basePath}.webp 1920w`;
const srcsetJpg = `${basePath}.jpg`;

// Dimensiones reales para reservar espacio y evitar CLS.
// home-hero: 1500x498 (ratio 3.01). about/services: 1920x637 (ratio 3.01).
// El ratio 3:1 sirve para las 3.
---

<section class="relative overflow-hidden bg-[var(--color-dark)]">
  {/* Imagen completa — sin overlay encima, sin crop. Aspect natural 3:1. */}
  <picture class="block w-full">
    <source
      type="image/webp"
      srcset={srcsetWebp}
      sizes="(max-width: 768px) 768px, (max-width: 1280px) 1280px, 1920px"
    />
    <img
      src={srcsetJpg}
      alt={imageAlt}
      width="1920"
      height="637"
      loading="eager"
      fetchpriority="high"
      decoding="async"
      class="block h-auto w-full"
    />
  </picture>

  {/* Panel de texto debajo sobre bg oscuro — contraste garantizado. */}
  <Container size="wide" class="relative py-12 md:py-16 lg:py-20">
    <div class="max-w-3xl">
      {
        eyebrow && (
          <p class="mb-4 inline-flex items-center gap-2 rounded-full bg-white/10 px-4 py-1.5 text-xs font-bold tracking-wider text-white uppercase backdrop-blur">
            <span class="bg-primary inline-block h-1.5 w-1.5 animate-pulse rounded-full" />
            {eyebrow}
          </p>
        )
      }
      <HeadingTag
        class="font-heading text-3xl leading-tight font-bold text-white md:text-4xl lg:text-5xl"
      >
        {title}
      </HeadingTag>
      {
        subtitle && (
          <p class="mt-4 max-w-2xl text-base leading-relaxed text-white/90 md:text-lg">
            {subtitle}
          </p>
        )
      }

      <div class="mt-6 flex flex-wrap gap-3 md:mt-8">
        <WhatsAppButton
          variant="inline"
          size="lg"
          {...whatsappMessage !== undefined ? { message: whatsappMessage } : {}}
        />
        {
          secondaryCta && (
            <Button
              href={secondaryCta.href}
              variant="outline"
              size="lg"
              class="hover:text-primary border-white bg-transparent text-white hover:bg-white"
            >
              {secondaryCta.label}
            </Button>
          )
        }
      </div>

      {/* Stats bar opcional — social proof */}
      {
        stats && stats.length > 0 && (
          <dl class="mt-8 grid max-w-2xl grid-cols-3 gap-4 border-t border-white/15 pt-6 md:mt-10">
            {stats.map((s: Stat) => (
              <div class="text-white">
                <dt class="sr-only">{s.label}</dt>
                <dd>
                  <p class="font-heading text-2xl font-bold md:text-3xl">{s.value}</p>
                  <p class="mt-0.5 text-xs text-white/75 md:text-sm">{s.label}</p>
                </dd>
              </div>
            ))}
          </dl>
        )
      }
    </div>
  </Container>

  {/* Borde inferior sutil en primary — conecta con el resto del sitio */}
  <div class="bg-primary absolute right-0 bottom-0 left-0 h-1" aria-hidden="true"></div>
</section>
