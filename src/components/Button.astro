---
interface Props {
  href?: string;
  type?: 'button' | 'submit' | 'reset';
  variant?: 'primary' | 'secondary' | 'outline' | 'ghost' | 'whatsapp';
  size?: 'sm' | 'md' | 'lg';
  external?: boolean;
  class?: string;
  'aria-label'?: string;
  'data-track'?: string;
  disabled?: boolean;
}

const {
  href,
  type = 'button',
  variant = 'primary',
  size = 'md',
  external = false,
  class: className = '',
  'aria-label': ariaLabel,
  'data-track': dataTrack,
  disabled = false,
} = Astro.props;

// Base con transición suave + leve lift al hover + ring focus visible.
// La clase `btn-shimmer` añade un destello blanco que cruza el botón al hover.
const base =
  'group/btn relative inline-flex items-center justify-center gap-2 font-bold rounded-full overflow-hidden transition-all duration-200 ease-out focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary motion-safe:hover:-translate-y-0.5 motion-safe:active:translate-y-0 motion-safe:active:scale-[0.98] motion-reduce:transition-none disabled:pointer-events-none disabled:opacity-60 btn-shimmer';

const variants = {
  primary:
    'bg-gradient-to-br from-primary to-primary-dark text-white shadow-md hover:shadow-2xl hover:shadow-primary/40 hover:from-primary-600 hover:to-primary-800',
  secondary:
    'bg-[var(--color-dark)] text-white shadow-md hover:bg-black hover:shadow-2xl hover:shadow-black/30',
  outline:
    'bg-white text-primary-700 border-2 border-primary-600 hover:bg-primary-600 hover:text-white hover:border-primary-700 hover:shadow-xl hover:shadow-primary/30',
  ghost: 'bg-transparent text-primary-700 hover:bg-primary-50 hover:shadow-md',
  whatsapp:
    'bg-gradient-to-br from-whatsapp to-whatsapp-dark text-white shadow-md hover:shadow-2xl hover:shadow-whatsapp/40',
};

const sizes = {
  sm: 'px-4 py-2 text-sm',
  md: 'px-6 py-3 text-base',
  lg: 'px-8 py-4 text-lg',
};

const classes = [base, variants[variant], sizes[size], className];
const externalProps = external ? { target: '_blank', rel: 'noopener noreferrer' } : {};
---

{
  href ? (
    <a
      href={href}
      class:list={classes}
      aria-label={ariaLabel}
      data-track={dataTrack}
      {...externalProps}
    >
      <span class="relative z-10 inline-flex items-center gap-2">
        <slot />
      </span>
    </a>
  ) : (
    <button
      type={type}
      class:list={classes}
      aria-label={ariaLabel}
      data-track={dataTrack}
      disabled={disabled}
    >
      <span class="relative z-10 inline-flex items-center gap-2">
        <slot />
      </span>
    </button>
  )
}

<style is:global>
  /* Destello blanco que recorre el botón al hacer hover.
     Se desactiva con prefers-reduced-motion. */
  .btn-shimmer::before {
    content: '';
    position: absolute;
    top: 0;
    left: -75%;
    width: 50%;
    height: 100%;
    background: linear-gradient(
      120deg,
      transparent 0%,
      rgba(255, 255, 255, 0.18) 50%,
      transparent 100%
    );
    transform: skewX(-20deg);
    transition: left 0.6s ease;
    pointer-events: none;
    z-index: 1;
  }
  .btn-shimmer:hover::before {
    left: 125%;
  }
  @media (prefers-reduced-motion: reduce) {
    .btn-shimmer::before {
      display: none;
    }
  }
</style>
