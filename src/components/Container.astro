---
import type { HTMLAttributes } from 'astro/types';

interface Props extends Omit<HTMLAttributes<'div'>, 'class'> {
  as?: 'div' | 'section' | 'article' | 'header' | 'footer' | 'main' | 'nav';
  size?: 'narrow' | 'default' | 'wide' | 'full';
  class?: string;
}

const { as: Tag = 'div', size = 'default', class: className = '', ...rest } = Astro.props;

const sizes = {
  narrow: 'max-w-3xl',
  default: 'max-w-[var(--container-wide)]',
  wide: 'max-w-7xl',
  full: 'max-w-full',
};
---

<Tag class:list={['mx-auto w-full px-4 sm:px-6 lg:px-8', sizes[size], className]} {...rest}>
  <slot />
</Tag>
