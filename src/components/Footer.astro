---
import Container from '@components/Container.astro';
import SocialLinks from '@components/SocialLinks.astro';
import { SITE } from '@lib/site';
import { getTelUrl, getMailUrl } from '@lib/whatsapp';
import { getLangFromUrl } from '@/i18n/config';

const lang = getLangFromUrl(Astro.url);
const year = new Date().getFullYear();

const labels =
  lang === 'es'
    ? {
        aboutTitle: 'Sobre nosotros',
        aboutDesc:
          'Expresos Ñan es la empresa de mudanzas, flete y carga de Cusco. Servicio local, inter-provincial, almacenaje y embalaje profesional desde 2024.',
        servicesTitle: 'Servicios',
        coverageTitle: 'Cobertura',
        contactTitle: 'Contacto',
        hoursWeekdays: 'Lun a Sáb:',
        hoursSunday: 'Domingo:',
        legal: {
          privacy: 'Política de privacidad',
          terms: 'Términos y condiciones',
        },
        services: [
          {
            label: 'Mudanzas locales',
            href: '/mudanzas-locales-en-cusco-expresos-nan-servicio-rapido-seguro-y-eficiente/',
          },
          { label: 'Mudanzas inter-provincia', href: '/mudanza-provincia/' },
          { label: 'Mudanzas de oficina', href: '/mudanzas-de-o/' },
          { label: 'Almacenaje y custodia', href: '/almacenaje-y-custodia-cusco/' },
          { label: 'Flota de camiones', href: '/flota-de-camiones-cusco/' },
          { label: 'Embalaje profesional', href: '/servicio-de-embalaje-cusco/' },
        ],
        coverage: [
          { label: 'Cusco metropolitano', href: '/cobertura/' },
          { label: 'Cusco ↔ Sicuani', href: '/mudanzas-cusco-sicuani/' },
          { label: 'Cusco ↔ Abancay', href: '/mudanzas-cusco-abancay/' },
          { label: 'Cusco ↔ Challhuahuacho', href: '/mudanzas-cusco-challhuahuacho/' },
          { label: 'Cusco ↔ Tambobamba', href: '/mudanzas-cusco-tambobamba/' },
          { label: 'Ver todas las rutas', href: '/cobertura/' },
        ],
      }
    : {
        aboutTitle: 'About us',
        aboutDesc:
          'Expresos Ñan is the leading moving, freight and storage company in Cusco. Local, intercity, storage and professional packing services.',
        servicesTitle: 'Services',
        coverageTitle: 'Coverage',
        contactTitle: 'Contact',
        hoursWeekdays: 'Mon-Sat:',
        hoursSunday: 'Sunday:',
        legal: {
          privacy: 'Privacy policy',
          terms: 'Terms & conditions',
        },
        services: [
          { label: 'Local moving', href: '/en/local-moving-cusco/' },
          { label: 'Intercity moving', href: '/en/intercity-moving/' },
          { label: 'Office moving', href: '/en/office-moving-cusco/' },
          { label: 'Storage & custody', href: '/en/storage-and-custody-cusco/' },
          { label: 'Our fleet', href: '/en/our-fleet/' },
        ],
        coverage: [
          { label: 'Cusco metropolitan area', href: '/en/coverage/' },
          { label: 'Cusco ↔ Sicuani', href: '/mudanzas-cusco-sicuani/' },
          { label: 'Cusco ↔ Abancay', href: '/mudanzas-cusco-abancay/' },
          { label: 'All routes', href: '/en/coverage/' },
        ],
      };
---

<footer class="relative mt-auto bg-[var(--color-dark)] text-gray-300">
  {/* Barra de acento primary arriba del footer — conecta visualmente con el resto del sitio */}
  <div class="bg-primary h-1 w-full" aria-hidden="true"></div>
  <Container size="wide" class="grid grid-cols-1 gap-10 py-12 md:grid-cols-2 lg:grid-cols-4">
    {/* Col 1 — Sobre */}
    <div>
      <img
        src={SITE.logo.primary}
        alt={SITE.name}
        width="160"
        height="44"
        class="mb-4 h-10 w-auto brightness-0 invert"
        loading="lazy"
      />
      <p class="text-sm leading-relaxed">{labels.aboutDesc}</p>
      <SocialLinks variant="dark" size="sm" class="mt-4" />
    </div>

    {/* Col 2 — Servicios */}
    <div>
      <h2
        class="font-heading after:bg-primary relative mb-4 pb-2 text-lg font-bold text-white after:absolute after:bottom-0 after:left-0 after:h-0.5 after:w-8 after:rounded-full"
      >
        {labels.servicesTitle}
      </h2>
      <ul class="space-y-2 text-sm">
        {
          labels.services.map((s) => (
            <li>
              <a href={s.href} class="hover:text-primary hover:underline">
                {s.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    {/* Col 3 — Cobertura */}
    <div>
      <h2
        class="font-heading after:bg-primary relative mb-4 pb-2 text-lg font-bold text-white after:absolute after:bottom-0 after:left-0 after:h-0.5 after:w-8 after:rounded-full"
      >
        {labels.coverageTitle}
      </h2>
      <ul class="space-y-2 text-sm">
        {
          labels.coverage.map((c) => (
            <li>
              <a href={c.href} class="hover:text-primary hover:underline">
                {c.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    {/* Col 4 — Contacto */}
    <div>
      <h2
        class="font-heading after:bg-primary relative mb-4 pb-2 text-lg font-bold text-white after:absolute after:bottom-0 after:left-0 after:h-0.5 after:w-8 after:rounded-full"
      >
        {labels.contactTitle}
      </h2>
      <address class="space-y-3 text-sm not-italic">
        <p>
          <a href={getTelUrl()} class="hover:text-primary block font-bold text-white">
            {SITE.phoneDisplay}
          </a>
          <span class="text-xs text-gray-400">WhatsApp + llamada</span>
        </p>
        <p>
          <a href={getMailUrl()} class="hover:text-primary break-all hover:underline">
            {SITE.email}
          </a>
        </p>
        <p>
          <span class="block">{SITE.address.street}</span>
          <span class="block">
            {SITE.address.locality}, {SITE.address.country}
            {SITE.address.postalCode}
          </span>
        </p>
        <p class="text-xs text-gray-400">
          <span class="block">
            {labels.hoursWeekdays}
            {SITE.openingHours.weekdays}
          </span>
          <span class="block">
            {labels.hoursSunday}
            {SITE.openingHours.sunday}
          </span>
        </p>
      </address>
    </div>
  </Container>

  <div class="border-t border-white/10">
    <Container
      size="wide"
      class="flex flex-col items-center justify-between gap-2 py-4 text-xs md:flex-row"
    >
      <p>
        © {year}
        {SITE.name}. {lang === 'es' ? 'Todos los derechos reservados.' : 'All rights reserved.'}
      </p>
      <ul class="flex gap-4">
        <li>
          <a
            href={lang === 'es' ? '/politica-de-privacidad/' : '/en/privacy-policy/'}
            class="hover:text-white"
          >
            {labels.legal.privacy}
          </a>
        </li>
        <li>
          <a
            href={lang === 'es' ? '/terminos-y-condiciones/' : '/en/terms/'}
            class="hover:text-white"
          >
            {labels.legal.terms}
          </a>
        </li>
      </ul>
    </Container>
  </div>
</footer>
