---
export const prerender = false;

import PanelLayout from '@layouts/PanelLayout.astro';
import { listUserSessions } from '@lib/auth/session';

const user = Astro.locals.user!;
const session = Astro.locals.session!;

const sessions = await listUserSessions(user.id);
const revoked = Astro.url.searchParams.get('revoked');
const revokedAll = Astro.url.searchParams.get('revoked-all');

function fmtDate(unixMs: number): string {
  return new Date(unixMs).toISOString().slice(0, 16).replace('T', ' ');
}
---

<PanelLayout title="Mi cuenta">
  <main class="mx-auto max-w-2xl space-y-6 p-4">
    <header>
      <a href="/panel/" class="text-xs text-gray-500 hover:text-gray-800">← Panel</a>
      <h1 class="font-heading mt-1 text-2xl font-bold">Mi cuenta</h1>
      <p class="mt-1 text-sm text-gray-600">{user.fullName} · {user.email} · {user.role}</p>
    </header>

    {
      revoked && (
        <div class="rounded-lg border-l-4 border-amber-500 bg-amber-50 p-3 text-sm text-amber-800">
          Sesión revocada.
        </div>
      )
    }
    {
      revokedAll && (
        <div class="rounded-lg border-l-4 border-amber-500 bg-amber-50 p-3 text-sm text-amber-800">
          Otras sesiones cerradas.
        </div>
      )
    }

    <section class="rounded-2xl border border-gray-200 bg-white p-5">
      <h2 class="font-heading mb-3 text-sm font-bold tracking-wider text-gray-500 uppercase">
        Acciones rápidas
      </h2>
      <div class="space-y-2">
        <a
          href="/panel/mi-cuenta/cambiar-password/"
          class="block rounded-full border border-gray-300 px-4 py-2 text-center text-sm font-bold hover:bg-gray-100"
        >
          Cambiar contraseña
        </a>
        <form method="POST" action="/api/panel/sessions/revoke-others/">
          <button
            class="w-full rounded-full border border-amber-300 bg-amber-50 px-4 py-2 text-sm font-bold text-amber-800 hover:bg-amber-100"
          >
            Cerrar todas las otras sesiones
          </button>
        </form>
        <a
          href="/api/panel/logout/"
          class="bg-primary hover:bg-primary-dark block rounded-full px-4 py-2 text-center text-sm font-bold text-white"
        >
          Cerrar esta sesión
        </a>
      </div>
    </section>

    <section class="rounded-2xl border border-gray-200 bg-white p-5">
      <h2 class="font-heading mb-3 text-sm font-bold tracking-wider text-gray-500 uppercase">
        Sesiones activas ({sessions.length})
      </h2>
      <ul class="space-y-2">
        {
          sessions.map((s) => {
            const isCurrent = s.id === session.id;
            return (
              <li class="rounded-lg border border-gray-200 p-3 text-sm">
                <div class="flex items-start justify-between gap-2">
                  <div class="min-w-0 flex-1">
                    <p class="font-bold">
                      {isCurrent && (
                        <span class="bg-primary/10 text-primary mr-2 inline-block rounded-full px-2 py-0.5 text-[10px] font-bold">
                          actual
                        </span>
                      )}
                      {s.ip ?? 'IP desconocida'}
                    </p>
                    <p class="mt-1 truncate text-xs text-gray-600">{s.userAgent ?? '—'}</p>
                    <p class="mt-1 text-[10px] text-gray-500">
                      Creada: {s.createdAt?.slice(0, 16).replace('T', ' ')}· Expira:{' '}
                      {fmtDate(s.expiresAt)}
                    </p>
                  </div>
                  {!isCurrent && (
                    <form method="POST" action={`/api/panel/sessions/${s.id}/revoke/`}>
                      <button class="text-xs font-bold text-red-600 hover:underline">
                        revocar
                      </button>
                    </form>
                  )}
                </div>
              </li>
            );
          })
        }
      </ul>
    </section>
  </main>
</PanelLayout>
