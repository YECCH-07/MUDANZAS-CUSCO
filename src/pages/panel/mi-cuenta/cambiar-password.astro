---
export const prerender = false;

import PanelLayout from '@layouts/PanelLayout.astro';

const user = Astro.locals.user!;
const mustChange = user.mustChangePassword;
const errorParam = Astro.url.searchParams.get('error');
const errorMessage =
  errorParam === 'current'
    ? 'La contraseña actual no coincide.'
    : errorParam === 'weak'
      ? 'La nueva contraseña debe tener mínimo 12 caracteres.'
      : errorParam === 'mismatch'
        ? 'La confirmación no coincide con la nueva contraseña.'
        : errorParam === 'same'
          ? 'La nueva contraseña debe ser distinta de la anterior.'
          : null;
---

<PanelLayout title="Cambiar contraseña">
  <main class="flex min-h-screen items-center justify-center p-4">
    <div class="w-full max-w-md">
      <div class="mb-8 text-center">
        <h1 class="font-heading text-2xl font-bold">Cambiar contraseña</h1>
        {
          mustChange && (
            <p class="mt-2 text-sm text-amber-700">
              Primer ingreso: debes cambiar la contraseña antes de continuar.
            </p>
          )
        }
      </div>

      <form
        method="POST"
        action="/api/panel/change-password/"
        class="space-y-4 rounded-2xl border border-gray-200 bg-white p-6 shadow-sm"
      >
        {
          errorMessage && (
            <div class="rounded-lg border-l-4 border-red-500 bg-red-50 p-3 text-sm text-red-800">
              {errorMessage}
            </div>
          )
        }

        <label class="block">
          <span class="mb-1 block text-sm font-bold">Contraseña actual</span>
          <input
            type="password"
            name="current"
            required
            autocomplete="current-password"
            class="focus:border-primary focus:ring-primary/20 w-full rounded-lg border border-gray-300 px-4 py-2 focus:ring-2 focus:outline-none"
          />
        </label>

        <label class="block">
          <span class="mb-1 block text-sm font-bold">Nueva contraseña</span>
          <input
            type="password"
            name="next"
            required
            minlength="12"
            autocomplete="new-password"
            class="focus:border-primary focus:ring-primary/20 w-full rounded-lg border border-gray-300 px-4 py-2 focus:ring-2 focus:outline-none"
          />
          <span class="mt-1 block text-xs text-gray-500">Mínimo 12 caracteres.</span>
        </label>

        <label class="block">
          <span class="mb-1 block text-sm font-bold">Confirma la nueva contraseña</span>
          <input
            type="password"
            name="confirm"
            required
            minlength="12"
            autocomplete="new-password"
            class="focus:border-primary focus:ring-primary/20 w-full rounded-lg border border-gray-300 px-4 py-2 focus:ring-2 focus:outline-none"
          />
        </label>

        <button
          type="submit"
          class="bg-primary hover:bg-primary-dark focus-visible:outline-primary w-full rounded-full px-6 py-3 font-bold text-white transition-colors focus-visible:outline-2 focus-visible:outline-offset-2"
        >
          Actualizar contraseña
        </button>
      </form>
    </div>
  </main>
</PanelLayout>
