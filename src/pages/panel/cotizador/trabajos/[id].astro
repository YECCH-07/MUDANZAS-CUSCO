---
export const prerender = false;

import CotizadorLayout from '@layouts/CotizadorLayout.astro';
import { db } from '@db/client';
import { jobs, quotes, customers, units, users, receipts } from '@db/schema';
import { eq, and } from 'drizzle-orm';

const { id } = Astro.params;
if (!id) return Astro.redirect('/panel/cotizador/trabajos/');

const job = await db
  .select({ j: jobs, q: quotes, c: customers })
  .from(jobs)
  .innerJoin(quotes, eq(quotes.id, jobs.quoteId))
  .innerJoin(customers, eq(customers.id, quotes.customerId))
  .where(eq(jobs.id, id))
  .get();

if (!job) return Astro.redirect('/panel/cotizador/trabajos/');

const unitsList = await db.select().from(units).where(eq(units.active, true)).all();
const conductores = await db
  .select()
  .from(users)
  .where(and(eq(users.role, 'conductor'), eq(users.active, true)))
  .all();

const receipt = await db.select().from(receipts).where(eq(receipts.jobId, id)).get();

const fmt = (c: number | null | undefined): string =>
  `S/ ${((c ?? 0) / 100).toLocaleString('es-PE', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
const updated = Astro.url.searchParams.get('updated');
const error = Astro.url.searchParams.get('error');
---

<CotizadorLayout title={`Trabajo ${job.q.number}`}>
  <header class="mb-4">
    <nav class="mb-2 text-sm">
      <a href="/panel/cotizador/trabajos/" class="text-gray-500 hover:text-gray-700">← Trabajos</a>
    </nav>
    <div class="flex flex-wrap items-start justify-between gap-4">
      <div>
        <p class="font-mono text-xs font-bold text-gray-500">{job.q.number}</p>
        <h1 class="font-heading text-2xl font-bold">{job.c.name}</h1>
        <p class="text-sm text-gray-600">{job.q.origin ?? ''} → {job.q.destination ?? ''}</p>
      </div>
      <div class="text-right">
        <p class="text-primary text-2xl font-bold">{fmt(job.q.totalCents)}</p>
        <span
          class:list={[
            'mt-1 inline-block rounded-full px-3 py-1 text-xs font-bold',
            job.j.status === 'scheduled' && 'bg-blue-100 text-blue-800',
            job.j.status === 'in_progress' && 'bg-amber-100 text-amber-800',
            job.j.status === 'completed' && 'bg-green-100 text-green-800',
            job.j.status === 'canceled' && 'bg-gray-200 text-gray-500',
          ]}
        >
          {job.j.status}
        </span>
      </div>
    </div>
  </header>

  {
    updated && (
      <div class="mb-4 rounded-lg border-l-4 border-green-500 bg-green-50 p-3 text-sm text-green-800">
        Actualizado.
      </div>
    )
  }
  {
    error && (
      <div class="mb-4 rounded-lg border-l-4 border-red-500 bg-red-50 p-3 text-sm text-red-800">
        Error: {error}
      </div>
    )
  }

  <div class="grid gap-6 lg:grid-cols-3">
    <form
      method="POST"
      action={`/api/panel/jobs/${id}/update/`}
      class="space-y-4 rounded-2xl border border-gray-200 bg-white p-6 lg:col-span-2"
    >
      <h2 class="font-heading text-sm font-bold tracking-wider text-gray-500 uppercase">
        Asignación
      </h2>

      <div class="grid gap-4 sm:grid-cols-2">
        <label class="block">
          <span class="mb-1 block text-sm font-bold">Unidad</span>
          <select
            name="unit_id"
            class="focus:border-primary focus:ring-primary/20 w-full rounded-lg border border-gray-300 bg-white px-4 py-2 focus:ring-2 focus:outline-none"
          >
            <option value="">— sin asignar —</option>
            {
              unitsList.map((u) => (
                <option value={u.id} selected={u.id === job.j.assignedUnitId}>
                  {u.plate} ({u.tonnage} t){u.alias ? ` · ${u.alias}` : ''}
                </option>
              ))
            }
          </select>
        </label>

        <label class="block">
          <span class="mb-1 block text-sm font-bold">Conductor</span>
          <select
            name="driver_id"
            class="focus:border-primary focus:ring-primary/20 w-full rounded-lg border border-gray-300 bg-white px-4 py-2 focus:ring-2 focus:outline-none"
          >
            <option value="">— sin asignar —</option>
            {
              conductores.map((c) => (
                <option value={c.id} selected={c.id === job.j.assignedDriverId}>
                  {c.fullName}
                </option>
              ))
            }
          </select>
        </label>
      </div>

      <label class="block">
        <span class="mb-1 block text-sm font-bold">Fecha programada</span>
        <input
          type="date"
          name="scheduled_date"
          value={job.j.scheduledDate ?? ''}
          class="focus:border-primary focus:ring-primary/20 w-full rounded-lg border border-gray-300 px-4 py-2 focus:ring-2 focus:outline-none"
        />
      </label>

      <label class="block">
        <span class="mb-1 block text-sm font-bold">Notas</span>
        <textarea
          name="notes"
          rows="3"
          class="focus:border-primary focus:ring-primary/20 w-full rounded-lg border border-gray-300 px-4 py-2 focus:ring-2 focus:outline-none"
          >{job.j.notes ?? ''}</textarea
        >
      </label>

      <button
        type="submit"
        class="bg-primary hover:bg-primary-dark rounded-full px-6 py-2 text-sm font-bold text-white"
      >
        Guardar cambios
      </button>
    </form>

    <aside class="space-y-4">
      <div class="space-y-3 rounded-2xl border border-gray-200 bg-white p-5">
        <h3 class="font-heading text-sm font-bold tracking-wider text-gray-500 uppercase">
          Estado del trabajo
        </h3>

        {
          job.j.status === 'scheduled' && (
            <form method="POST" action={`/api/panel/jobs/${id}/start/`}>
              <button class="w-full rounded-full bg-amber-500 py-2 text-sm font-bold text-white hover:bg-amber-600">
                Marcar en progreso
              </button>
            </form>
          )
        }
        {
          job.j.status === 'in_progress' && (
            <form method="POST" action={`/api/panel/jobs/${id}/complete/`}>
              <button class="w-full rounded-full bg-green-600 py-2 text-sm font-bold text-white hover:bg-green-700">
                Marcar como completado
              </button>
            </form>
          )
        }
        {
          job.j.status === 'completed' && !receipt && (
            <form
              method="POST"
              action={`/api/panel/receipts/issue-from-job/${id}/`}
              class="space-y-2"
            >
              <label class="block text-sm">
                <span class="mb-1 block text-xs font-bold">Método de pago</span>
                <select
                  name="payment_method"
                  required
                  class="w-full rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm"
                >
                  <option value="efectivo">Efectivo</option>
                  <option value="transferencia">Transferencia</option>
                  <option value="yape">Yape</option>
                  <option value="plin">Plin</option>
                  <option value="otro">Otro</option>
                </select>
              </label>
              <label class="flex items-center gap-2 text-xs">
                <input type="checkbox" name="requires_sunat" value="1" class="h-4 w-4" />
                <span class="font-bold">Requiere factura SUNAT (contador)</span>
              </label>
              <button class="bg-primary hover:bg-primary-dark w-full rounded-full py-2 text-sm font-bold text-white">
                Emitir recibo
              </button>
            </form>
          )
        }
        {
          receipt && (
            <div class="border-primary/30 bg-primary/5 rounded-lg border p-3 text-sm">
              <p class="font-bold">Recibo emitido</p>
              <p class="font-mono text-xs">{receipt.number}</p>
              <a
                href={`/panel/cotizador/recibos/${receipt.id}/`}
                class="text-primary mt-2 inline-block text-xs font-bold hover:underline"
              >
                Ver recibo →
              </a>
            </div>
          )
        }

        {
          !['completed', 'canceled'].includes(job.j.status) && (
            <form method="POST" action={`/api/panel/jobs/${id}/cancel/`}>
              <button
                class="w-full rounded-full border border-gray-300 py-2 text-xs font-bold text-gray-700 hover:bg-gray-100"
                onclick="return confirm('¿Cancelar este trabajo?');"
              >
                Cancelar trabajo
              </button>
            </form>
          )
        }
      </div>

      <a
        href={`/panel/cotizador/trabajos/${id}/costos/`}
        class="border-primary/30 bg-primary/5 text-primary hover:bg-primary/10 block rounded-2xl border p-4 text-center text-xs font-bold"
      >
        Ver P&L (costos vs ingreso) →
      </a>

      <a
        href={`/panel/cotizador/trabajos/${id}/imprimir/`}
        target="_blank"
        rel="noopener"
        class="block rounded-2xl border border-gray-200 bg-white p-4 text-center text-xs font-bold text-gray-600 hover:bg-gray-50"
      >
        Imprimir hoja de ruta
      </a>

      <a
        href={`/panel/cotizador/${job.j.quoteId}/`}
        class="block rounded-2xl border border-gray-200 bg-white p-4 text-center text-xs font-bold text-gray-600 hover:bg-gray-50"
      >
        ← Ver cotización original
      </a>
    </aside>
  </div>
</CotizadorLayout>
