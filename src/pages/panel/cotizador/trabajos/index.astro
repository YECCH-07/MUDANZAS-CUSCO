---
export const prerender = false;

import CotizadorLayout from '@layouts/CotizadorLayout.astro';
import { db } from '@db/client';
import { jobs, quotes, customers, units, users } from '@db/schema';
import { desc, eq } from 'drizzle-orm';
import { alias } from 'drizzle-orm/sqlite-core';

const assignedDriver = alias(users, 'assignedDriver');

const rows = await db
  .select({
    id: jobs.id,
    status: jobs.status,
    scheduledDate: jobs.scheduledDate,
    completedAt: jobs.completedAt,
    quoteNumber: quotes.number,
    customerName: customers.name,
    totalCents: quotes.totalCents,
    unitPlate: units.plate,
    driverName: assignedDriver.fullName,
  })
  .from(jobs)
  .innerJoin(quotes, eq(quotes.id, jobs.quoteId))
  .innerJoin(customers, eq(customers.id, quotes.customerId))
  .leftJoin(units, eq(units.id, jobs.assignedUnitId))
  .leftJoin(assignedDriver, eq(assignedDriver.id, jobs.assignedDriverId))
  .orderBy(desc(jobs.createdAt))
  .limit(200)
  .all();

const fmt = (c: number | null | undefined): string =>
  `S/ ${((c ?? 0) / 100).toLocaleString('es-PE', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
---

<CotizadorLayout title="Trabajos">
  <header class="mb-6">
    <h1 class="font-heading text-2xl font-bold md:text-3xl">Trabajos</h1>
    <p class="mt-1 text-sm text-gray-600">
      {rows.length} trabajo(s) creados a partir de cotizaciones aceptadas.
    </p>
  </header>

  {
    rows.length === 0 ? (
      <div class="rounded-2xl border border-dashed border-gray-300 bg-white p-8 text-center text-sm text-gray-600">
        Aún no hay trabajos. Un trabajo se crea automáticamente cuando aceptas una cotización.
      </div>
    ) : (
      <div class="overflow-x-auto rounded-2xl border border-gray-200 bg-white">
        <table class="w-full text-left text-sm">
          <thead class="bg-gray-50 text-xs font-bold tracking-wider uppercase">
            <tr>
              <th class="px-4 py-3">Cotización</th>
              <th class="px-4 py-3">Cliente</th>
              <th class="px-4 py-3">Fecha</th>
              <th class="px-4 py-3">Unidad</th>
              <th class="px-4 py-3">Conductor</th>
              <th class="px-4 py-3">Total</th>
              <th class="px-4 py-3">Estado</th>
              <th class="px-4 py-3" />
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            {rows.map((j) => (
              <tr>
                <td class="px-4 py-3 font-mono text-xs font-bold">{j.quoteNumber}</td>
                <td class="px-4 py-3">{j.customerName}</td>
                <td class="px-4 py-3 text-xs">{j.scheduledDate ?? '—'}</td>
                <td class="px-4 py-3 font-mono text-xs">{j.unitPlate ?? '—'}</td>
                <td class="px-4 py-3 text-xs">{j.driverName ?? '—'}</td>
                <td class="px-4 py-3 font-bold">{fmt(j.totalCents)}</td>
                <td class="px-4 py-3">
                  <span
                    class:list={[
                      'inline-block rounded-full px-2 py-0.5 text-[10px] font-bold',
                      j.status === 'scheduled' && 'bg-blue-100 text-blue-800',
                      j.status === 'in_progress' && 'bg-amber-100 text-amber-800',
                      j.status === 'completed' && 'bg-green-100 text-green-800',
                      j.status === 'canceled' && 'bg-gray-200 text-gray-500',
                    ]}
                  >
                    {j.status}
                  </span>
                </td>
                <td class="px-4 py-3 text-right">
                  <a
                    href={`/panel/cotizador/trabajos/${j.id}/`}
                    class="text-primary text-xs font-bold hover:underline"
                  >
                    Abrir →
                  </a>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )
  }
</CotizadorLayout>
