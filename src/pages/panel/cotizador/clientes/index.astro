---
export const prerender = false;

import CotizadorLayout from '@layouts/CotizadorLayout.astro';
import { db } from '@db/client';
import { customers } from '@db/schema';
import { desc, like, or } from 'drizzle-orm';

const q = (Astro.url.searchParams.get('q') ?? '').trim();

const rows = q
  ? await db
      .select()
      .from(customers)
      .where(
        or(
          like(customers.name, `%${q}%`),
          like(customers.phone, `%${q}%`),
          like(customers.docNumber, `%${q}%`),
        ),
      )
      .orderBy(desc(customers.createdAt))
      .limit(100)
      .all()
  : await db.select().from(customers).orderBy(desc(customers.createdAt)).limit(100).all();

const created = Astro.url.searchParams.get('created');
---

<CotizadorLayout title="Clientes">
  <header class="mb-6 flex items-start justify-between gap-4">
    <div>
      <h1 class="font-heading text-2xl font-bold md:text-3xl">Clientes</h1>
      <p class="mt-1 text-sm text-gray-600">Base de contactos.</p>
    </div>
    <a
      href="/panel/cotizador/clientes/nuevo/"
      class="bg-primary hover:bg-primary-dark rounded-full px-5 py-2 text-sm font-bold text-white"
    >
      + Nuevo cliente
    </a>
  </header>

  {
    created && (
      <div class="mb-4 rounded-lg border-l-4 border-green-500 bg-green-50 p-3 text-sm text-green-800">
        Cliente <strong>{created}</strong> creado.
      </div>
    )
  }

  <form method="GET" class="mb-4">
    <input
      type="text"
      name="q"
      value={q}
      placeholder="Buscar por nombre, teléfono o documento…"
      class="focus:border-primary focus:ring-primary/20 w-full rounded-full border border-gray-300 px-5 py-2 text-sm focus:ring-2 focus:outline-none"
    />
  </form>

  {
    rows.length === 0 ? (
      <div class="rounded-2xl border border-dashed border-gray-300 bg-white p-8 text-center text-sm text-gray-600">
        {q ? 'Sin resultados.' : 'Aún no hay clientes.'}
      </div>
    ) : (
      <div class="overflow-x-auto rounded-2xl border border-gray-200 bg-white">
        <table class="w-full text-left text-sm">
          <thead class="bg-gray-50 text-xs font-bold tracking-wider uppercase">
            <tr>
              <th class="px-4 py-3">Nombre</th>
              <th class="px-4 py-3">Teléfono</th>
              <th class="px-4 py-3">Documento</th>
              <th class="px-4 py-3">Etiquetas</th>
              <th class="px-4 py-3" />
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            {rows.map((c) => {
              const tags = (() => {
                try {
                  return JSON.parse(c.tagsJson) as string[];
                } catch {
                  return [];
                }
              })();
              return (
                <tr class:list={[c.blacklisted && 'bg-red-50']}>
                  <td class="px-4 py-3 font-bold">{c.name}</td>
                  <td class="px-4 py-3 text-xs">{c.phone ?? '—'}</td>
                  <td class="px-4 py-3 text-xs">
                    {c.docType && c.docNumber ? `${c.docType} ${c.docNumber}` : '—'}
                  </td>
                  <td class="px-4 py-3">
                    {tags.length === 0 ? (
                      <span class="text-xs text-gray-400">—</span>
                    ) : (
                      <div class="flex flex-wrap gap-1">
                        {tags.map((t) => (
                          <span class="bg-primary/10 text-primary inline-block rounded-full px-2 py-0.5 text-[10px] font-bold">
                            {t}
                          </span>
                        ))}
                      </div>
                    )}
                  </td>
                  <td class="px-4 py-3 text-right">
                    <a
                      href={`/panel/cotizador/clientes/${c.id}/`}
                      class="text-primary text-xs font-bold hover:underline"
                    >
                      Abrir →
                    </a>
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    )
  }
</CotizadorLayout>
