---
export const prerender = false;

import CotizadorLayout from '@layouts/CotizadorLayout.astro';
import StatusBadge from '@components/panel/StatusBadge.astro';
import EmptyState from '@components/panel/EmptyState.astro';
import { ICONS } from '@components/panel/icons';
import { db } from '@db/client';
import { quotes, customers } from '@db/schema';
import { desc, eq, count } from 'drizzle-orm';
import { soles, fmtDate } from '@lib/panel/format';
import { getService } from '@lib/panel/services';

const statusFilter = Astro.url.searchParams.get('status') ?? '';
const allowed = [
  'draft',
  'sent',
  'accepted',
  'rejected',
  'expired',
  'completed',
  'canceled',
] as const;
type S = (typeof allowed)[number];

const base = db
  .select({
    id: quotes.id,
    number: quotes.number,
    status: quotes.status,
    totalCents: quotes.totalCents,
    serviceType: quotes.serviceType,
    expiresAt: quotes.expiresAt,
    createdAt: quotes.createdAt,
    customerName: customers.name,
    customerPhone: customers.phone,
  })
  .from(quotes)
  .innerJoin(customers, eq(customers.id, quotes.customerId));

const rows = allowed.includes(statusFilter as S)
  ? await base
      .where(eq(quotes.status, statusFilter as S))
      .orderBy(desc(quotes.createdAt))
      .limit(200)
      .all()
  : await base.orderBy(desc(quotes.createdAt)).limit(200).all();

// Conteos por estado para mostrar en cada chip
const counts: Record<string, number> = {};
const allCountRows = await db
  .select({ status: quotes.status, n: count() })
  .from(quotes)
  .groupBy(quotes.status)
  .all();
let totalAll = 0;
for (const r of allCountRows) {
  counts[r.status] = r.n;
  totalAll += r.n;
}

const STATUS_LABELS: Record<S, string> = {
  draft: 'Borradores',
  sent: 'Enviadas',
  accepted: 'Aceptadas',
  rejected: 'Rechazadas',
  expired: 'Vencidas',
  completed: 'Completadas',
  canceled: 'Canceladas',
};
---

<CotizadorLayout title="Cotizaciones">
  <header class="mb-6 flex flex-wrap items-start justify-between gap-4">
    <div>
      <h1 class="font-heading text-2xl font-bold tracking-tight md:text-3xl">Cotizaciones</h1>
      <p class="mt-1 text-sm text-gray-600">{rows.length} resultado(s) de {totalAll} totales.</p>
    </div>
    <div class="flex flex-wrap gap-2">
      <a
        href="/panel/cotizador/kanban/"
        class="border-primary-300 text-primary-700 hover:bg-primary-50 inline-flex items-center gap-1.5 rounded-full border bg-white px-4 py-2 text-sm font-bold transition-colors"
      >
        <svg
          class="h-4 w-4"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <rect x="3" y="3" width="6" height="18" rx="1"></rect>
          <rect x="11" y="3" width="6" height="12" rx="1"></rect>
          <rect x="19" y="3" width="2" height="6" rx="1"></rect>
        </svg>
        Kanban
      </a>
      <a
        href="/panel/cotizador/nueva/"
        class="bg-primary hover:bg-primary-dark shadow-brand-sm inline-flex items-center gap-1.5 rounded-full px-5 py-2 text-sm font-bold text-white transition-colors"
      >
        <svg
          class="h-4 w-4"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M12 5v14 M5 12h14"></path>
        </svg>
        Nueva cotización
      </a>
    </div>
  </header>

  {/* CHIPS DE FILTRO con conteos */}
  <nav class="mb-5 flex flex-wrap gap-2" aria-label="Filtrar por estado">
    <a
      href="/panel/cotizador/listado/"
      class:list={[
        'panel-lift inline-flex items-center gap-1.5 rounded-full border px-3 py-1.5 text-xs font-bold transition-all',
        !statusFilter
          ? 'border-primary-600 bg-primary-600 shadow-brand text-white'
          : 'hover:border-primary-300 hover:bg-primary-50 border-gray-300 bg-white text-gray-700',
      ]}
    >
      Todas
      <span
        class:list={[
          'rounded-full px-1.5 py-0.5 text-[10px]',
          !statusFilter ? 'bg-white/20' : 'bg-gray-100 text-gray-600',
        ]}>{totalAll}</span
      >
    </a>
    {
      allowed.map((s) => {
        const active = statusFilter === s;
        const n = counts[s] ?? 0;
        return (
          <a
            href={`?status=${s}`}
            class:list={[
              'panel-lift inline-flex items-center gap-1.5 rounded-full border px-3 py-1.5 text-xs font-bold transition-all',
              active
                ? 'border-primary-600 bg-primary-600 shadow-brand text-white'
                : 'hover:border-primary-300 hover:bg-primary-50 border-gray-300 bg-white text-gray-700',
            ]}
          >
            {STATUS_LABELS[s]}
            <span
              class:list={[
                'rounded-full px-1.5 py-0.5 text-[10px]',
                active ? 'bg-white/20' : 'bg-gray-100 text-gray-600',
              ]}
            >
              {n}
            </span>
          </a>
        );
      })
    }
  </nav>

  {
    rows.length === 0 ? (
      <EmptyState
        title="Sin cotizaciones en este filtro"
        description={
          statusFilter
            ? 'Prueba con otro estado o crea una nueva cotización.'
            : 'Crea tu primera cotización para empezar.'
        }
        ctaLabel="Crear cotización"
        ctaHref="/panel/cotizador/nueva/"
        iconHref={ICONS.doc}
      />
    ) : (
      <div class="shadow-brand-sm overflow-hidden rounded-2xl border border-gray-200 bg-white">
        <div class="overflow-x-auto">
          <table class="w-full text-left text-sm">
            <thead class="bg-gradient-to-r from-gray-50 to-white text-xs font-bold tracking-wider text-gray-500 uppercase">
              <tr>
                <th class="px-4 py-3">Número</th>
                <th class="px-4 py-3">Cliente</th>
                <th class="px-4 py-3">Servicio</th>
                <th class="px-4 py-3 text-right">Total</th>
                <th class="px-4 py-3">Estado</th>
                <th class="px-4 py-3">Fecha</th>
                <th class="px-4 py-3 text-right" />
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
              {rows.map((q) => (
                <tr class="hover:bg-primary-50/30 transition-colors">
                  <td class="px-4 py-3 font-mono text-xs font-bold text-gray-700">{q.number}</td>
                  <td class="px-4 py-3">
                    <p class="font-bold">{q.customerName}</p>
                    <p class="text-xs text-gray-500">{q.customerPhone ?? '—'}</p>
                  </td>
                  <td class="px-4 py-3 text-xs">
                    <p class="text-primary-700 font-bold">{getService(q.serviceType).name}</p>
                  </td>
                  <td class="px-4 py-3 text-right font-bold tabular-nums">{soles(q.totalCents)}</td>
                  <td class="px-4 py-3">
                    <StatusBadge status={q.status} />
                  </td>
                  <td class="px-4 py-3 text-xs text-gray-500">{fmtDate(q.createdAt)}</td>
                  <td class="px-4 py-3 text-right whitespace-nowrap">
                    <a
                      href={`/api/panel/quotes/${q.id}/pdf/`}
                      target="_blank"
                      rel="noopener"
                      class="hover:text-primary mr-3 text-xs font-bold text-gray-600 hover:underline"
                    >
                      PDF
                    </a>
                    <a
                      href={`/panel/cotizador/${q.id}/`}
                      class="text-primary-700 text-xs font-bold hover:underline"
                    >
                      Abrir →
                    </a>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    )
  }
</CotizadorLayout>
