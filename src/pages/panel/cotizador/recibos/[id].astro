---
export const prerender = false;

import CotizadorLayout from '@layouts/CotizadorLayout.astro';
import { db } from '@db/client';
import { receipts, customers, quotes, jobs, units, users } from '@db/schema';
import { eq } from 'drizzle-orm';
import { SITE } from '@lib/site';
import { isStorageConfigured, signedGetUrl } from '@lib/panel/storage';

const { id } = Astro.params;
if (!id) return Astro.redirect('/panel/cotizador/recibos/');

const row = await db
  .select({
    r: receipts,
    c: customers,
    q: quotes,
    j: jobs,
  })
  .from(receipts)
  .innerJoin(customers, eq(customers.id, receipts.customerId))
  .leftJoin(quotes, eq(quotes.id, receipts.quoteId))
  .leftJoin(jobs, eq(jobs.id, receipts.jobId))
  .where(eq(receipts.id, id))
  .get();

if (!row) return Astro.redirect('/panel/cotizador/recibos/');

const unit = row.j?.assignedUnitId
  ? await db.select().from(units).where(eq(units.id, row.j.assignedUnitId)).get()
  : null;
const driver = row.j?.assignedDriverId
  ? await db.select().from(users).where(eq(users.id, row.j.assignedDriverId)).get()
  : null;

const fmt = (c: number | null | undefined): string =>
  `S/ ${((c ?? 0) / 100).toLocaleString('es-PE', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
const verifyUrl = `${SITE.url}/verificar/${row.r.uuid}/`;

// Si hay pdfKey y B2 configurado, ofrecer URL firmada (1h).
let pdfDownloadUrl: string | null = null;
if (row.r.pdfKey && isStorageConfigured()) {
  pdfDownloadUrl = await signedGetUrl('docs', row.r.pdfKey);
}
---

<CotizadorLayout title={`Recibo ${row.r.number}`}>
  <header class="mb-4">
    <nav class="mb-2 text-sm">
      <a href="/panel/cotizador/recibos/" class="text-gray-500 hover:text-gray-700">← Recibos</a>
    </nav>
    <div class="flex flex-wrap items-start justify-between gap-4">
      <div>
        <p class="font-mono text-xs font-bold text-gray-500">{row.r.number}</p>
        <h1 class="font-heading text-2xl font-bold">{row.c.name}</h1>
        <p class="text-sm text-gray-600">
          {row.r.issuedAt.slice(0, 16).replace('T', ' ')} · {row.r.paymentMethod}
        </p>
      </div>
      {
        row.r.voidedAt ? (
          <span class="rounded-full bg-red-100 px-3 py-1 text-xs font-bold text-red-800">
            ANULADO
          </span>
        ) : (
          <span class="rounded-full bg-green-100 px-3 py-1 text-xs font-bold text-green-800">
            VÁLIDO
          </span>
        )
      }
    </div>
  </header>

  {
    row.r.voidedAt && row.r.voidReason && (
      <div class="mb-4 rounded-2xl border-l-4 border-red-500 bg-red-50 p-4 text-sm text-red-800">
        <p class="font-bold">Razón de anulación</p>
        <p class="mt-1">{row.r.voidReason}</p>
      </div>
    )
  }

  <div class="grid gap-6 lg:grid-cols-3">
    <div class="rounded-2xl border border-gray-200 bg-white p-6 lg:col-span-2">
      <dl class="grid grid-cols-2 gap-3 text-sm">
        <div>
          <dt class="text-gray-500">Servicio</dt><dd class="font-bold">
            {row.q?.serviceType ?? '—'}
          </dd>
        </div>
        <div>
          <dt class="text-gray-500">Origen → Destino</dt><dd>
            {row.q?.origin ?? '—'} → {row.q?.destination ?? '—'}
          </dd>
        </div>
        <div>
          <dt class="text-gray-500">Fecha del servicio</dt><dd>{row.j?.scheduledDate ?? '—'}</dd>
        </div>
        <div><dt class="text-gray-500">Unidad</dt><dd>{unit?.plate ?? '—'}</dd></div>
        <div><dt class="text-gray-500">Conductor</dt><dd>{driver?.fullName ?? '—'}</dd></div>
        <div><dt class="text-gray-500">Tipo</dt><dd>{row.r.docKind}</dd></div>
      </dl>

      <div class="mt-6 flex items-end justify-between border-t border-gray-100 pt-4">
        <span class="text-sm text-gray-500">Total cobrado</span>
        <span class="text-primary text-3xl font-bold">{fmt(row.r.totalCents)}</span>
      </div>

      {
        row.r.requiresSunatInvoice && (
          <div class="mt-4 rounded-lg bg-amber-50 p-3 text-xs text-amber-800">
            <strong>Tag SUNAT activo</strong>: el contador debe emitir la factura/boleta electrónica
            correspondiente a este recibo.
          </div>
        )
      }
    </div>

    <aside class="space-y-4">
      <div class="space-y-3 rounded-2xl border border-gray-200 bg-white p-5">
        <h3 class="font-heading text-sm font-bold tracking-wider text-gray-500 uppercase">
          Verificación
        </h3>
        <p class="text-xs break-all">{verifyUrl}</p>
        <a
          href={verifyUrl}
          target="_blank"
          rel="noopener"
          class="text-primary inline-block text-xs font-bold hover:underline"
        >
          Abrir verificador público →
        </a>

        {
          pdfDownloadUrl && (
            <a
              href={pdfDownloadUrl}
              target="_blank"
              rel="noopener"
              class="bg-primary hover:bg-primary-dark mt-2 block rounded-full py-2 text-center text-sm font-bold text-white"
            >
              Descargar PDF
            </a>
          )
        }
        {
          !pdfDownloadUrl && (
            <p class="rounded bg-amber-50 p-2 text-[10px] text-amber-800">
              PDF no disponible (B2 storage no configurado en este entorno). La numeración y el QR
              siguen siendo válidos.
            </p>
          )
        }
      </div>

      {
        !row.r.voidedAt && (
          <form
            method="POST"
            action={`/api/panel/receipts/${id}/void/`}
            class="space-y-2 rounded-2xl border border-gray-200 bg-white p-5"
          >
            <h3 class="font-heading text-sm font-bold tracking-wider text-gray-500 uppercase">
              Anular recibo
            </h3>
            <input
              type="text"
              name="reason"
              required
              minlength="4"
              maxlength="200"
              placeholder="Motivo de anulación…"
              class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm"
            />
            <button
              class="w-full rounded-full border border-red-300 bg-red-50 py-2 text-sm font-bold text-red-700 hover:bg-red-100"
              onclick="return confirm('¿Anular este recibo? El verificador público mostrará ANULADO de inmediato.');"
            >
              Anular recibo
            </button>
          </form>
        )
      }
    </aside>
  </div>
</CotizadorLayout>
