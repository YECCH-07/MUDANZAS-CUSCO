---
export const prerender = false;

import CotizadorLayout from '@layouts/CotizadorLayout.astro';
import { db } from '@db/client';
import { quoteTemplates } from '@db/schema';
import { eq } from 'drizzle-orm';

const { id } = Astro.params;
if (!id) return Astro.redirect('/panel/cotizador/plantillas/');

const tpl = await db.select().from(quoteTemplates).where(eq(quoteTemplates.id, id)).get();
if (!tpl) return Astro.redirect('/panel/cotizador/plantillas/');

const fields = (() => {
  try {
    return JSON.parse(tpl.defaultFields);
  } catch {
    return {};
  }
})() as Record<string, unknown>;
const items = (() => {
  try {
    return JSON.parse(tpl.defaultItems);
  } catch {
    return [];
  }
})() as Array<{ label: string; amountCents: number }>;

const itemsText = items.map((i) => `${i.label} | ${(i.amountCents / 100).toFixed(2)}`).join('\n');
---

<CotizadorLayout title={tpl.name}>
  <header class="mb-6">
    <nav class="mb-2 text-sm">
      <a href="/panel/cotizador/plantillas/" class="text-gray-500 hover:text-gray-700"
        >← Plantillas</a
      >
    </nav>
    <h1 class="font-heading text-2xl font-bold">Editar plantilla</h1>
  </header>

  <form
    method="POST"
    action={`/api/panel/quote-templates/${id}/update/`}
    class="max-w-2xl space-y-4 rounded-2xl border border-gray-200 bg-white p-6"
  >
    <label class="block">
      <span class="mb-1 block text-sm font-bold">Nombre</span>
      <input
        type="text"
        name="name"
        required
        value={tpl.name}
        class="focus:border-primary focus:ring-primary/20 w-full rounded-lg border border-gray-300 px-4 py-2 focus:ring-2 focus:outline-none"
      />
    </label>

    <label class="block">
      <span class="mb-1 block text-sm font-bold">Tipo de servicio</span>
      <select
        name="service_type"
        required
        class="focus:border-primary focus:ring-primary/20 w-full rounded-lg border border-gray-300 bg-white px-4 py-2 focus:ring-2 focus:outline-none"
      >
        <optgroup label="Mudanzas">
          <option value="mudanza_embalaje" selected={tpl.serviceType === 'mudanza_embalaje'}>
            Mudanza Express (servicio integral)
          </option>
          <option value="mudanza_personal" selected={tpl.serviceType === 'mudanza_personal'}>
            Mudanza Estándar (vehículo + personal)
          </option>
          <option
            value="solo_vehiculo_personal"
            selected={tpl.serviceType === 'solo_vehiculo_personal'}
          >
            Vehículo + Personal de carga y descarga
          </option>
        </optgroup>
        <optgroup label="Otros servicios">
          <option value="flete" selected={tpl.serviceType === 'flete'}>Flete</option>
          <option value="embalaje_solo" selected={tpl.serviceType === 'embalaje_solo'}>
            Embalaje profesional
          </option>
          <option value="armado_desarmado" selected={tpl.serviceType === 'armado_desarmado'}>
            Armado y desarmado de muebles
          </option>
          <option value="almacenaje" selected={tpl.serviceType === 'almacenaje'}>
            Almacenaje y custodia
          </option>
          <option value="otro" selected={tpl.serviceType === 'otro'}>
            Servicio personalizado
          </option>
        </optgroup>
      </select>
    </label>

    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block">
        <span class="mb-1 block text-sm font-bold">Origen</span>
        <input
          type="text"
          name="origin"
          value={(fields.origin as string) ?? ''}
          class="focus:border-primary focus:ring-primary/20 w-full rounded-lg border border-gray-300 px-4 py-2 focus:ring-2 focus:outline-none"
        />
      </label>
      <label class="block">
        <span class="mb-1 block text-sm font-bold">Destino</span>
        <input
          type="text"
          name="destination"
          value={(fields.destination as string) ?? ''}
          class="focus:border-primary focus:ring-primary/20 w-full rounded-lg border border-gray-300 px-4 py-2 focus:ring-2 focus:outline-none"
        />
      </label>
    </div>

    <div class="grid gap-4 sm:grid-cols-4">
      <label class="block">
        <span class="mb-1 block text-sm font-bold">Volumen m³</span>
        <input
          type="number"
          name="volume_m3"
          min="0"
          value={(fields.volume_m3 as number) ?? ''}
          class="w-full rounded-lg border border-gray-300 px-3 py-2"
        />
      </label>
      <label class="block">
        <span class="mb-1 block text-sm font-bold">Distancia km</span>
        <input
          type="number"
          name="distance_km"
          min="0"
          value={(fields.distance_km as number) ?? ''}
          class="w-full rounded-lg border border-gray-300 px-3 py-2"
        />
      </label>
      <label class="block">
        <span class="mb-1 block text-sm font-bold">Personal</span>
        <input
          type="number"
          name="crew_size"
          min="1"
          max="20"
          value={(fields.crew_size as number) ?? 2}
          class="w-full rounded-lg border border-gray-300 px-3 py-2"
        />
      </label>
      <label class="block">
        <span class="mb-1 block text-sm font-bold">Pisos</span>
        <input
          type="number"
          name="floors"
          min="0"
          max="30"
          value={(fields.floors as number) ?? 0}
          class="w-full rounded-lg border border-gray-300 px-3 py-2"
        />
      </label>
    </div>

    <label class="block">
      <span class="mb-1 block text-sm font-bold">Ítems</span>
      <textarea
        name="items_csv"
        rows="6"
        class="w-full rounded-lg border border-gray-300 px-4 py-2 font-mono text-xs"
        >{itemsText}</textarea
      >
    </label>

    <label class="flex items-center gap-2">
      <input type="checkbox" name="active" value="1" checked={tpl.active} class="h-4 w-4" />
      <span class="text-sm font-bold">Plantilla activa</span>
    </label>

    <div class="flex gap-3 pt-2">
      <button
        class="bg-primary hover:bg-primary-dark rounded-full px-6 py-2 text-sm font-bold text-white"
      >
        Guardar cambios
      </button>
      <a
        href="/panel/cotizador/plantillas/"
        class="rounded-full border border-gray-300 px-6 py-2 text-sm font-bold hover:bg-gray-100"
      >
        Cancelar
      </a>
    </div>
  </form>
</CotizadorLayout>
