---
export const prerender = false;

import CotizadorLayout from '@layouts/CotizadorLayout.astro';
import { db } from '@db/client';
import { quoteTemplates, users } from '@db/schema';
import { desc, eq } from 'drizzle-orm';

const rows = await db
  .select({
    id: quoteTemplates.id,
    name: quoteTemplates.name,
    serviceType: quoteTemplates.serviceType,
    active: quoteTemplates.active,
    createdAt: quoteTemplates.createdAt,
    creatorName: users.fullName,
  })
  .from(quoteTemplates)
  .leftJoin(users, eq(users.id, quoteTemplates.createdBy))
  .orderBy(desc(quoteTemplates.createdAt))
  .all();

const created = Astro.url.searchParams.get('created');
const updated = Astro.url.searchParams.get('updated');
const deleted = Astro.url.searchParams.get('deleted');
---

<CotizadorLayout title="Plantillas">
  <header class="mb-6 flex items-start justify-between gap-4">
    <div>
      <h1 class="font-heading text-2xl font-bold md:text-3xl">Plantillas de cotización</h1>
      <p class="mt-1 text-sm text-gray-600">Pre-llenan los formularios para cotizar más rápido.</p>
    </div>
    <a
      href="/panel/cotizador/plantillas/nueva/"
      class="bg-primary hover:bg-primary-dark rounded-full px-5 py-2 text-sm font-bold text-white"
    >
      + Nueva plantilla
    </a>
  </header>

  {
    created && (
      <div class="mb-4 rounded-lg border-l-4 border-green-500 bg-green-50 p-3 text-sm text-green-800">
        Plantilla creada.
      </div>
    )
  }
  {
    updated && (
      <div class="mb-4 rounded-lg border-l-4 border-green-500 bg-green-50 p-3 text-sm text-green-800">
        Plantilla actualizada.
      </div>
    )
  }
  {
    deleted && (
      <div class="mb-4 rounded-lg border-l-4 border-amber-500 bg-amber-50 p-3 text-sm text-amber-800">
        Plantilla desactivada.
      </div>
    )
  }

  {
    rows.length === 0 ? (
      <div class="rounded-2xl border border-dashed border-gray-300 bg-white p-8 text-center text-sm text-gray-600">
        Sin plantillas. Crea la primera para acelerar tus cotizaciones.
      </div>
    ) : (
      <div class="overflow-x-auto rounded-2xl border border-gray-200 bg-white">
        <table class="w-full text-left text-sm">
          <thead class="bg-gray-50 text-xs font-bold tracking-wider uppercase">
            <tr>
              <th class="px-4 py-3">Nombre</th>
              <th class="px-4 py-3">Servicio</th>
              <th class="px-4 py-3">Creador</th>
              <th class="px-4 py-3">Estado</th>
              <th class="px-4 py-3" />
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            {rows.map((t) => (
              <tr class:list={[!t.active && 'text-gray-400']}>
                <td class="px-4 py-3 font-bold">{t.name}</td>
                <td class="px-4 py-3 text-xs">{t.serviceType}</td>
                <td class="px-4 py-3 text-xs">{t.creatorName ?? '—'}</td>
                <td class="px-4 py-3 text-xs">
                  {t.active ? (
                    <span class="rounded-full bg-green-100 px-2 py-0.5 font-bold text-green-800">
                      Activa
                    </span>
                  ) : (
                    <span class="rounded-full bg-gray-200 px-2 py-0.5 font-bold text-gray-600">
                      Inactiva
                    </span>
                  )}
                </td>
                <td class="px-4 py-3 text-right">
                  <a
                    href={`/panel/cotizador/plantillas/${t.id}/`}
                    class="text-primary text-xs font-bold hover:underline"
                  >
                    Editar →
                  </a>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )
  }
</CotizadorLayout>
