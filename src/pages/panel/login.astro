---
export const prerender = false;

import PanelLayout from '@layouts/PanelLayout.astro';
import { SITE } from '@lib/site';

const nextParam = Astro.url.searchParams.get('next') ?? '';
const errorParam = Astro.url.searchParams.get('error');

const errorMessage =
  errorParam === 'invalid'
    ? 'Credenciales inválidas.'
    : errorParam === 'rate'
      ? 'Demasiados intentos. Espera 15 minutos e intenta de nuevo.'
      : errorParam === 'expired'
        ? 'Tu contraseña temporal expiró. Pide al administrador que la regenere.'
        : errorParam === 'inactive'
          ? 'Tu cuenta está desactivada. Contacta al administrador.'
          : null;
---

<PanelLayout title="Iniciar sesión">
  <main class="relative flex min-h-screen items-center justify-center overflow-hidden p-4">
    {/* Fondo decorativo con blobs gradient */}
    <div aria-hidden="true" class="pointer-events-none absolute inset-0">
      <div class="bg-primary-200/40 absolute -top-40 -left-40 h-96 w-96 rounded-full blur-3xl">
      </div>
      <div class="bg-primary-100/60 absolute -right-40 bottom-0 h-96 w-96 rounded-full blur-3xl">
      </div>
    </div>

    <div class="panel-fade-in relative w-full max-w-md">
      <div class="mb-8 text-center">
        <div
          class="shadow-brand-lg mx-auto mb-4 inline-flex h-24 w-24 items-center justify-center rounded-3xl bg-white p-3"
        >
          <img
            src={SITE.logo.icon}
            alt="Expresos Ñan"
            width="80"
            height="80"
            class="h-full w-full object-contain"
          />
        </div>
        <h1 class="font-heading text-brand-gradient text-3xl font-bold tracking-tight">
          Panel interno
        </h1>
        <p class="text-primary-700 mt-1 text-xs font-bold tracking-wider uppercase">Expresos Ñan</p>
        <p class="mt-1 text-xs text-gray-500">Acceso restringido</p>
      </div>

      <form
        method="POST"
        action="/api/panel/login/"
        class="shadow-brand-lg space-y-4 rounded-2xl border border-gray-200 bg-white p-6"
      >
        {
          errorMessage && (
            <div
              class="rounded-lg border-l-4 border-red-500 bg-red-50 p-3 text-sm text-red-800"
              role="alert"
            >
              {errorMessage}
            </div>
          )
        }

        <input type="hidden" name="next" value={nextParam} />

        <label class="block">
          <span class="mb-1 block text-sm font-bold">Correo</span>
          <input
            type="email"
            name="email"
            required
            autocomplete="username"
            autofocus
            class="focus:border-primary focus:ring-primary/20 w-full rounded-lg border border-gray-300 px-4 py-2 focus:ring-2 focus:outline-none"
          />
        </label>

        <label class="block">
          <span class="mb-1 block text-sm font-bold">Contraseña</span>
          <input
            type="password"
            name="password"
            required
            minlength="8"
            autocomplete="current-password"
            class="focus:border-primary focus:ring-primary/20 w-full rounded-lg border border-gray-300 px-4 py-2 focus:ring-2 focus:outline-none"
          />
        </label>

        <button
          type="submit"
          class="bg-primary hover:bg-primary-dark focus-visible:outline-primary w-full rounded-full px-6 py-3 font-bold text-white transition-colors focus-visible:outline-2 focus-visible:outline-offset-2"
        >
          Entrar
        </button>

        <p class="text-center text-xs text-gray-500">
          ¿Problemas? Contacta al administrador del sistema.
        </p>
      </form>
    </div>
  </main>
</PanelLayout>
