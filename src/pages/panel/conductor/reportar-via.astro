---
export const prerender = false;
import PanelLayout from '@layouts/PanelLayout.astro';

const ROUTES = [
  { slug: 'cusco-sicuani', label: 'Cusco ↔ Sicuani' },
  { slug: 'cusco-abancay', label: 'Cusco ↔ Abancay' },
  { slug: 'cusco-challhuahuacho', label: 'Cusco ↔ Challhuahuacho' },
  { slug: 'cusco-tambobamba', label: 'Cusco ↔ Tambobamba' },
  { slug: 'cusco-haquira', label: 'Cusco ↔ Haquira' },
  { slug: 'cusco-mara', label: 'Cusco ↔ Mara' },
  { slug: 'cusco-coyllurqui', label: 'Cusco ↔ Coyllurqui' },
  { slug: 'cusco-colquemarca', label: 'Cusco ↔ Colquemarca' },
  { slug: 'cusco-capacmarca', label: 'Cusco ↔ Capacmarca' },
];

const error = Astro.url.searchParams.get('error');
const created = Astro.url.searchParams.get('created');
---

<PanelLayout title="Reportar estado de vía">
  <main class="mx-auto max-w-lg space-y-4 p-4">
    <header>
      <a href="/panel/conductor/hoy/" class="text-xs text-gray-500 hover:text-gray-800">← Hoy</a>
      <h1 class="font-heading mt-1 text-xl font-bold">Reportar estado de vía</h1>
      <p class="mt-1 text-xs text-gray-600">
        Tu reporte caduca a las 24h. Otros conductores ven la advertencia al iniciar el día.
      </p>
    </header>

    {
      created && (
        <div class="rounded-lg border-l-4 border-green-500 bg-green-50 p-3 text-sm text-green-800">
          Reporte enviado.
        </div>
      )
    }
    {
      error && (
        <div class="rounded-lg border-l-4 border-red-500 bg-red-50 p-3 text-sm text-red-800">
          {error}
        </div>
      )
    }

    <form
      method="POST"
      action="/api/panel/route-status/"
      class="space-y-3 rounded-2xl border border-gray-200 bg-white p-5"
    >
      <label class="block">
        <span class="mb-1 block text-sm font-bold">Ruta *</span>
        <select
          name="route_slug"
          required
          class="focus:border-primary focus:ring-primary/20 w-full rounded-lg border border-gray-300 bg-white px-3 py-2 focus:ring-2 focus:outline-none"
        >
          {ROUTES.map((r) => <option value={r.slug}>{r.label}</option>)}
        </select>
      </label>

      <fieldset>
        <legend class="mb-2 text-sm font-bold">Estado *</legend>
        <div class="grid grid-cols-2 gap-2 text-sm">
          <label class="flex items-center gap-2 rounded-lg border border-gray-200 p-2">
            <input type="radio" name="status" value="ok" required class="h-4 w-4" />
            <span class="font-bold text-green-700">OK</span>
          </label>
          <label class="flex items-center gap-2 rounded-lg border border-gray-200 p-2">
            <input type="radio" name="status" value="precaucion" class="h-4 w-4" />
            <span class="font-bold text-amber-700">Precaución</span>
          </label>
          <label class="flex items-center gap-2 rounded-lg border border-gray-200 p-2">
            <input type="radio" name="status" value="bloqueada" class="h-4 w-4" />
            <span class="font-bold text-red-700">Bloqueada</span>
          </label>
          <label class="flex items-center gap-2 rounded-lg border border-gray-200 p-2">
            <input type="radio" name="status" value="desvio" class="h-4 w-4" />
            <span class="font-bold text-blue-700">Desvío</span>
          </label>
        </div>
      </fieldset>

      <label class="block">
        <span class="mb-1 block text-sm font-bold">Nota (obligatoria si no es OK) *</span>
        <textarea
          name="note"
          rows="3"
          maxlength="300"
          placeholder="Paro en Livitaca hasta las 18:00 / huaico en abra Pillpinto…"
          class="focus:border-primary focus:ring-primary/20 w-full rounded-lg border border-gray-300 px-3 py-2 focus:ring-2 focus:outline-none"
        ></textarea>
      </label>

      <button
        type="submit"
        class="bg-primary hover:bg-primary-dark w-full rounded-full py-3 text-sm font-bold text-white"
      >
        Enviar reporte
      </button>
    </form>
  </main>
</PanelLayout>
