---
export const prerender = false;

import AdminLayout from '@layouts/AdminLayout.astro';
import { db } from '@db/client';
import { driverAssignments, users, units } from '@db/schema';
import { desc, eq } from 'drizzle-orm';
import { alias } from 'drizzle-orm/sqlite-core';

const driverUser = alias(users, 'driverUser');

// Listado completo (vigentes y cerradas). El orden muestra vigentes primero.
const rows = await db
  .select({
    id: driverAssignments.id,
    userId: driverAssignments.userId,
    unitId: driverAssignments.unitId,
    startsAt: driverAssignments.startsAt,
    endsAt: driverAssignments.endsAt,
    driverName: driverUser.fullName,
    driverEmail: driverUser.email,
    plate: units.plate,
    tonnage: units.tonnage,
    alias: units.alias,
  })
  .from(driverAssignments)
  .innerJoin(driverUser, eq(driverUser.id, driverAssignments.userId))
  .innerJoin(units, eq(units.id, driverAssignments.unitId))
  .orderBy(desc(driverAssignments.startsAt))
  .all();

const created = Astro.url.searchParams.get('created') === 'true';
const closed = Astro.url.searchParams.get('closed') === 'true';
const filterUnitId = Astro.url.searchParams.get('unit') ?? null;

const filteredRows = filterUnitId ? rows.filter((r) => r.unitId === filterUnitId) : rows;
---

<AdminLayout title="Asignaciones conductor ↔ unidad">
  <header class="mb-6 flex flex-wrap items-start justify-between gap-4">
    <div>
      <h1 class="font-heading text-2xl font-bold md:text-3xl">Asignaciones</h1>
      <p class="mt-1 text-sm text-gray-600">Conductor responsable por unidad.</p>
    </div>
    <a
      href="/panel/admin/asignaciones/nueva/"
      class="bg-primary hover:bg-primary-dark rounded-full px-5 py-2 text-sm font-bold text-white"
    >
      + Nueva asignación
    </a>
  </header>

  {
    created && (
      <div
        class="mb-4 rounded-lg border-l-4 border-green-500 bg-green-50 p-3 text-sm text-green-800"
        role="status"
      >
        Asignación creada correctamente.
      </div>
    )
  }
  {
    closed && (
      <div
        class="mb-4 rounded-lg border-l-4 border-amber-500 bg-amber-50 p-3 text-sm text-amber-800"
        role="status"
      >
        Asignación cerrada.
      </div>
    )
  }
  {
    filterUnitId && (
      <div class="mb-4 flex items-center gap-2 text-sm text-gray-600">
        Filtrando por unidad.
        <a href="/panel/admin/asignaciones/" class="text-primary text-xs font-bold hover:underline">
          Quitar filtro
        </a>
      </div>
    )
  }

  {
    filteredRows.length === 0 ? (
      <div class="rounded-2xl border border-dashed border-gray-300 bg-white p-10 text-center">
        <p class="font-bold">Aún no hay asignaciones.</p>
        <p class="mt-1 text-sm text-gray-600">
          Crea una asignación para que el conductor pueda registrar su día.
        </p>
      </div>
    ) : (
      <div class="overflow-x-auto rounded-2xl border border-gray-200 bg-white">
        <table class="w-full text-left text-sm">
          <thead class="bg-gray-50 text-xs font-bold tracking-wider uppercase">
            <tr>
              <th class="px-4 py-3">Conductor</th>
              <th class="px-4 py-3">Unidad</th>
              <th class="px-4 py-3">Desde</th>
              <th class="px-4 py-3">Hasta</th>
              <th class="px-4 py-3">Estado</th>
              <th class="px-4 py-3" />
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            {filteredRows.map((a) => {
              const vigente = a.endsAt === null;
              return (
                <tr class:list={[!vigente && 'text-gray-400']}>
                  <td class="px-4 py-3">
                    <p class="font-bold">{a.driverName}</p>
                    <p class="text-xs text-gray-500">{a.driverEmail}</p>
                  </td>
                  <td class="px-4 py-3 font-mono text-xs font-bold">
                    {a.plate} ({a.tonnage}t){a.alias ? ` · ${a.alias}` : ''}
                  </td>
                  <td class="px-4 py-3 text-xs">{a.startsAt}</td>
                  <td class="px-4 py-3 text-xs">{a.endsAt ?? '—'}</td>
                  <td class="px-4 py-3">
                    {vigente ? (
                      <span class="inline-block rounded-full bg-green-100 px-2 py-0.5 text-xs font-bold text-green-800">
                        Vigente
                      </span>
                    ) : (
                      <span class="inline-block rounded-full bg-gray-200 px-2 py-0.5 text-xs font-bold text-gray-600">
                        Cerrada
                      </span>
                    )}
                  </td>
                  <td class="px-4 py-3 text-right">
                    {vigente && (
                      <form
                        method="POST"
                        action={`/api/panel/assignments/${a.id}/close/`}
                        class="inline"
                      >
                        <button
                          type="submit"
                          class="text-xs font-bold text-red-600 hover:underline"
                          data-confirm="¿Cerrar esta asignación? El conductor dejará de poder registrar para la unidad."
                          data-loading-text="…"
                        >
                          Cerrar
                        </button>
                      </form>
                    )}
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    )
  }
</AdminLayout>
