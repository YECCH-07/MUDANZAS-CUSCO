---
export const prerender = false;

import AdminLayout from '@layouts/AdminLayout.astro';
import { db } from '@db/client';
import { units, driverAssignments, users } from '@db/schema';
import { desc, eq, isNull, and } from 'drizzle-orm';

// Traer unidades + conductor asignado vigente (si existe).
const rows = await db
  .select({
    id: units.id,
    plate: units.plate,
    tonnage: units.tonnage,
    alias: units.alias,
    soatExpires: units.soatExpires,
    rtvExpires: units.rtvExpires,
    active: units.active,
    createdAt: units.createdAt,
    assignedDriverId: driverAssignments.userId,
    assignedDriverName: users.fullName,
  })
  .from(units)
  .leftJoin(
    driverAssignments,
    and(eq(driverAssignments.unitId, units.id), isNull(driverAssignments.endsAt)),
  )
  .leftJoin(users, eq(users.id, driverAssignments.userId))
  .orderBy(desc(units.active), units.plate)
  .all();

const successParam = Astro.url.searchParams.get('created');
---

<AdminLayout title="Unidades">
  <header class="mb-6 flex flex-wrap items-start justify-between gap-4">
    <div>
      <h1 class="font-heading text-2xl font-bold md:text-3xl">Unidades</h1>
      <p class="mt-1 text-sm text-gray-600">Flota de camiones 1, 2 y 4 toneladas.</p>
    </div>
    <a
      href="/panel/admin/unidades/nueva/"
      class="bg-primary hover:bg-primary-dark rounded-full px-5 py-2 text-sm font-bold text-white"
    >
      + Nueva unidad
    </a>
  </header>

  {
    successParam && (
      <div
        class="mb-4 rounded-lg border-l-4 border-green-500 bg-green-50 p-3 text-sm text-green-800"
        role="status"
      >
        Unidad <strong>{successParam}</strong> creada correctamente.
      </div>
    )
  }

  {
    rows.length === 0 ? (
      <div class="rounded-2xl border border-dashed border-gray-300 bg-white p-10 text-center">
        <p class="font-bold">Aún no hay unidades registradas.</p>
        <p class="mt-1 text-sm text-gray-600">
          Crea la primera para poder asignar conductores y comenzar a registrar viajes.
        </p>
        <a
          href="/panel/admin/unidades/nueva/"
          class="bg-primary hover:bg-primary-dark mt-4 inline-block rounded-full px-5 py-2 text-sm font-bold text-white"
        >
          Crear primera unidad
        </a>
      </div>
    ) : (
      <div class="overflow-x-auto rounded-2xl border border-gray-200 bg-white">
        <table class="w-full text-left text-sm">
          <thead class="bg-gray-50 text-xs font-bold tracking-wider uppercase">
            <tr>
              <th class="px-4 py-3">Placa</th>
              <th class="px-4 py-3">Tonelaje</th>
              <th class="px-4 py-3">Alias</th>
              <th class="px-4 py-3">Conductor asignado</th>
              <th class="px-4 py-3">SOAT</th>
              <th class="px-4 py-3">RTV</th>
              <th class="px-4 py-3">Estado</th>
              <th class="px-4 py-3" />
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            {rows.map((u) => (
              <tr class:list={[!u.active && 'bg-gray-50 text-gray-400']}>
                <td class="px-4 py-3 font-bold">{u.plate}</td>
                <td class="px-4 py-3">{u.tonnage} t</td>
                <td class="px-4 py-3">{u.alias ?? '—'}</td>
                <td class="px-4 py-3">{u.assignedDriverName ?? '—'}</td>
                <td class="px-4 py-3 text-xs">{u.soatExpires ?? '—'}</td>
                <td class="px-4 py-3 text-xs">{u.rtvExpires ?? '—'}</td>
                <td class="px-4 py-3">
                  {u.active ? (
                    <span class="inline-block rounded-full bg-green-100 px-2 py-0.5 text-xs font-bold text-green-800">
                      Activa
                    </span>
                  ) : (
                    <span class="inline-block rounded-full bg-gray-200 px-2 py-0.5 text-xs font-bold text-gray-600">
                      Inactiva
                    </span>
                  )}
                </td>
                <td class="px-4 py-3 text-right">
                  <a
                    href={`/panel/admin/unidades/${u.id}/`}
                    class="text-primary text-xs font-bold hover:underline"
                  >
                    Editar →
                  </a>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )
  }
</AdminLayout>
