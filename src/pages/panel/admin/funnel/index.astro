---
export const prerender = false;

import AdminLayout from '@layouts/AdminLayout.astro';
import { db } from '@db/client';
import { quotes, receipts } from '@db/schema';
import { between, count } from 'drizzle-orm';

function firstDayOfMonth(): string {
  const d = new Date();
  return `${d.getUTCFullYear()}-${String(d.getUTCMonth() + 1).padStart(2, '0')}-01`;
}
function todayISO(): string {
  return new Date().toISOString().slice(0, 10);
}

const from = Astro.url.searchParams.get('from') || firstDayOfMonth();
const to = Astro.url.searchParams.get('to') || todayISO();

// Funnel: quotes en cada estado dentro del periodo (filtrar por createdAt).
const fromIso = from + 'T00:00:00.000Z';
const toIso = to + 'T23:59:59.999Z';

const allInPeriod = await db
  .select()
  .from(quotes)
  .where(between(quotes.createdAt, fromIso, toIso))
  .all();

const total = allInPeriod.length;
const sent = allInPeriod.filter((q) => ['sent', 'accepted', 'completed'].includes(q.status)).length;
const accepted = allInPeriod.filter((q) => ['accepted', 'completed'].includes(q.status)).length;
const completed = allInPeriod.filter((q) => q.status === 'completed').length;

const receiptsCount = await db
  .select({ n: count() })
  .from(receipts)
  .where(between(receipts.issuedAt, fromIso, toIso))
  .get();

const stages = [
  { label: 'Cotizaciones (lead)', value: total, hint: 'creadas en el periodo' },
  { label: 'Enviadas', value: sent, hint: 'sent o aceptadas' },
  { label: 'Aceptadas', value: accepted, hint: 'aceptadas o completadas' },
  { label: 'Completadas', value: completed, hint: 'trabajos terminados' },
  { label: 'Recibo emitido', value: receiptsCount?.n ?? 0, hint: 'cobro confirmado' },
];

function pct(num: number, denom: number): string {
  if (!denom) return '—';
  return `${((num / denom) * 100).toFixed(1)}%`;
}

// Breakdowns: por servicio + por lead source + por cotizador
const byService: Record<string, number> = {};
const byLead: Record<string, number> = {};
for (const q of allInPeriod) {
  byService[q.serviceType] = (byService[q.serviceType] ?? 0) + 1;
  const lead = q.leadSource ?? 'sin-fuente';
  byLead[lead] = (byLead[lead] ?? 0) + 1;
}

// Razones de rechazo
const rejected = allInPeriod.filter((q) => q.status === 'rejected');
const byReason: Record<string, number> = {};
for (const q of rejected) {
  const r = q.rejectionReason ?? 'sin-razon';
  byReason[r] = (byReason[r] ?? 0) + 1;
}

function bar(value: number, max: number): string {
  const w = max > 0 ? Math.max(2, Math.round((value / max) * 100)) : 2;
  return `width: ${w}%;`;
}
const maxStage = Math.max(...stages.map((s) => s.value));
---

<AdminLayout title="Funnel de conversión">
  <header class="mb-6">
    <h1 class="font-heading text-2xl font-bold md:text-3xl">Funnel de conversión</h1>
    <p class="mt-1 text-sm text-gray-600">Cómo viajan las cotizaciones por el pipeline.</p>
  </header>

  <form
    method="GET"
    class="mb-4 flex flex-wrap items-end gap-3 rounded-2xl border border-gray-200 bg-white p-4"
  >
    <label class="block">
      <span class="mb-1 block text-xs font-bold tracking-wider text-gray-500 uppercase">Desde</span>
      <input
        type="date"
        name="from"
        value={from}
        class="rounded-lg border border-gray-300 px-3 py-2 text-sm"
      />
    </label>
    <label class="block">
      <span class="mb-1 block text-xs font-bold tracking-wider text-gray-500 uppercase">Hasta</span>
      <input
        type="date"
        name="to"
        value={to}
        class="rounded-lg border border-gray-300 px-3 py-2 text-sm"
      />
    </label>
    <button
      class="bg-primary hover:bg-primary-dark rounded-full px-5 py-2 text-sm font-bold text-white"
      >Aplicar</button
    >
  </form>

  <section class="mb-6 rounded-2xl border border-gray-200 bg-white p-6">
    <h2 class="font-heading mb-4 text-lg font-bold">Etapas</h2>
    <ul class="space-y-3">
      {
        stages.map((s, idx) => (
          <li>
            <div class="flex items-end justify-between text-sm">
              <span class="font-bold">{s.label}</span>
              <span>
                <strong class="text-primary text-lg">{s.value}</strong>
                {idx > 0 && (
                  <span class="ml-2 text-xs text-gray-500">
                    {pct(s.value, stages[idx - 1]!.value)} vs etapa anterior
                  </span>
                )}
              </span>
            </div>
            <div class="mt-1 h-3 overflow-hidden rounded bg-gray-100">
              <div class="bg-primary h-full" style={bar(s.value, maxStage)} />
            </div>
            <p class="mt-1 text-[10px] text-gray-500">{s.hint}</p>
          </li>
        ))
      }
    </ul>
    <p class="mt-4 text-xs text-gray-500">
      Conversión global lead → recibo emitido: <strong>{pct(stages[4]!.value, total)}</strong>
    </p>
  </section>

  <div class="grid gap-6 lg:grid-cols-3">
    <section class="rounded-2xl border border-gray-200 bg-white p-5">
      <h3 class="font-heading mb-3 text-sm font-bold tracking-wider text-gray-500 uppercase">
        Por tipo de servicio
      </h3>
      {
        Object.keys(byService).length === 0 ? (
          <p class="text-sm text-gray-500">—</p>
        ) : (
          <ul class="space-y-2 text-sm">
            {Object.entries(byService)
              .sort(([, a], [, b]) => b - a)
              .map(([k, v]) => (
                <li class="flex justify-between">
                  <span>{k}</span>
                  <strong>{v}</strong>
                </li>
              ))}
          </ul>
        )
      }
    </section>

    <section class="rounded-2xl border border-gray-200 bg-white p-5">
      <h3 class="font-heading mb-3 text-sm font-bold tracking-wider text-gray-500 uppercase">
        Por fuente de lead
      </h3>
      {
        Object.keys(byLead).length === 0 ? (
          <p class="text-sm text-gray-500">—</p>
        ) : (
          <ul class="space-y-2 text-sm">
            {Object.entries(byLead)
              .sort(([, a], [, b]) => b - a)
              .map(([k, v]) => (
                <li class="flex justify-between">
                  <span>{k}</span>
                  <strong>{v}</strong>
                </li>
              ))}
          </ul>
        )
      }
    </section>

    <section class="rounded-2xl border border-gray-200 bg-white p-5">
      <h3 class="font-heading mb-3 text-sm font-bold tracking-wider text-gray-500 uppercase">
        Razones de rechazo
      </h3>
      {
        Object.keys(byReason).length === 0 ? (
          <p class="text-sm text-gray-500">—</p>
        ) : (
          <ul class="space-y-2 text-sm">
            {Object.entries(byReason)
              .sort(([, a], [, b]) => b - a)
              .map(([k, v]) => (
                <li class="flex justify-between">
                  <span class="capitalize">{k}</span>
                  <strong>{v}</strong>
                </li>
              ))}
          </ul>
        )
      }
    </section>
  </div>
</AdminLayout>
