---
export const prerender = false;

import AdminLayout from '@layouts/AdminLayout.astro';
import { db } from '@db/client';
import { expenseCategories } from '@db/schema';
import { asc } from 'drizzle-orm';

const cats = await db
  .select()
  .from(expenseCategories)
  .orderBy(asc(expenseCategories.labelEs))
  .all();
const fmt = (c: number | null | undefined): string =>
  `S/ ${((c ?? 0) / 100).toLocaleString('es-PE', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
const created = Astro.url.searchParams.get('created');
const updated = Astro.url.searchParams.get('updated');
---

<AdminLayout title="Categorías de gasto">
  <header class="mb-6 flex items-start justify-between gap-4">
    <div>
      <h1 class="font-heading text-2xl font-bold md:text-3xl">Categorías de gasto</h1>
      <p class="mt-1 text-sm text-gray-600">
        Catálogo controlado para los registros de los conductores. El umbral define el monto a
        partir del cual la foto del comprobante es obligatoria.
      </p>
    </div>
  </header>

  {
    created && (
      <div class="mb-4 rounded-lg border-l-4 border-green-500 bg-green-50 p-3 text-sm text-green-800">
        Categoría añadida.
      </div>
    )
  }
  {
    updated && (
      <div class="mb-4 rounded-lg border-l-4 border-green-500 bg-green-50 p-3 text-sm text-green-800">
        Categoría actualizada.
      </div>
    )
  }

  <div class="grid gap-6 lg:grid-cols-3">
    <form
      method="POST"
      action="/api/panel/expense-categories/"
      class="space-y-3 rounded-2xl border border-gray-200 bg-white p-5 lg:col-span-1"
    >
      <h2 class="font-heading text-sm font-bold tracking-wider text-gray-500 uppercase">
        Nueva categoría
      </h2>
      <label class="block">
        <span class="mb-1 block text-xs font-bold">Slug *</span>
        <input
          type="text"
          name="slug"
          required
          pattern="[a-z0-9_-]{2,30}"
          placeholder="combustible"
          class="w-full rounded-lg border border-gray-300 px-3 py-2 font-mono text-sm"
        />
      </label>
      <label class="block">
        <span class="mb-1 block text-xs font-bold">Etiqueta *</span>
        <input
          type="text"
          name="label_es"
          required
          minlength="2"
          maxlength="60"
          class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm"
        />
      </label>
      <label class="block">
        <span class="mb-1 block text-xs font-bold">Foto obligatoria a partir de (céntimos)</span>
        <input
          type="number"
          name="threshold_cents"
          min="0"
          step="100"
          class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm"
        />
        <span class="mt-1 block text-[10px] text-gray-500">Vacío = nunca obligatoria.</span>
      </label>
      <button
        class="bg-primary hover:bg-primary-dark w-full rounded-full py-2 text-sm font-bold text-white"
      >
        Crear categoría
      </button>
    </form>

    <div class="overflow-x-auto rounded-2xl border border-gray-200 bg-white lg:col-span-2">
      <table class="w-full text-left text-sm">
        <thead class="bg-gray-50 text-xs font-bold tracking-wider uppercase">
          <tr>
            <th class="px-4 py-3">Slug</th>
            <th class="px-4 py-3">Etiqueta</th>
            <th class="px-4 py-3 text-right">Foto desde</th>
            <th class="px-4 py-3">Estado</th>
            <th class="px-4 py-3"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          {
            cats.map((c) => (
              <tr>
                <td class="px-4 py-3 font-mono text-xs">{c.slug}</td>
                <td class="px-4 py-3 font-bold">{c.labelEs}</td>
                <td class="px-4 py-3 text-right text-xs">
                  {c.requiresPhotoAboveCents !== null ? fmt(c.requiresPhotoAboveCents) : '—'}
                </td>
                <td class="px-4 py-3 text-xs">
                  {c.active ? (
                    <span class="rounded-full bg-green-100 px-2 py-0.5 font-bold text-green-800">
                      activa
                    </span>
                  ) : (
                    <span class="rounded-full bg-gray-200 px-2 py-0.5 font-bold text-gray-600">
                      inactiva
                    </span>
                  )}
                </td>
                <td class="px-4 py-3 text-right">
                  <form method="POST" action={`/api/panel/expense-categories/${c.id}/toggle/`}>
                    <button class="text-xs font-bold text-amber-700 hover:underline">
                      {c.active ? 'Desactivar' : 'Activar'}
                    </button>
                  </form>
                </td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
  </div>
</AdminLayout>
