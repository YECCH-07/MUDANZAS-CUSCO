---
export const prerender = false;

import AdminLayout from '@layouts/AdminLayout.astro';
import { db } from '@db/client';
import { users } from '@db/schema';
import { desc } from 'drizzle-orm';

const rows = await db
  .select({
    id: users.id,
    email: users.email,
    fullName: users.fullName,
    role: users.role,
    phone: users.phone,
    active: users.active,
    mustChangePassword: users.mustChangePassword,
    createdAt: users.createdAt,
  })
  .from(users)
  .orderBy(desc(users.createdAt))
  .all();

const createdParam = Astro.url.searchParams.get('created');
const resetParam = Astro.url.searchParams.get('reset');
const tempPwParam = Astro.url.searchParams.get('pw');

const roleLabel = (r: string): string =>
  ({ superadmin: 'Superadmin', cotizador: 'Cotizador', conductor: 'Conductor' })[r] ?? r;
---

<AdminLayout title="Usuarios">
  <header class="mb-6 flex flex-wrap items-start justify-between gap-4">
    <div>
      <h1 class="font-heading text-2xl font-bold md:text-3xl">Usuarios</h1>
      <p class="mt-1 text-sm text-gray-600">Conductores, cotizadores y administradores.</p>
    </div>
    <a
      href="/panel/admin/usuarios/nuevo/"
      class="bg-primary hover:bg-primary-dark rounded-full px-5 py-2 text-sm font-bold text-white"
    >
      + Nuevo usuario
    </a>
  </header>

  {
    (createdParam || resetParam) && tempPwParam && (
      <div
        class="mb-4 rounded-2xl border-l-4 border-green-500 bg-green-50 p-4 text-sm text-green-900"
        role="status"
      >
        <p class="font-bold">
          {createdParam
            ? `Usuario ${createdParam} creado`
            : `Contraseña reseteada para ${resetParam}`}
        </p>
        <p class="mt-2">Contraseña temporal (válida 24h, debe cambiarla al primer login):</p>
        <code class="mt-2 block rounded bg-white px-3 py-2 font-mono text-base text-green-900">
          {tempPwParam}
        </code>
        <p class="mt-3 text-xs text-green-800">
          Comparte esta clave UNA sola vez con el usuario. Si recargas la página desaparece —
          guárdala o envíasela ya. Si SMTP está configurado, también recibió el email.
        </p>
      </div>
    )
  }

  <div class="overflow-x-auto rounded-2xl border border-gray-200 bg-white">
    <table class="w-full text-left text-sm">
      <thead class="bg-gray-50 text-xs font-bold tracking-wider uppercase">
        <tr>
          <th class="px-4 py-3">Nombre</th>
          <th class="px-4 py-3">Email</th>
          <th class="px-4 py-3">Rol</th>
          <th class="px-4 py-3">Teléfono</th>
          <th class="px-4 py-3">Estado</th>
          <th class="px-4 py-3">Creado</th>
          <th class="px-4 py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        {
          rows.map((u) => (
            <tr class:list={[!u.active && 'bg-gray-50 text-gray-400']}>
              <td class="px-4 py-3 font-bold">{u.fullName}</td>
              <td class="px-4 py-3 text-xs">{u.email}</td>
              <td class="px-4 py-3">
                <span
                  class:list={[
                    'inline-block rounded-full px-2 py-0.5 text-xs font-bold',
                    u.role === 'superadmin' && 'bg-primary/10 text-primary',
                    u.role === 'cotizador' && 'bg-blue-100 text-blue-800',
                    u.role === 'conductor' && 'bg-amber-100 text-amber-800',
                  ]}
                >
                  {roleLabel(u.role)}
                </span>
              </td>
              <td class="px-4 py-3 text-xs">{u.phone ?? '—'}</td>
              <td class="px-4 py-3">
                {u.active ? (
                  <span class="inline-block rounded-full bg-green-100 px-2 py-0.5 text-xs font-bold text-green-800">
                    Activo{u.mustChangePassword ? ' (pw pendiente)' : ''}
                  </span>
                ) : (
                  <span class="inline-block rounded-full bg-gray-200 px-2 py-0.5 text-xs font-bold text-gray-600">
                    Inactivo
                  </span>
                )}
              </td>
              <td class="px-4 py-3 text-xs text-gray-500">{u.createdAt?.slice(0, 10)}</td>
              <td class="px-4 py-3 text-right">
                <a
                  href={`/panel/admin/usuarios/${u.id}/documentos/`}
                  class="text-primary text-xs font-bold hover:underline"
                >
                  Docs →
                </a>
                <form
                  method="POST"
                  action={`/api/panel/users/${u.id}/reset-password/`}
                  class="ml-2 inline"
                >
                  <button
                    class="text-xs text-amber-700 hover:underline"
                    data-confirm="¿Resetear contraseña? El usuario tendrá una nueva temporal de 24h y sus sesiones quedarán invalidadas."
                    data-loading-text="Reseteando…"
                  >
                    Reset pw
                  </button>
                </form>
              </td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>

  <p class="mt-4 text-xs text-gray-500">
    Gestión completa (reset password, impersonación, desactivar, 2FA) se habilita en PANEL-03.
  </p>
</AdminLayout>
