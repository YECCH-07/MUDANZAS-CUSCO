---
export const prerender = false;

import AdminLayout from '@layouts/AdminLayout.astro';
import PhotoUploader from '@components/panel/PhotoUploader.astro';
import { db } from '@db/client';
import { users, driverDocuments } from '@db/schema';
import { alias } from 'drizzle-orm/sqlite-core';
import { desc, eq } from 'drizzle-orm';
import { isStorageConfigured, signedGetUrl } from '@lib/panel/storage';

const { id } = Astro.params;
if (!id) return Astro.redirect('/panel/admin/usuarios/');
const target = await db.select().from(users).where(eq(users.id, id)).get();
if (!target) return Astro.redirect('/panel/admin/usuarios/');

const uploader = alias(users, 'uploader');

const docs = await db
  .select({
    id: driverDocuments.id,
    kind: driverDocuments.kind,
    fileKey: driverDocuments.fileKey,
    validUntil: driverDocuments.validUntil,
    notes: driverDocuments.notes,
    uploadedAt: driverDocuments.uploadedAt,
    uploaderName: uploader.fullName,
  })
  .from(driverDocuments)
  .leftJoin(uploader, eq(uploader.id, driverDocuments.uploadedBy))
  .where(eq(driverDocuments.userId, id))
  .orderBy(desc(driverDocuments.uploadedAt))
  .all();

const docsWithUrl = await Promise.all(
  docs.map(async (d) => ({
    ...d,
    url: isStorageConfigured() ? await signedGetUrl('docs', d.fileKey) : null,
  })),
);

const labels: Record<string, string> = {
  licencia: 'Licencia',
  dni: 'DNI',
  record_policial: 'Récord policial',
  certificado_medico: 'Certificado médico',
  contrato: 'Contrato',
  otro: 'Otro',
};

const today = new Date().toISOString().slice(0, 10);
function expiry(d: string | null) {
  if (!d) return null;
  const days = Math.floor(
    (new Date(d + 'T00:00:00').getTime() - new Date(today + 'T00:00:00').getTime()) / 86400000,
  );
  if (days < 0) return { label: 'VENCIDO', cls: 'bg-red-100 text-red-800' };
  if (days <= 7) return { label: `${days} días`, cls: 'bg-red-100 text-red-800' };
  if (days <= 30) return { label: `${days} días`, cls: 'bg-amber-100 text-amber-800' };
  return { label: `${days} días`, cls: 'bg-green-100 text-green-800' };
}

const created = Astro.url.searchParams.get('created');
const deleted = Astro.url.searchParams.get('deleted');
---

<AdminLayout title={`Documentos · ${target.fullName}`}>
  <header class="mb-6">
    <nav class="mb-2 text-sm">
      <a href="/panel/admin/usuarios/" class="text-gray-500 hover:text-gray-700">← Usuarios</a>
    </nav>
    <h1 class="font-heading text-2xl font-bold">Documentos del usuario</h1>
    <p class="mt-1 text-sm text-gray-600">{target.fullName} · {target.role}</p>
  </header>

  {
    created && (
      <div class="mb-4 rounded-lg border-l-4 border-green-500 bg-green-50 p-3 text-sm text-green-800">
        Documento subido.
      </div>
    )
  }
  {
    deleted && (
      <div class="mb-4 rounded-lg border-l-4 border-amber-500 bg-amber-50 p-3 text-sm text-amber-800">
        Documento eliminado.
      </div>
    )
  }

  <div class="grid gap-6 lg:grid-cols-3">
    <form
      method="POST"
      action="/api/panel/driver-documents/"
      class="space-y-3 rounded-2xl border border-gray-200 bg-white p-5 lg:col-span-1"
    >
      <h2 class="font-heading text-sm font-bold tracking-wider text-gray-500 uppercase">
        Subir documento
      </h2>
      <input type="hidden" name="user_id" value={target.id} />

      <label class="block">
        <span class="mb-1 block text-xs font-bold">Tipo *</span>
        <select
          name="kind"
          required
          class="w-full rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm"
        >
          <option value="">—</option>
          {Object.entries(labels).map(([slug, lbl]) => <option value={slug}>{lbl}</option>)}
        </select>
      </label>

      <label class="block">
        <span class="mb-1 block text-xs font-bold">Vigencia</span>
        <input
          type="date"
          name="valid_until"
          class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm"
        />
      </label>

      <label class="block">
        <span class="mb-1 block text-xs font-bold">Notas</span>
        <input
          type="text"
          name="notes"
          maxlength="200"
          class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm"
        />
      </label>

      <div>
        <span class="mb-1 block text-xs font-bold">Archivo (PDF o imagen) *</span>
        <PhotoUploader
          name="file_key"
          scope="docs"
          prefix="driver-docs"
          allowPdf={true}
          label="Elegir archivo"
        />
      </div>

      <button
        class="bg-primary hover:bg-primary-dark w-full rounded-full py-2 text-sm font-bold text-white"
      >
        Subir documento
      </button>
    </form>

    <div class="space-y-3 lg:col-span-2">
      {
        docsWithUrl.length === 0 ? (
          <div class="rounded-2xl border border-dashed border-gray-300 bg-white p-8 text-center text-sm text-gray-600">
            Sin documentos para este usuario.
          </div>
        ) : (
          docsWithUrl.map((d) => {
            const exp = expiry(d.validUntil);
            return (
              <div class="rounded-2xl border border-gray-200 bg-white p-4">
                <div class="flex items-start justify-between gap-3">
                  <div>
                    <p class="font-bold">{labels[d.kind] ?? d.kind}</p>
                    <p class="mt-1 text-xs text-gray-600">
                      {d.uploaderName ?? '—'} · {d.uploadedAt.slice(0, 10)}
                      {d.validUntil && ` · vence ${d.validUntil}`}
                    </p>
                    {d.notes && <p class="mt-1 text-xs text-gray-500">{d.notes}</p>}
                  </div>
                  <div class="flex flex-col items-end gap-1">
                    {exp && (
                      <span
                        class:list={['rounded-full px-2 py-0.5 text-[10px] font-bold', exp.cls]}
                      >
                        {exp.label}
                      </span>
                    )}
                    {d.url && (
                      <a
                        href={d.url}
                        target="_blank"
                        rel="noopener"
                        class="text-primary text-xs font-bold hover:underline"
                      >
                        Abrir →
                      </a>
                    )}
                    <form method="POST" action={`/api/panel/driver-documents/${d.id}/delete/`}>
                      <button
                        class="text-xs text-red-600 hover:underline"
                        onclick="return confirm('¿Eliminar?');"
                      >
                        eliminar
                      </button>
                    </form>
                  </div>
                </div>
              </div>
            );
          })
        )
      }
    </div>
  </div>
</AdminLayout>
