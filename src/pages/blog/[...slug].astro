---
/*
 * Ruta dinámica para cada artículo del blog. URL: /blog/[slug]/
 * - getStaticPaths: entrega todos los posts publicados (no draft).
 * - related: 3 posts de la misma categoría (excluyendo el actual).
 * - Render: render() del MDX dentro de BlogPostLayout.
 */
import { getCollection, render } from 'astro:content';
import BlogPostLayout from '@layouts/BlogPostLayout.astro';
import type { CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const all = await getCollection('blog', ({ data }) => !data.draft);
  return all.map((entry) => {
    const related = all
      .filter((e) => e.data.category === entry.data.category && e.id !== entry.id)
      .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
      .slice(0, 3);
    return {
      params: { slug: entry.id.replace(/\.(md|mdx)$/, '') },
      props: { entry, related },
    };
  });
}

interface Props {
  entry: CollectionEntry<'blog'>;
  related: CollectionEntry<'blog'>[];
}

const { entry, related } = Astro.props as Props;
const { Content } = await render(entry);
---

<BlogPostLayout entry={entry} related={related}>
  <Content />
</BlogPostLayout>
