---
/*
 * Listado por etiqueta. URL: /blog/etiqueta/[tag]/
 * Los tags pueden tener acentos; se usan como string en el slug.
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import Container from '@components/Container.astro';
import Section from '@components/Section.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import CTASection from '@components/CTASection.astro';
import SectionHeader from '@components/SectionHeader.astro';
import { getCollection } from 'astro:content';
import { CATEGORIES, formatPubDate } from '@lib/blog';
import type { CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const all = await getCollection('blog', ({ data }) => !data.draft);
  const tags = new Set<string>();
  all.forEach((p) => p.data.tags.forEach((t) => tags.add(t)));
  return Array.from(tags).map((tag) => ({
    params: { tag },
    props: {
      tag,
      posts: all
        .filter((p) => p.data.tags.includes(tag))
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
    },
  }));
}

interface Props {
  tag: string;
  posts: CollectionEntry<'blog'>[];
}

const { tag, posts } = Astro.props as Props;
const postUrl = (id: string) => `/blog/${id.replace(/\.(md|mdx)$/, '')}/`;
---

<BaseLayout
  title={`Artículos con la etiqueta “${tag}” | Blog Expresos Ñan`}
  description={`Artículos del blog de Expresos Ñan etiquetados con ${tag}. Consejos y guías sobre mudanzas en Cusco.`}
  ogImage="/wp-content/uploads/2024/05/MUDANZAS-CUSCO.png"
>
  <Section spacing="sm">
    <Container>
      <Breadcrumbs
        items={[
          { label: 'Inicio', href: '/' },
          { label: 'Blog', href: '/blog/' },
          { label: `Etiqueta: ${tag}` },
        ]}
      />
    </Container>
  </Section>

  <Section background="white" spacing="md">
    <Container>
      <SectionHeader
        eyebrow="Etiqueta"
        title={`#${tag}`}
        subtitle={`${posts.length} artículo${posts.length === 1 ? '' : 's'} con esta etiqueta.`}
      />
    </Container>
  </Section>

  <Section background="gray" spacing="lg">
    <Container>
      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        {
          posts.map((post) => (
            <article class="group flex h-full flex-col overflow-hidden rounded-2xl border border-gray-100 bg-white shadow-sm transition-all hover:shadow-lg motion-safe:hover:-translate-y-1">
              <a href={postUrl(post.id)} class="block aspect-[16/9] overflow-hidden bg-gray-100">
                <img
                  src={post.data.heroImage}
                  alt={post.data.heroImageAlt}
                  loading="lazy"
                  decoding="async"
                  width="480"
                  height="270"
                  class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                />
              </a>
              <div class="flex flex-1 flex-col p-6">
                <div class="mb-2 flex items-center gap-2 text-xs">
                  <a
                    href={`/blog/categoria/${post.data.category}/`}
                    class="bg-primary/10 text-primary-dark rounded-full px-2.5 py-0.5 font-bold tracking-wider uppercase"
                  >
                    {CATEGORIES[post.data.category].label}
                  </a>
                  <time datetime={post.data.pubDate.toISOString()} class="text-gray-500">
                    {formatPubDate(post.data.pubDate)}
                  </time>
                </div>
                <h2 class="font-heading mb-2 text-lg leading-tight font-bold">
                  <a href={postUrl(post.id)} class="hover:text-primary">
                    {post.data.title}
                  </a>
                </h2>
                <p class="mb-4 line-clamp-3 flex-1 text-sm text-gray-700">
                  {post.data.description}
                </p>
                <a
                  href={postUrl(post.id)}
                  class="text-primary hover:text-primary-dark mt-auto inline-flex items-center gap-1 text-sm font-bold"
                >
                  Leer artículo →
                </a>
              </div>
            </article>
          ))
        }
      </div>
    </Container>
  </Section>

  <CTASection
    title="¿Quieres más contenido como este?"
    whatsappMessage="Hola, tengo una consulta sobre mi mudanza en Cusco."
  />
</BaseLayout>
