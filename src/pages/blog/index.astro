---
/*
 * Listado principal del blog. Muestra todos los artículos publicados ordenados
 * por fecha desc, con filtros rápidos por categoría.
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import Container from '@components/Container.astro';
import Section from '@components/Section.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import CTASection from '@components/CTASection.astro';
import SectionHeader from '@components/SectionHeader.astro';
import { getCollection } from 'astro:content';
import { CATEGORIES, formatPubDate } from '@lib/blog';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const postUrl = (id: string) => `/blog/${id.replace(/\.(md|mdx)$/, '')}/`;
---

<BaseLayout
  title="Blog de Mudanzas y Fletes en Cusco | Expresos Ñan"
  description="Consejos, guías y precios sobre mudanzas, embalaje, almacenaje y rutas desde Cusco. Contenido útil para familias, estudiantes y empresas."
  ogImage="/wp-content/uploads/2024/05/MUDANZAS-CUSCO.png"
  whatsappMessage="Hola, estoy leyendo el blog y quiero cotización para mi mudanza."
>
  <Fragment slot="head">
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Blog Expresos Ñan"
      href="/blog/rss.xml"
    />
  </Fragment>

  <Section spacing="sm">
    <Container>
      <Breadcrumbs items={[{ label: 'Inicio', href: '/' }, { label: 'Blog' }]} />
    </Container>
  </Section>

  <Section background="white" spacing="md">
    <Container>
      <SectionHeader
        eyebrow="Blog"
        title="Consejos, guías y precios reales"
        subtitle="Escribimos sobre mudanzas en Cusco basado en lo que realmente preguntan nuestros clientes. Sin relleno, sin SEO vacío — información práctica."
      />

      {/* Filtro por categorías */}
      <div class="mt-8 flex flex-wrap gap-2">
        <a
          href="/blog/"
          class="hover:border-primary hover:text-primary rounded-full border border-gray-300 bg-white px-4 py-2 text-sm font-bold text-gray-700 transition-colors"
        >
          Todos
        </a>
        {
          Object.entries(CATEGORIES).map(([slug, { label }]) => (
            <a
              href={`/blog/categoria/${slug}/`}
              class="hover:border-primary hover:text-primary rounded-full border border-gray-300 bg-white px-4 py-2 text-sm text-gray-700 transition-colors"
            >
              {label}
            </a>
          ))
        }
      </div>
    </Container>
  </Section>

  {/* Grid de artículos */}
  <Section background="gray" spacing="lg">
    <Container>
      {
        posts.length === 0 ? (
          <p class="text-center text-gray-600">No hay artículos publicados todavía.</p>
        ) : (
          <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
            {posts.map((post) => (
              <article class="group hover:border-primary/30 flex h-full flex-col overflow-hidden rounded-2xl border border-gray-100 bg-white shadow-sm transition-all hover:shadow-lg motion-safe:hover:-translate-y-1">
                <a href={postUrl(post.id)} class="block aspect-[16/9] overflow-hidden bg-gray-100">
                  <img
                    src={post.data.heroImage}
                    alt={post.data.heroImageAlt}
                    loading="lazy"
                    decoding="async"
                    width="480"
                    height="270"
                    class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                  />
                </a>
                <div class="flex flex-1 flex-col p-6">
                  <div class="mb-3 flex flex-wrap items-center gap-2 text-xs">
                    <a
                      href={`/blog/categoria/${post.data.category}/`}
                      class="bg-primary/10 text-primary-dark hover:bg-primary rounded-full px-2.5 py-0.5 font-bold tracking-wider uppercase transition-colors hover:text-white"
                    >
                      {CATEGORIES[post.data.category].label}
                    </a>
                    <time datetime={post.data.pubDate.toISOString()} class="text-gray-500">
                      {formatPubDate(post.data.pubDate)}
                    </time>
                  </div>
                  <h2 class="font-heading mb-2 text-lg leading-tight font-bold">
                    <a href={postUrl(post.id)} class="hover:text-primary">
                      {post.data.title}
                    </a>
                  </h2>
                  <p class="mb-4 line-clamp-3 flex-1 text-sm text-gray-700">
                    {post.data.description}
                  </p>
                  <div class="mt-auto flex items-center justify-between">
                    <a
                      href={postUrl(post.id)}
                      class="text-primary hover:text-primary-dark inline-flex items-center gap-1 text-sm font-bold"
                    >
                      Leer artículo
                      <svg
                        class="h-4 w-4"
                        viewBox="0 0 20 20"
                        fill="currentColor"
                        aria-hidden="true"
                      >
                        <path
                          fill-rule="evenodd"
                          d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z"
                          clip-rule="evenodd"
                        />
                      </svg>
                    </a>
                    {post.data.readingTime && (
                      <span class="text-xs text-gray-500">{post.data.readingTime} min</span>
                    )}
                  </div>
                </div>
              </article>
            ))}
          </div>
        )
      }
    </Container>
  </Section>

  <CTASection
    title="¿Tu pregunta no está en el blog?"
    subtitle="Escríbenos por WhatsApp y resolvemos al momento."
    whatsappMessage="Hola, tengo una consulta sobre mi mudanza en Cusco."
  />
</BaseLayout>
