---
import BaseLayout from '@layouts/BaseLayout.astro';
import Container from '@components/Container.astro';
import Section from '@components/Section.astro';
import Hero from '@components/Hero.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import CTASection from '@components/CTASection.astro';

const priceRows = [
  { label: 'Taxi cargo / mini move', price: 'S/ 150 – 300', notes: '1 t unit, 2-4 hours' },
  { label: 'Room / studio apartment', price: 'S/ 250 – 450', notes: '2 t unit, 3-5 hours' },
  { label: '1-2 bedroom apartment', price: 'S/ 400 – 700', notes: '4 t unit, 5-7 hours' },
  { label: '3 bedroom apartment', price: 'S/ 600 – 1,000', notes: '4 t unit, 6-8 hours' },
  {
    label: 'Complete family house',
    price: 'S/ 900 – 1,600',
    notes: '2 trips with 4 t unit, full day',
  },
];

const includes = [
  'Loading and unloading staff (2-4 people depending on volume)',
  'Own truck with professional driver (A-IIIb or A-IIIc license)',
  'Blankets and straps to protect furniture',
  "Basic cardboard boxes (if you don't have them)",
  'Disassembly and reassembly of standard furniture (beds, wardrobes)',
  'Direct transport with no unnecessary stops',
];

const faqs = [
  {
    q: 'How much does a local move in Cusco cost?',
    a: 'It depends on volume and distance. As a reference: a taxi cargo or mini move starts at S/ 150, a room or studio between S/ 250-450, a 1-3 bedroom apartment between S/ 400-1,000, and a complete family house from S/ 900. We quote exact price via WhatsApp in minutes.',
  },
  {
    q: 'Do you quote in US dollars?',
    a: 'All prices are in Peruvian Soles (S/). Current reference: USD 1 ≈ S/ 3.75 (varies). For business customers we can issue invoice in Soles with tax ID.',
  },
  {
    q: 'Do you work weekends?',
    a: 'Yes, we work Saturdays, Sundays and holidays. Sundays have fewer units available, so we recommend booking with 3-4 days notice for weekend moves.',
  },
  {
    q: 'Can you help if my street is narrow or has no parking?',
    a: 'Yes. For complicated areas (Historic Center of Cusco, for example) we carry cargo in short segments with hand trolleys, or use the smallest unit. Just let us know in the quote if your address has access limitations.',
  },
];
---

<BaseLayout
  title="Local Moving in Cusco | Expresos Ñan"
  description="Professional local moving service in Cusco metropolitan area. Homes, apartments and small offices. Packing, transport and furniture assembly included. WhatsApp 925 671 052."
  ogImage="/wp-content/uploads/2024/05/MUDANZAS-DE-DEPARTAMENTO-OFICINAS-HABITACIONES-CUSCO.jpg"
>
  <Hero
    eyebrow="Local moving"
    title="Local moving in Cusco — full-service"
    subtitle="Moves within the Cusco metropolitan area with professional staff, blankets, straps and disassembly included. Transparent pricing."
    image="/wp-content/uploads/2024/05/MUDANZAS-DE-DEPARTAMENTO-OFICINAS-HABITACIONES-CUSCO.jpg"
    imageAlt="Apartment move in Cusco with Expreso Ñan"
    whatsappMessage="Hi, I need a quote for a local move in Cusco. Origin: [address]. Destination: [address]."
    secondaryCta={{ label: 'See coverage', href: '/en/coverage/' }}
  />

  <Section spacing="sm">
    <Container>
      <Breadcrumbs
        items={[
          { label: 'Home', href: '/en/' },
          { label: 'Services', href: '/en/services/' },
          { label: 'Local moving' },
        ]}
      />
    </Container>
  </Section>

  <Section background="white" spacing="md">
    <Container size="narrow">
      <div class="space-y-4 text-base leading-relaxed text-gray-700 md:text-lg">
        <p>
          We understand that a move is a moment of change and stress. Our goal is simple:
          <strong> you don't have to worry about anything</strong>. We arrive with the full team
          (staff, truck, blankets, straps, boxes, tools), we pack what's left, disassemble
          furniture, load, transport, unload and reassemble at destination. Your participation is
          limited to telling us where each thing goes.
        </p>
        <p>
          We work with <strong>our own units</strong> — no subcontracting. You coordinate with the same
          team from start to finish: same company, same drivers, same responsibility.
        </p>
        <p>
          Moving to <strong>Pisac, Urubamba, Ollantaytambo, Chinchero</strong> or any Sacred Valley locality
          (1-4 h from Cusco)? Active service too — technically a short inter-provincial move. Check the
          <a href="/en/intercity-moving/" class="text-primary underline"> inter-provincial page </a>
          or quote directly via WhatsApp.
        </p>
      </div>
    </Container>
  </Section>

  <Section background="gray" spacing="md">
    <Container size="narrow">
      <h2 class="font-heading mb-6 text-2xl font-bold md:text-3xl">Reference prices 2026</h2>
      <p class="mb-4 text-sm text-gray-600">
        Reference prices within Cusco metropolitan area. Final quote depends on real volume and
        distance.
      </p>
      <div class="overflow-x-auto rounded-2xl border border-gray-200 bg-white">
        <table class="w-full text-left">
          <thead class="bg-gray-50 text-sm font-bold">
            <tr>
              <th class="px-4 py-3">Type of move</th>
              <th class="px-4 py-3">Price</th>
              <th class="hidden px-4 py-3 md:table-cell">Notes</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            {
              priceRows.map((row) => (
                <tr class="text-sm">
                  <td class="px-4 py-3 font-bold">{row.label}</td>
                  <td class="text-primary px-4 py-3 font-bold">{row.price}</td>
                  <td class="hidden px-4 py-3 text-gray-600 md:table-cell">{row.notes}</td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
    </Container>
  </Section>

  <Section background="white" spacing="md">
    <Container size="narrow">
      <h2 class="font-heading mb-6 text-2xl font-bold md:text-3xl">
        What's included in the service
      </h2>
      <ul class="space-y-3">
        {
          includes.map((item) => (
            <li class="flex items-start gap-3 rounded-lg border border-gray-100 bg-gray-50 p-4">
              <svg
                class="text-primary mt-0.5 h-5 w-5 shrink-0"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M4.5 12.75l6 6 9-13.5" />
              </svg>
              <span class="text-sm text-gray-700">{item}</span>
            </li>
          ))
        }
      </ul>
    </Container>
  </Section>

  <Section background="gray" spacing="lg">
    <Container size="narrow">
      <h2 class="font-heading mb-8 text-2xl font-bold md:text-3xl">Frequently asked questions</h2>
      <div class="space-y-3">
        {
          faqs.map((faq) => (
            <details class="group rounded-xl border border-gray-200 bg-white">
              <summary class="hover:text-primary flex cursor-pointer list-none items-center justify-between p-5 font-bold [&::-webkit-details-marker]:hidden">
                <span>{faq.q}</span>
                <svg
                  class="h-5 w-5 shrink-0 transition-transform group-open:rotate-180"
                  viewBox="0 0 20 20"
                  fill="currentColor"
                  aria-hidden="true"
                >
                  <path
                    fill-rule="evenodd"
                    d="M5.23 7.21a.75.75 0 011.06.02L10 11.06l3.71-3.83a.75.75 0 111.08 1.04l-4.25 4.39a.75.75 0 01-1.08 0L5.21 8.27a.75.75 0 01.02-1.06z"
                    clip-rule="evenodd"
                  />
                </svg>
              </summary>
              <div class="border-t border-gray-100 px-5 py-4 text-sm leading-relaxed text-gray-700">
                <p>{faq.a}</p>
              </div>
            </details>
          ))
        }
      </div>
    </Container>
  </Section>

  <CTASection
    title="Ready to schedule your local move?"
    subtitle="WhatsApp us with origin, destination and volume — you'll get the closed price within minutes."
    whatsappMessage="Hi, I need a quote for a local move in Cusco."
  />
</BaseLayout>
