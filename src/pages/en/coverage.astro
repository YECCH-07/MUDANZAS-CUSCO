---
import BaseLayout from '@layouts/BaseLayout.astro';
import Container from '@components/Container.astro';
import Section from '@components/Section.astro';
import Hero from '@components/Hero.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import CTASection from '@components/CTASection.astro';
import {
  METRO,
  VALLE_SAGRADO_1_2H,
  VALLE_SAGRADO_2_3H,
  VALLE_SAGRADO_3_4H,
  INTERPROVINCIAL,
} from '@lib/coverage';
import { getCollection } from 'astro:content';

const routes = await getCollection('routes');
const activeRoutes = routes.filter((r) => r.data.status === 'active');
const comingSoonRoutes = routes.filter((r) => r.data.status === 'coming-soon');
---

<BaseLayout
  title="Coverage — Cusco, Sacred Valley, Apurímac | Expresos Ñan"
  description="Full coverage of Expresos Ñan moving service: 8 Cusco metropolitan districts, 22 Sacred Valley localities, and 9 inter-provincial routes to Apurímac, Canchis and Chumbivilcas."
  ogImage="/wp-content/uploads/2024/05/MUDANZAS-CUSCO.png"
>
  <Hero
    eyebrow="Coverage"
    title="All the routes we serve"
    subtitle="8 metropolitan districts · 22 Sacred Valley localities (1-4 h) · 9 active inter-provincial routes · 4 routes opening soon."
    image="/wp-content/uploads/2024/05/MUDANZAS-CUSCO.png"
    imageAlt="Coverage map of Expresos Ñan in Cusco and Apurímac"
    whatsappMessage="Hi, I need a quote for a move. My destination is [locality]."
    secondaryCta={{ label: 'See services', href: '/en/services/' }}
  />

  <Section spacing="sm">
    <Container>
      <Breadcrumbs items={[{ label: 'Home', href: '/en/' }, { label: 'Coverage' }]} />
    </Container>
  </Section>

  {/* Zone 1 — Cusco metropolitan */}
  <Section background="white" spacing="lg" id="metro">
    <Container>
      <div class="mb-8 max-w-2xl">
        <p class="text-primary mb-2 text-xs font-bold tracking-wider uppercase">
          Zone 1 · {METRO.timeRange}
        </p>
        <h2 class="font-heading text-3xl font-bold md:text-4xl">Cusco metropolitan area</h2>
        <p class="mt-3 text-gray-700">
          All metropolitan districts. Moves resolved the same day, usually with no distance
          surcharge.
        </p>
      </div>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {
          METRO.localities.map((loc) => (
            <a
              href={`/${loc.slug}/`}
              class="hover:border-primary group block rounded-2xl border border-gray-200 bg-gray-50 p-5 transition-all hover:shadow-md"
            >
              <p class="text-primary mb-1 text-xs font-bold tracking-wider uppercase">
                {loc.province}
              </p>
              <h3 class="font-heading group-hover:text-primary text-lg font-bold">{loc.name}</h3>
              <span class="text-primary mt-2 inline-block text-sm font-bold">See district →</span>
            </a>
          ))
        }
      </div>
    </Container>
  </Section>

  {/* Zone 2 — Sacred Valley */}
  <Section background="gray" spacing="lg">
    <Container>
      <div class="mb-8 max-w-2xl">
        <p class="text-primary mb-2 text-xs font-bold tracking-wider uppercase">
          Zone 2 · 1-4 hours
        </p>
        <h2 class="font-heading text-3xl font-bold md:text-4xl">Sacred Valley and surroundings</h2>
        <p class="mt-3 text-gray-700">
          <strong>22 localities with active service.</strong> Direct WhatsApp quote (no individual landing
          pages yet). Organized by travel time from Cusco.
        </p>
      </div>

      <div class="mb-8">
        <h3 class="font-heading mb-4 text-xl font-bold">
          Sacred Valley core ·{' '}
          <span class="text-primary">{VALLE_SAGRADO_1_2H.timeRange}</span>
        </h3>
        <ul class="flex flex-wrap gap-2">
          {
            VALLE_SAGRADO_1_2H.localities.map((loc) => (
              <li class="rounded-full border border-gray-200 bg-white px-4 py-2 text-sm">
                <span class="font-bold">{loc.name}</span>
                <span class="ml-1 text-gray-500">· {loc.province}</span>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="mb-8">
        <h3 class="font-heading mb-4 text-xl font-bold">
          Deep Sacred Valley and Anta highlands ·{' '}
          <span class="text-primary">{VALLE_SAGRADO_2_3H.timeRange}</span>
        </h3>
        <ul class="flex flex-wrap gap-2">
          {
            VALLE_SAGRADO_2_3H.localities.map((loc) => (
              <li class="rounded-full border border-gray-200 bg-white px-4 py-2 text-sm">
                <span class="font-bold">{loc.name}</span>
                <span class="ml-1 text-gray-500">· {loc.province}</span>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <h3 class="font-heading mb-4 text-xl font-bold">
          Quispicanchi, Calca highlands and nearby provinces ·{' '}
          <span class="text-primary">{VALLE_SAGRADO_3_4H.timeRange}</span>
        </h3>
        <ul class="flex flex-wrap gap-2">
          {
            VALLE_SAGRADO_3_4H.localities.map((loc) => (
              <li class="rounded-full border border-gray-200 bg-white px-4 py-2 text-sm">
                <span class="font-bold">{loc.name}</span>
                <span class="ml-1 text-gray-500">· {loc.province}</span>
              </li>
            ))
          }
        </ul>
      </div>
    </Container>
  </Section>

  {/* Zone 3 — Inter-provincial active */}
  <Section background="white" spacing="lg">
    <Container>
      <div class="mb-8 max-w-2xl">
        <p class="text-primary mb-2 text-xs font-bold tracking-wider uppercase">
          Zone 3 · {INTERPROVINCIAL.timeRange}
        </p>
        <h2 class="font-heading text-3xl font-bold md:text-4xl">Active inter-provincial routes</h2>
        <p class="mt-3 text-gray-700">
          9 operating routes to Apurímac, Canchis and Chumbivilcas. Each has a dedicated landing
          page (in Spanish) with map, reference rates and FAQs.
        </p>
      </div>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {
          activeRoutes.map((r) => (
            <a
              href={`/mudanzas-${r.data.slug}/`}
              class="hover:border-primary group block rounded-2xl border border-gray-200 bg-gray-50 p-5 transition-all hover:shadow-md"
            >
              <p class="text-primary mb-1 text-xs font-bold tracking-wider uppercase">
                {r.data.distanceKm} km · {r.data.durationHours} h
              </p>
              <h4 class="font-heading group-hover:text-primary text-lg font-bold">
                Cusco ↔ {r.data.destination}
              </h4>
              <p class="mt-1 text-xs text-gray-600">
                {r.data.province}, {r.data.region}
              </p>
              <span class="text-primary mt-3 inline-block text-sm font-bold">See route →</span>
            </a>
          ))
        }
      </div>
    </Container>
  </Section>

  {/* Coming soon */}
  {
    comingSoonRoutes.length > 0 && (
      <Section background="gray" spacing="lg">
        <Container>
          <div class="mb-8 max-w-2xl">
            <p class="text-primary mb-2 text-xs font-bold tracking-wider uppercase">Coming soon</p>
            <h2 class="font-heading text-2xl font-bold md:text-3xl">Routes opening in 2026</h2>
            <p class="mt-3 text-gray-700">
              Pre-register on each landing and we'll notify you when the route becomes available.
            </p>
          </div>
          <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
            {comingSoonRoutes.map((r) => (
              <a
                href={`/mudanzas-${r.data.slug}/`}
                class="hover:border-primary group block rounded-2xl border border-amber-200 bg-amber-50 p-5 transition-all"
              >
                <p class="mb-1 text-xs font-bold tracking-wider text-amber-700 uppercase">
                  Coming soon · {r.data.distanceKm} km
                </p>
                <h4 class="font-heading group-hover:text-primary text-lg font-bold">
                  {r.data.origin} → {r.data.destination}
                </h4>
                <p class="mt-1 text-xs text-gray-600">
                  {r.data.province}, {r.data.region}
                </p>
                <span class="text-primary mt-3 inline-block text-sm font-bold">Pre-register →</span>
              </a>
            ))}
          </div>
        </Container>
      </Section>
    )
  }

  <Section background="white" spacing="md">
    <Container size="narrow">
      <div
        class="rounded-2xl border-l-4 border-gray-300 bg-gray-50 p-6 text-sm leading-relaxed text-gray-700"
      >
        <p class="mb-2 font-bold">Routes we do not serve</p>
        <p>
          We do not operate the <strong>Cusco ↔ Lima</strong> route, nor routes to Espinar, Quillabamba
          or other localities not listed. For those destinations, we recommend contacting specialized
          long-distance operators. We don't charge referral fees.
        </p>
      </div>
    </Container>
  </Section>

  <CTASection
    title="Is your destination on the list?"
    subtitle="If you see your route, check its page. If not, WhatsApp us — we'll confirm if it's possible or recommend an alternative."
    whatsappMessage="Hi, my move is [origin] → [destination]. Is this route covered?"
  />
</BaseLayout>
