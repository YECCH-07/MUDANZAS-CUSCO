---
import '@/styles/global.css';
import { getLangFromUrl } from '@/i18n/config';
import { useTranslations } from '@/i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <title>Cuscomudanzas — En construcción</title>
    <meta
      name="description"
      content="Sitio en construcción. Pronto estará disponible la nueva versión de cuscomudanzas.com con todos nuestros servicios de mudanza en Cusco."
    />
    <meta name="robots" content="noindex, nofollow" />
  </head>
  <body class="flex min-h-screen flex-col items-center justify-center bg-white text-dark">
    <main class="mx-auto max-w-2xl px-6 py-20 text-center">
      <h1 class="font-heading text-4xl font-bold text-primary md:text-5xl">
        Expresos Ñan — Cusco
      </h1>
      <p class="mt-4 text-lg text-gray-700">
        Sitio en construcción. Esta página temporal confirma que el pipeline (Astro 6 + Tailwind 4 +
        TypeScript + i18n) está funcionando.
      </p>
      <p class="mt-2 text-sm text-gray-500">
        Locale detectado: <strong>{lang}</strong> — "{t('cta.whatsapp')}"
      </p>
    </main>
  </body>
</html>
