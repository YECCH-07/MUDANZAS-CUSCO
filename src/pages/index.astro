---
import BaseLayout from '@layouts/BaseLayout.astro';
import Container from '@components/Container.astro';
import Section from '@components/Section.astro';
import HeroCover from '@components/HeroCover.astro';
import SectionHeader from '@components/SectionHeader.astro';
import StatsBar from '@components/StatsBar.astro';
import ServiceCard from '@components/ServiceCard.astro';
import CTASection from '@components/CTASection.astro';
import TestimonialCarousel from '@components/TestimonialCarousel.astro';
import Button from '@components/Button.astro';
import {
  METRO,
  VALLE_SAGRADO_1_2H,
  VALLE_SAGRADO_2_3H,
  VALLE_SAGRADO_3_4H,
  INTERPROVINCIAL,
} from '@lib/coverage';

const services = [
  {
    title: 'Mudanzas locales en Cusco',
    description:
      'Traslado dentro del área metropolitana: casas, departamentos, oficinas pequeñas. Embalaje, carga, transporte y armado de muebles incluidos.',
    href: '/mudanzas-locales-en-cusco-expresos-nan-servicio-rapido-seguro-y-eficiente/',
    image: '/wp-content/uploads/2024/05/MUDANZAS-DE-DEPARTAMENTO-OFICINAS-HABITACIONES-CUSCO.jpg',
    imageAlt: 'Mudanza de departamento en Cusco con camión Expreso Ñan',
  },
  {
    title: 'Flete y carga',
    description:
      'Transporte de mercadería, muebles individuales, electrodomésticos y carga general. Servicio express local y a provincias del sur.',
    href: '/servicio-de-flete-cusco/',
    image: '/wp-content/uploads/2024/05/CAMION-DE-MUDANZAS-DE-5-TONELADAS-CUSCO.jpg',
    imageAlt: 'Camión Expreso Ñan para servicio de flete y carga en Cusco',
  },
  {
    title: 'Almacenaje y custodia',
    description:
      'Guarda tus muebles y cajas en depósito vigilado por días, meses o años. Vigilancia 24/7, inventario fotográfico y acta firmada.',
    href: '/almacenaje-y-custodia-cusco/',
    image: '/wp-content/uploads/2024/05/MUDANZA-PERSONALIZADA-CUSCO.png',
    imageAlt: 'Servicio de almacenaje y custodia de pertenencias en Cusco',
  },
  {
    title: 'Mudanzas de oficina',
    description:
      'Servicio empresarial con desarme, embalaje y traslado en fines de semana. Factura electrónica con RUC y confidencialidad garantizada.',
    href: '/mudanzas-de-o/',
    image: '/wp-content/uploads/2024/05/SERVICIO-DE-EMBALAJE-Y-MUDANZAS-CUSCO.jpg',
    imageAlt: 'Mudanza de oficina en Cusco — equipo profesional',
  },
];

// Datos de cobertura provienen de lib/coverage.ts (fuente única de verdad)

/*
 * Sectores con icono SVG inline (stroke=currentColor para heredar color del wrapper).
 * Evitamos emojis — se renderizan distinto por OS y rompen consistencia visual.
 */
const sectores = [
  {
    title: 'Familias y residencial',
    description:
      'Mudanzas completas familiares — casas, departamentos y cuartos. El grueso de nuestro trabajo.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 10.5L12 3l9 7.5"/><path d="M5 10v10h5v-6h4v6h5V10"/></svg>`,
  },
  {
    title: 'Minería y corredor Las Bambas',
    description:
      'Personal rotativo y contratistas hacia Challhuahuacho, Tambobamba, Haquira, Mara, Coyllurqui.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 20h18"/><path d="M5 20l5-10 4 7 2-3 3 6"/></svg>`,
  },
  {
    title: 'Sector público y docentes',
    description:
      'Funcionarios UGEL, Red de Salud, Municipalidades. Factura electrónica y orden de servicio.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 21h18"/><path d="M3 10l9-6 9 6"/><path d="M5 10v11"/><path d="M19 10v11"/><path d="M9 14v4"/><path d="M12 14v4"/><path d="M15 14v4"/></svg>`,
  },
  {
    title: 'Estudiantes UNSAAC',
    description: 'Cambio de pensión, traslado a provincia al terminar ciclo. Tarifas económicas.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 9l10-5 10 5-10 5L2 9z"/><path d="M6 11v5c0 1.5 2.5 3 6 3s6-1.5 6-3v-5"/><path d="M22 9v6"/></svg>`,
  },
  {
    title: 'Oficinas y empresas',
    description:
      'Mudanzas de oficina en fin de semana, factura con RUC, NDA si hay documentación sensible.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="7" width="18" height="13" rx="2"/><path d="M8 7V5a2 2 0 012-2h4a2 2 0 012 2v2"/><path d="M3 13h18"/></svg>`,
  },
  {
    title: 'Comerciantes y fletes recurrentes',
    description:
      'Mercadería entre Cusco y Sicuani/Abancay/Las Bambas. Tarifa mensual con descuento.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 7l9-4 9 4v10l-9 4-9-4V7z"/><path d="M3 7l9 4 9-4"/><path d="M12 11v10"/></svg>`,
  },
];

const advantages = [
  {
    title: 'Puntualidad',
    description:
      'Llegamos al horario pactado. Sin retrasos ni excusas — tu tiempo vale tanto como el nuestro.',
  },
  {
    title: 'Seguridad',
    description:
      'Embalaje profesional, mantas y fajas para cada mueble. Choferes con licencia A-IIIb/A-IIIc.',
  },
  {
    title: 'Flota propia',
    description: 'Unidades de 1, 2 y 4 toneladas. Sin subcontrataciones ni intermediarios.',
  },
  {
    title: 'Cobertura amplia',
    description:
      'Todos los distritos de Cusco metropolitano y 9 rutas activas hacia Apurímac, Canchis y Chumbivilcas.',
  },
  {
    title: 'Sin sorpresas en el precio',
    description: 'Cotizamos por WhatsApp con el precio final. Lo que vemos es lo que pagas.',
  },
  {
    title: 'Armado y desarmado',
    description:
      'Desarmamos en origen y armamos en destino sin costo adicional en la mayoría de casos.',
  },
];
---

<BaseLayout
  title="Servicio De Mudanza En Cusco | Expresos Ñan"
  description="Servicio completo de mudanza en Cusco: embalaje, transporte, carga y descarga. Cobertura local y provincial (Sicuani, Abancay, Challhuahuacho). Cotiza por WhatsApp al 925 671 052."
  ogImage="/wp-content/uploads/2024/05/MUDANZAS-CUSCO.png"
>
  {/* 1. Hero principal con foto de portada */}
  <HeroCover
    image="home"
    eyebrow="Expresos Ñan · Mudanzas Cusco"
    title="Mudanzas profesionales en Cusco — transporte seguro y confiable"
    subtitle="Servicio completo de embalaje, carga, transporte y descarga. Cobertura local en todos los distritos de Cusco y rutas activas a Apurímac, Canchis y Chumbivilcas."
    imageAlt="Camión HINO de Expreso Ñan en carretera con personal entregando caja — mudanzas Cusco"
    whatsappMessage="Hola, vi su web y necesito cotización para una mudanza. Mi origen es [ciudad/distrito] y destino [ciudad/distrito]."
    secondaryCta={{ label: 'Ver servicios', href: '/servicio-de-caraga-flete-y-mudanza-cusco/' }}
    stats={[
      { value: '17', label: 'destinos activos' },
      { value: '9', label: 'rutas inter-provincia' },
      { value: '100%', label: 'flota propia' },
    ]}
  />

  {/* 2. Servicios destacados */}
  <Section background="white" spacing="lg" id="servicios" aria-labelledby="servicios-heading">
    <Container>
      <SectionHeader
        eyebrow="Qué hacemos"
        title="Servicios principales"
        subtitle="Mudanza completa, flete, almacenaje, embalaje, armado de muebles y mudanzas de oficina. Todo con flota propia y equipo profesional."
        id="servicios-heading"
      />

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {services.map((s) => <ServiceCard {...s} />)}
      </div>

      <div class="mt-10 text-center">
        <Button href="/servicio-de-caraga-flete-y-mudanza-cusco/" variant="outline" size="md">
          Ver todos los servicios
        </Button>
      </div>
    </Container>
  </Section>

  {/* 2b. Sectores que atendemos */}
  <Section background="dark" spacing="lg" decoration="dots">
    <Container>
      <SectionHeader
        eyebrow="Sectores"
        title="Perfiles que confían en nosotros"
        subtitle="Cada mudanza tiene su propio calendario, protocolo y tipo de carga. Atendemos perfiles muy distintos con el mismo compromiso."
        invert
      />
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {
          sectores.map((s) => (
            <article class="hover:border-primary/50 group rounded-2xl border border-white/10 bg-white/5 p-6 backdrop-blur transition-all motion-safe:hover:-translate-y-1">
              <div
                class="bg-primary/20 text-primary-light mb-4 inline-flex h-12 w-12 items-center justify-center rounded-full [&_svg]:h-6 [&_svg]:w-6"
                set:html={s.icon}
              />
              <h3 class="font-heading mb-2 text-lg font-bold text-white">{s.title}</h3>
              <p class="text-sm text-white/80">{s.description}</p>
            </article>
          ))
        }
      </div>
    </Container>
  </Section>

  {/* 3. Cobertura — 3 zonas */}
  <Section background="gray" spacing="lg" id="cobertura" aria-labelledby="cobertura-heading">
    <Container>
      <SectionHeader
        eyebrow="Cobertura"
        title="Llegamos donde estés"
        subtitle="Servicio activo en tres zonas: Cusco metropolitano (hasta 1 h), Valle Sagrado y alrededores (1 a 4 h, 22 localidades), y rutas inter-provinciales largas (5 a 12 h) a Apurímac, Canchis y Chumbivilcas."
        id="cobertura-heading"
      />

      <div class="grid gap-8 lg:grid-cols-3">
        {/* Zona 1 — Metropolitano */}
        <article>
          <p class="text-primary mb-1 text-xs font-bold tracking-wider uppercase">
            {METRO.timeRange}
          </p>
          <h3 class="font-heading mb-4 text-xl font-bold">{METRO.label}</h3>
          <ul class="grid grid-cols-2 gap-2">
            {
              METRO.localities.map((loc) => (
                <li>
                  {loc.slug ? (
                    <a
                      href={`/${loc.slug}/`}
                      class="hover:border-primary hover:text-primary block rounded-lg border border-gray-200 bg-white px-3 py-2 text-sm transition-colors"
                    >
                      {loc.name}
                    </a>
                  ) : (
                    <span class="block rounded-lg border border-gray-200 bg-white px-3 py-2 text-sm text-gray-700">
                      {loc.name}
                    </span>
                  )}
                </li>
              ))
            }
          </ul>
        </article>

        {/* Zona 2 — Valle Sagrado y alrededores */}
        <article>
          <p class="text-primary mb-1 text-xs font-bold tracking-wider uppercase">1 a 4 horas</p>
          <h3 class="font-heading mb-4 text-xl font-bold">Valle Sagrado y alrededores</h3>
          <div class="space-y-3">
            {
              [VALLE_SAGRADO_1_2H, VALLE_SAGRADO_2_3H, VALLE_SAGRADO_3_4H].map((zone) => (
                <div class="rounded-lg border border-gray-200 bg-white p-3">
                  <p class="mb-1 text-xs font-bold text-gray-500">{zone.timeRange}</p>
                  <p class="text-sm text-gray-700">
                    {zone.localities.map((l) => l.name).join(', ')}
                  </p>
                </div>
              ))
            }
          </div>
          <p class="mt-3 text-xs text-gray-600">
            22 localidades con servicio activo. Cotización directa por WhatsApp.
          </p>
        </article>

        {/* Zona 3 — Inter-provincial */}
        <article>
          <p class="text-primary mb-1 text-xs font-bold tracking-wider uppercase">
            {INTERPROVINCIAL.timeRange}
          </p>
          <h3 class="font-heading mb-4 text-xl font-bold">Inter-provincial largo</h3>
          <ul class="space-y-2">
            {
              INTERPROVINCIAL.localities.map((loc) => (
                <li>
                  <a
                    href={loc.slug ? `/${loc.slug}/` : '/mudanza-provincia/'}
                    class="hover:border-primary hover:text-primary flex items-center justify-between rounded-lg border border-gray-200 bg-white px-3 py-2 text-sm transition-colors"
                  >
                    <span>Cusco ↔ {loc.name}</span>
                    <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                      <path
                        fill-rule="evenodd"
                        d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z"
                        clip-rule="evenodd"
                      />
                    </svg>
                  </a>
                </li>
              ))
            }
          </ul>
          <p class="mt-3 text-xs text-gray-600">
            Próximamente: Cusco ↔ Arequipa, Cusco → Juliaca, Cusco → Puno.
          </p>
        </article>
      </div>

      {/* Stats bar debajo de cobertura — refuerzo de confianza */}
      <div class="mt-10">
        <StatsBar
          items={[
            { value: '8', label: 'distritos metropolitanos' },
            { value: '22', label: 'localidades Valle Sagrado' },
            { value: '9', label: 'rutas inter-provincia' },
            { value: '4', label: 'rutas próximamente' },
          ]}
        />
      </div>
    </Container>
  </Section>

  {/* 4. ¿Por qué elegirnos? */}
  <Section background="white" spacing="lg">
    <Container>
      <SectionHeader
        eyebrow="Por qué elegirnos"
        title="Lo que nos diferencia"
        subtitle="Empresa cusqueña, flota propia y proceso verificado en cientos de mudanzas familiares, empresariales e inter-provinciales."
      />

      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {
          advantages.map((adv, i) => (
            <article class="rounded-2xl border border-gray-100 p-6">
              <span class="bg-primary/10 text-primary font-heading mb-4 inline-flex h-10 w-10 items-center justify-center rounded-full text-lg font-bold">
                {String(i + 1).padStart(2, '0')}
              </span>
              <h3 class="font-heading mb-2 text-lg font-bold">{adv.title}</h3>
              <p class="text-sm text-gray-700">{adv.description}</p>
            </article>
          ))
        }
      </div>
    </Container>
  </Section>

  {/* 5. Galería abreviada */}
  <Section background="gray" spacing="lg" id="galeria">
    <Container>
      <SectionHeader eyebrow="Nuestro trabajo" title="Mudanzas recientes" />

      <div class="grid grid-cols-2 gap-3 md:grid-cols-4">
        <img
          src="/wp-content/uploads/2024/05/MUDANZAS-DE-DEPARTAMENTO-OFICINAS-HABITACIONES-CUSCO.jpg"
          alt="Mudanza de departamento en Cusco"
          loading="lazy"
          decoding="async"
          width="480"
          height="480"
          class="aspect-square w-full rounded-lg object-cover"
        />
        <img
          src="/wp-content/uploads/2024/05/ARMADO-Y-DESARMADO-DE-MUEBLES-CUSCO-MUDANZAS.jpg"
          alt="Armado y desarmado de muebles en Cusco"
          loading="lazy"
          decoding="async"
          width="480"
          height="480"
          class="aspect-square w-full rounded-lg object-cover"
        />
        <img
          src="/wp-content/uploads/2024/05/SERVICIO-DE-EMBALAJE-Y-MUDANZAS-CUSCO.jpg"
          alt="Servicio de embalaje profesional en Cusco"
          loading="lazy"
          decoding="async"
          width="480"
          height="480"
          class="aspect-square w-full rounded-lg object-cover"
        />
        <img
          src="/wp-content/uploads/2024/05/SERVICIO-DE-DESARMADO-Y-ARMADO-DE-MUEBLES-CUSCO.jpg"
          alt="Equipo profesional desarmando muebles en Cusco"
          loading="lazy"
          decoding="async"
          width="480"
          height="480"
          class="aspect-square w-full rounded-lg object-cover"
        />
        <img
          src="/wp-content/uploads/2024/05/CAMION-DE-DOS-TONELADAS-MUDANZAS-CUSCO.jpg"
          alt="Camión de 2 toneladas Expreso Ñan"
          loading="lazy"
          decoding="async"
          width="480"
          height="480"
          class="aspect-square w-full rounded-lg object-cover"
        />
        <img
          src="/wp-content/uploads/2024/05/CAMION-DE-MUDANZAS-DE-5-TONELADAS-CUSCO.jpg"
          alt="Unidad de 4 toneladas para departamentos en Cusco"
          loading="lazy"
          decoding="async"
          width="480"
          height="480"
          class="aspect-square w-full rounded-lg object-cover"
        />
        <img
          src="/wp-content/uploads/2024/05/EMBALAJE-CUSCO.png"
          alt="Materiales de embalaje profesional"
          loading="lazy"
          decoding="async"
          width="480"
          height="480"
          class="aspect-square w-full rounded-lg bg-white object-contain p-6"
        />
        <img
          src="/wp-content/uploads/2024/05/MUDANZA-PERSONALIZADA-CUSCO.png"
          alt="Mudanza personalizada en Cusco"
          loading="lazy"
          decoding="async"
          width="480"
          height="480"
          class="aspect-square w-full rounded-lg bg-white object-contain p-6"
        />
      </div>

      <div class="mt-8 text-center">
        <Button href="/projects/" variant="outline" size="md">Ver galería completa</Button>
      </div>
    </Container>
  </Section>

  {/* 6. Testimonios */}
  <Section background="white" spacing="lg" id="testimonios">
    <Container>
      <SectionHeader eyebrow="Clientes" title="Lo que dicen quienes ya nos eligieron" />
      <TestimonialCarousel />
    </Container>
  </Section>

  {/* 7. CTA final */}
  <CTASection
    title="¿Listo para tu próxima mudanza?"
    subtitle="Te cotizamos en minutos por WhatsApp. Sin compromiso, sin llenar formularios, sin esperas."
    whatsappMessage="Hola, quiero cotización para mi mudanza. Origen: [dirección]. Destino: [dirección]. Fecha tentativa: [fecha]."
  />
</BaseLayout>
