---
import BaseLayout from '@layouts/BaseLayout.astro';
import Container from '@components/Container.astro';
import Section from '@components/Section.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import WhatsAppButton from '@components/WhatsAppButton.astro';
import ContactForm from '@components/ContactForm.astro';
import SocialLinks from '@components/SocialLinks.astro';
import { SITE } from '@lib/site';
import { getTelUrl, getMailUrl } from '@lib/whatsapp';

const success = Astro.url.searchParams.get('success') === 'true';

const contactPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: `Contacto — ${SITE.name}`,
  url: `${SITE.url}/contact/`,
  inLanguage: 'es',
  mainEntity: { '@id': `${SITE.url}/#localbusiness` },
};
---

<BaseLayout
  title="Contacto — Expresos Ñan | Mudanzas Cusco"
  description="Contáctanos por WhatsApp (925 671 052), teléfono o email. Cotizamos tu mudanza en minutos. Atendemos Cusco metropolitano y rutas a Apurímac, Canchis y Chumbivilcas."
  whatsappMessage="Hola, vi la página de contacto y quisiera cotización para mi mudanza."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(contactPageSchema)} is:inline />
  </Fragment>

  <Section background="white" spacing="md">
    <Container>
      <Breadcrumbs items={[{ label: 'Inicio', href: '/' }, { label: 'Contacto' }]} class="mb-6" />

      <header class="mb-10 max-w-2xl">
        <p class="text-primary mb-2 text-xs font-bold tracking-wider uppercase">Contacto</p>
        <h1 class="font-heading text-4xl font-bold md:text-5xl">Conversemos sobre tu mudanza</h1>
        <p class="mt-3 text-gray-700">
          El canal más rápido es WhatsApp — te respondemos en minutos. También puedes llamarnos,
          escribirnos por email o dejarnos los datos en el formulario y nos comunicamos.
        </p>
      </header>

      {
        success && (
          <div class="mb-10 rounded-2xl border-l-4 border-green-600 bg-green-50 p-6" role="status">
            <p class="font-bold text-green-800">¡Gracias, recibimos tu mensaje!</p>
            <p class="mt-1 text-sm text-green-700">
              Te contactaremos en las próximas horas. Si tu mudanza es urgente, escríbenos también
              por WhatsApp al {SITE.phoneDisplay}.
            </p>
          </div>
        )
      }

      <div class="grid gap-10 lg:grid-cols-[1.2fr_1fr]">
        {/* Formulario */}
        <div>
          <h2 class="font-heading mb-4 text-2xl font-bold">Cuéntanos qué necesitas mover</h2>
          <ContactForm kind="general" />
        </div>

        {/* Información de contacto */}
        <aside class="space-y-6">
          <div class="rounded-2xl bg-gray-50 p-6">
            <h2 class="font-heading mb-4 text-xl font-bold">Canales directos</h2>
            <ul class="space-y-4 text-sm">
              <li>
                <p class="text-xs font-bold tracking-wider text-gray-500 uppercase">
                  WhatsApp (más rápido)
                </p>
                <WhatsAppButton variant="inline" size="md" class="mt-2" />
              </li>
              <li>
                <p class="text-xs font-bold tracking-wider text-gray-500 uppercase">Teléfono</p>
                <a href={getTelUrl()} class="hover:text-primary mt-1 block text-base font-bold">
                  {SITE.phoneDisplay}
                </a>
              </li>
              <li>
                <p class="text-xs font-bold tracking-wider text-gray-500 uppercase">Email</p>
                <a
                  href={getMailUrl('Consulta desde el sitio')}
                  class="hover:text-primary mt-1 block break-all"
                >
                  {SITE.email}
                </a>
              </li>
              <li>
                <p class="text-xs font-bold tracking-wider text-gray-500 uppercase">Dirección</p>
                <address class="mt-1 text-sm not-italic">
                  {SITE.address.street}<br />
                  {SITE.address.locality}, {SITE.address.country}
                  {SITE.address.postalCode}
                </address>
              </li>
              <li>
                <p class="text-xs font-bold tracking-wider text-gray-500 uppercase">Horario</p>
                <p class="mt-1 text-sm">
                  Lunes a Sábado: {SITE.openingHours.weekdays}<br />
                  Domingo: {SITE.openingHours.sunday}
                </p>
              </li>
            </ul>

            <div class="mt-6 border-t border-gray-200 pt-5">
              <SocialLinks variant="light" size="md" label="Síguenos en redes" />
            </div>
          </div>

          <div class="overflow-hidden rounded-2xl border border-gray-200">
            <iframe
              title="Ubicación Expresos Ñan en Cusco"
              src="https://www.openstreetmap.org/export/embed.html?bbox=-72.0%2C-13.56%2C-71.93%2C-13.50&layer=mapnik&marker=-13.5319%2C-71.9675"
              width="100%"
              height="260"
              loading="lazy"
              style="border:0"></iframe>
            <div class="bg-white px-4 py-3 text-center">
              <a
                href="https://www.openstreetmap.org/?mlat=-13.5319&mlon=-71.9675#map=14/-13.5319/-71.9675"
                target="_blank"
                rel="noopener noreferrer"
                class="text-primary text-sm font-bold hover:underline"
              >
                Ver mapa más grande →
              </a>
            </div>
          </div>
        </aside>
      </div>
    </Container>
  </Section>

  {/* Formulario empresarial */}
  <Section background="gray" spacing="md">
    <Container size="narrow">
      <header class="mb-6">
        <p class="text-primary mb-2 text-xs font-bold tracking-wider uppercase">Empresas</p>
        <h2 class="font-heading text-2xl font-bold md:text-3xl">
          ¿Mudanza de oficina o flete recurrente?
        </h2>
        <p class="mt-2 text-gray-700">
          Para empresas ofrecemos cotización formal, factura electrónica con RUC, coordinación en
          fines de semana y confidencialidad total.
        </p>
      </header>
      <ContactForm kind="business" subject="Solicitud empresarial — cuscomudanzas.com" />
    </Container>
  </Section>
</BaseLayout>
