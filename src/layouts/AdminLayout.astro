---
/*
 * Layout para todas las páginas de /panel/admin/**.
 * Sidebar de navegación + header con datos del usuario + slot para contenido.
 * Mobile-first: sidebar colapsa en bottom nav en pantallas pequeñas.
 */
import '@/styles/global.css';
import { SITE } from '@lib/site';
import CommandPalette from '@components/panel/CommandPalette.astro';
import ConfirmDialog from '@components/panel/ConfirmDialog.astro';

interface NavItem {
  label: string;
  href: string;
  icon:
    | 'home'
    | 'users'
    | 'truck'
    | 'calculator'
    | 'tag'
    | 'chart'
    | 'history'
    | 'settings'
    | 'doc'
    | 'cash'
    | 'file';
}

interface Props {
  title: string;
}

const { title } = Astro.props;
const user = Astro.locals.user;
if (!user) throw new Error('AdminLayout requires authenticated user');

const nav: NavItem[] = [
  { label: 'Dashboard', href: '/panel/admin/', icon: 'home' },
  { label: 'Usuarios', href: '/panel/admin/usuarios/', icon: 'users' },
  { label: 'Unidades', href: '/panel/admin/unidades/', icon: 'truck' },
  { label: 'Asignaciones', href: '/panel/admin/asignaciones/', icon: 'tag' },
  { label: 'Balances', href: '/panel/admin/balances/', icon: 'chart' },
  { label: 'Funnel', href: '/panel/admin/funnel/', icon: 'chart' },
  { label: 'Caja chica', href: '/panel/admin/caja-chica/', icon: 'cash' },
  { label: 'Categorías', href: '/panel/admin/categorias/', icon: 'tag' },
  { label: 'Calculadora', href: '/panel/admin/calculadora/', icon: 'calculator' },
  { label: 'Audit', href: '/panel/admin/audit/', icon: 'history' },
];

function isActiveRoute(href: string): boolean {
  const { pathname } = Astro.url;
  if (href === '/panel/admin/') return pathname === '/panel/admin/' || pathname === '/panel/admin';
  return pathname.startsWith(href);
}
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="robots" content="noindex, nofollow" />
    {/* Cross-document view transitions nativas (Chrome 126+, Edge, Safari TP) */}
    <meta name="view-transition" content="same-origin" />
    <link rel="icon" type="image/png" href={SITE.logo.icon} />
    <link rel="manifest" href="/panel/manifest.webmanifest" />
    <link rel="apple-touch-icon" href="/panel/icon-192.png" />
    <title>{title} · {SITE.name} · Admin</title>
    <meta name="theme-color" content="#D72638" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <script is:inline>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker
            .register('/panel/sw.js', { scope: '/panel/' })
            .catch((err) => console.warn('[panel] SW register failed:', err));
        });
      }
    </script>
  </head>
  <body class="text-dark min-h-screen bg-gray-50 font-sans antialiased">
    <div class="flex min-h-screen flex-col md:flex-row">
      {/* Sidebar desktop */}
      <aside
        class="hidden w-60 shrink-0 border-r border-gray-200 bg-white md:flex md:flex-col"
        aria-label="Navegación principal"
      >
        <div class="border-b border-gray-100 px-5 py-4">
          <a href="/panel/admin/" class="flex items-center gap-3">
            <img
              src={SITE.logo.icon}
              alt="Expresos Ñan"
              width="40"
              height="40"
              class="h-10 w-10 shrink-0 object-contain"
            />
            <div>
              <p class="text-primary text-[10px] leading-none font-bold tracking-wider uppercase">
                Expresos Ñan
              </p>
              <p class="font-heading text-base leading-tight font-bold">Panel admin</p>
            </div>
          </a>
        </div>
        <nav class="flex-1 space-y-1 p-3">
          {
            nav.map((item) => {
              const current = isActiveRoute(item.href);
              return (
                <a
                  href={item.href}
                  class:list={[
                    'group relative flex items-center gap-3 rounded-lg px-3 py-2 text-sm font-bold transition-all',
                    current
                      ? 'from-primary-50 text-primary-700 shadow-brand-sm bg-gradient-to-r to-white'
                      : 'text-gray-700 hover:bg-gray-100',
                  ]}
                  aria-current={current ? 'page' : undefined}
                >
                  {current && (
                    <span
                      class="bg-primary-600 absolute top-1/2 left-0 h-6 w-1 -translate-y-1/2 rounded-r-full"
                      aria-hidden="true"
                    />
                  )}
                  <span class="inline-block h-5 w-5" aria-hidden="true">
                    {item.icon === 'home' && (
                      <svg
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <path d="M3 10.5L12 3l9 7.5V21a1.5 1.5 0 01-1.5 1.5h-15A1.5 1.5 0 013 21V10.5z" />
                      </svg>
                    )}
                    {item.icon === 'users' && (
                      <svg
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <path d="M16 21v-2a4 4 0 00-4-4H6a4 4 0 00-4 4v2" />
                        <circle cx="9" cy="7" r="4" />
                        <path d="M22 21v-2a4 4 0 00-3-3.87M16 3.13A4 4 0 0116 11" />
                      </svg>
                    )}
                    {item.icon === 'truck' && (
                      <svg
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <path d="M1 3h15v13H1z" />
                        <path d="M16 8h4l3 3v5h-7V8z" />
                        <circle cx="5.5" cy="18.5" r="2.5" />
                        <circle cx="18.5" cy="18.5" r="2.5" />
                      </svg>
                    )}
                    {item.icon === 'tag' && (
                      <svg
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <path d="M20.59 13.41l-7.17 7.17a2 2 0 01-2.83 0L2 12V2h10l8.59 8.59a2 2 0 010 2.82z" />
                        <line x1="7" y1="7" x2="7.01" y2="7" />
                      </svg>
                    )}
                    {item.icon === 'chart' && (
                      <svg
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <line x1="18" y1="20" x2="18" y2="10" />
                        <line x1="12" y1="20" x2="12" y2="4" />
                        <line x1="6" y1="20" x2="6" y2="14" />
                      </svg>
                    )}
                    {item.icon === 'history' && (
                      <svg
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <path d="M3 3v5h5" />
                        <path d="M3.05 13A9 9 0 106 5.3L3 8" />
                        <line x1="12" y1="7" x2="12" y2="12" />
                        <line x1="12" y1="12" x2="15" y2="15" />
                      </svg>
                    )}
                  </span>
                  {item.label}
                </a>
              );
            })
          }
        </nav>
        <div class="border-t border-gray-100 p-4 text-sm">
          <p class="font-bold">{user.fullName}</p>
          <p class="text-xs text-gray-500">{user.email}</p>
          <a
            href="/api/panel/logout/"
            class="mt-3 block rounded-full border border-gray-300 px-3 py-1.5 text-center text-xs font-bold hover:bg-gray-100"
          >
            Cerrar sesión
          </a>
        </div>
      </aside>

      {/* Header móvil */}
      <header
        class="flex items-center justify-between border-b border-gray-200 bg-white px-4 py-3 md:hidden"
      >
        <a href="/panel/admin/" class="flex items-center gap-2">
          <img
            src={SITE.logo.icon}
            alt="Expresos Ñan"
            width="32"
            height="32"
            class="h-8 w-8 shrink-0 object-contain"
          />
          <div class="min-w-0">
            <p class="font-heading text-sm leading-tight font-bold">Panel admin</p>
            <p class="truncate text-[10px] text-gray-500">{user.fullName}</p>
          </div>
        </a>
        <a
          href="/api/panel/logout/"
          class="rounded-full border border-gray-300 px-3 py-1.5 text-xs font-bold hover:bg-gray-100"
        >
          Salir
        </a>
      </header>

      {/* Contenido */}
      <main class="flex-1 pb-20 md:pb-0">
        <div class="mx-auto max-w-6xl p-4 md:p-8">
          <slot />
        </div>
      </main>

      {/* Bottom nav móvil */}
      <nav
        class="fixed right-0 bottom-0 left-0 z-10 border-t border-gray-200 bg-white md:hidden"
        aria-label="Navegación (móvil)"
      >
        <ul class="grid grid-cols-5 text-xs">
          {
            nav.slice(0, 5).map((item) => {
              const current = isActiveRoute(item.href);
              return (
                <li>
                  <a
                    href={item.href}
                    aria-current={current ? 'page' : undefined}
                    class:list={[
                      'flex flex-col items-center gap-1 px-2 py-2 text-[10px] font-bold transition-colors',
                      current ? 'text-primary-700' : 'text-gray-600 hover:text-gray-900',
                    ]}
                  >
                    {item.label}
                  </a>
                </li>
              );
            })
          }
        </ul>
      </nav>
    </div>
    <CommandPalette />
    <ConfirmDialog />
  </body>
</html>
