---
/*
 * Layout para landings de rutas inter-provinciales ACTIVAS.
 * Renderiza hero, mapa Leaflet con polilínea, información de ruta, servicios,
 * tarifas, FAQs y CTA. SEO: Schema.org MovingCompany con areaServed Place + GeoCoordinates.
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import Container from '@components/Container.astro';
import Section from '@components/Section.astro';
import Hero from '@components/Hero.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import CTASection from '@components/CTASection.astro';
import WhatsAppButton from '@components/WhatsAppButton.astro';
import RouteMap from '@components/RouteMap.astro';
import SchemaFAQ from '@components/schema/SchemaFAQ.astro';
import { SITE } from '@lib/site';
import type { CollectionEntry } from 'astro:content';

interface Props {
  route: CollectionEntry<'routes'>['data'];
}

const { route } = Astro.props;
const pageUrl = `${SITE.url}/mudanzas-${route.slug}/`;

const movingCompanySchema = {
  '@context': 'https://schema.org',
  '@type': 'MovingCompany',
  name: `Mudanzas ${route.origin} ↔ ${route.destination} — ${SITE.name}`,
  description: route.metaDescription,
  url: pageUrl,
  provider: { '@id': `${SITE.url}/#localbusiness` },
  areaServed: [
    {
      '@type': 'Place',
      name: `${route.origin}, Cusco, Perú`,
      geo: {
        '@type': 'GeoCoordinates',
        latitude: route.coordinates.origin.lat,
        longitude: route.coordinates.origin.lng,
      },
    },
    {
      '@type': 'Place',
      name: `${route.destination}, ${route.province}, ${route.region}, Perú`,
      geo: {
        '@type': 'GeoCoordinates',
        latitude: route.coordinates.destination.lat,
        longitude: route.coordinates.destination.lng,
      },
    },
  ],
};
---

<BaseLayout
  title={route.metaTitle}
  description={route.metaDescription}
  ogImage={route.ogImage}
  whatsappMessage={route.ctaMessage}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(movingCompanySchema)} is:inline />
    {route.faqs.length > 0 && <SchemaFAQ faqs={route.faqs} />}
  </Fragment>

  <Hero
    eyebrow={route.heroEyebrow}
    title={route.heroTitle}
    subtitle={route.heroSubtitle}
    image={route.heroImage}
    imageAlt={route.heroImageAlt}
    whatsappMessage={route.ctaMessage}
    secondaryCta={{ label: 'Ver toda la cobertura', href: '/cobertura/' }}
  />

  <Section spacing="sm">
    <Container>
      <Breadcrumbs
        items={[
          { label: 'Inicio', href: '/' },
          { label: 'Cobertura', href: '/cobertura/' },
          { label: `Cusco ↔ ${route.destination}` },
        ]}
      />
    </Container>
  </Section>

  {/* Mapa + ficha de ruta */}
  <Section background="white" spacing="md">
    <Container>
      <div class="grid gap-6 lg:grid-cols-[1.4fr_1fr]">
        <RouteMap
          originLat={route.coordinates.origin.lat}
          originLng={route.coordinates.origin.lng}
          originName={route.origin}
          destLat={route.coordinates.destination.lat}
          destLng={route.coordinates.destination.lng}
          destName={route.destination}
          status="active"
        />
        <aside class="rounded-2xl border border-gray-200 bg-gray-50 p-6">
          <h2 class="font-heading mb-4 text-xl font-bold">Ficha de ruta</h2>
          <dl class="space-y-3 text-sm">
            <div>
              <dt class="text-xs font-bold tracking-wider text-gray-500 uppercase">Origen</dt>
              <dd class="mt-1 font-bold">{route.origin}</dd>
            </div>
            <div>
              <dt class="text-xs font-bold tracking-wider text-gray-500 uppercase">Destino</dt>
              <dd class="mt-1 font-bold">
                {route.destination} ({route.province}, {route.region})
              </dd>
            </div>
            <div>
              <dt class="text-xs font-bold tracking-wider text-gray-500 uppercase">Distancia</dt>
              <dd class="mt-1">{route.distanceKm} km</dd>
            </div>
            <div>
              <dt class="text-xs font-bold tracking-wider text-gray-500 uppercase">
                Tiempo estimado
              </dt>
              <dd class="mt-1">{route.durationHours} horas</dd>
            </div>
            <div>
              <dt class="text-xs font-bold tracking-wider text-gray-500 uppercase">
                Tipo de carretera
              </dt>
              <dd class="mt-1">{route.roadType}</dd>
            </div>
            {
              route.altitudeMsnm !== undefined && (
                <div>
                  <dt class="text-xs font-bold tracking-wider text-gray-500 uppercase">
                    Altitud destino
                  </dt>
                  <dd class="mt-1">{route.altitudeMsnm} msnm</dd>
                </div>
              )
            }
            {
              route.intermediateStops.length > 0 && (
                <div>
                  <dt class="text-xs font-bold tracking-wider text-gray-500 uppercase">
                    Paradas intermedias
                  </dt>
                  <dd class="mt-1">{route.intermediateStops.join(' · ')}</dd>
                </div>
              )
            }
          </dl>
          <div class="mt-5">
            <WhatsAppButton
              variant="inline"
              size="md"
              class="w-full"
              message={route.ctaMessage}
              label={`Cotizar Cusco ↔ ${route.destination}`}
            />
          </div>
        </aside>
      </div>
    </Container>
  </Section>

  {/* Descripción larga */}
  <Section background="white" spacing="md">
    <Container size="narrow">
      <h2 class="font-heading mb-4 text-2xl font-bold md:text-3xl">
        Mudanzas {route.origin} ↔ {route.destination}: lo que tienes que saber
      </h2>
      <div class="prose-content space-y-4 text-base leading-relaxed text-gray-700 md:text-lg">
        {route.description.map((para) => <p set:html={para} />)}
      </div>
    </Container>
  </Section>

  {/* Industrias y temporada crítica */}
  {
    (route.relevantIndustries.length > 0 || route.temporadaCritica) && (
      <Section background="gray" spacing="md">
        <Container size="narrow">
          <div class="grid gap-6 md:grid-cols-2">
            {route.relevantIndustries.length > 0 && (
              <div class="rounded-2xl bg-white p-6">
                <p class="text-primary mb-2 text-xs font-bold tracking-wider uppercase">
                  Sectores que atendemos
                </p>
                <ul class="space-y-2 text-sm text-gray-700">
                  {route.relevantIndustries.map((ind) => (
                    <li class="flex gap-2">
                      <span class="text-primary">•</span>
                      {ind}
                    </li>
                  ))}
                </ul>
              </div>
            )}
            {route.temporadaCritica && (
              <div class="border-primary rounded-2xl border-l-4 bg-white p-6">
                <p class="text-primary mb-2 text-xs font-bold tracking-wider uppercase">
                  Temporada crítica
                </p>
                <p class="text-sm leading-relaxed text-gray-700">{route.temporadaCritica}</p>
              </div>
            )}
          </div>
        </Container>
      </Section>
    )
  }

  {/* Particularidades logísticas */}
  {
    route.challenges && (
      <Section background="white" spacing="md">
        <Container size="narrow">
          <h2 class="font-heading mb-4 text-2xl font-bold md:text-3xl">
            Particularidades de la ruta Cusco ↔ {route.destination}
          </h2>
          <div class="border-primary rounded-2xl border-l-4 bg-gray-50 p-6 text-base leading-relaxed text-gray-700">
            <p set:html={route.challenges} />
          </div>
        </Container>
      </Section>
    )
  }

  {/* Servicios disponibles en la ruta */}
  {
    route.services.length > 0 && (
      <Section background="gray" spacing="md">
        <Container>
          <div class="mb-8 max-w-2xl">
            <p class="text-primary mb-2 text-xs font-bold tracking-wider uppercase">Servicios</p>
            <h2 class="font-heading text-2xl font-bold md:text-3xl">
              Servicios en la ruta Cusco ↔ {route.destination}
            </h2>
          </div>
          <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
            {route.services.map((s) => (
              <article class="flex h-full flex-col rounded-2xl border border-gray-100 bg-white p-5 shadow-sm transition-shadow hover:shadow-md">
                <h3 class="font-heading mb-2 text-lg font-bold">
                  <a href={s.href} class="hover:text-primary">
                    {s.title}
                  </a>
                </h3>
                <p class="mb-3 flex-1 text-sm text-gray-700">{s.description}</p>
                <a
                  href={s.href}
                  class="text-primary hover:text-primary-dark mt-auto inline-flex items-center gap-1 text-sm font-bold"
                >
                  Ver más
                  <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                    <path
                      fill-rule="evenodd"
                      d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z"
                      clip-rule="evenodd"
                    />
                  </svg>
                </a>
              </article>
            ))}
          </div>
        </Container>
      </Section>
    )
  }

  {/* Tabla de precios */}
  {
    route.priceTable && (
      <Section background="white" spacing="md">
        <Container size="narrow">
          <h2 class="font-heading mb-2 text-2xl font-bold md:text-3xl">
            Tarifas referenciales Cusco ↔ {route.destination}
          </h2>
          {route.priceTable.note && (
            <p class="mb-6 text-sm text-gray-600">{route.priceTable.note}</p>
          )}
          <div class="overflow-x-auto rounded-2xl border border-gray-200">
            <table class="w-full text-left">
              <thead class="bg-gray-50 text-sm font-bold">
                <tr>
                  <th class="px-4 py-3">Tipo de mudanza / flete</th>
                  <th class="px-4 py-3">Precio referencial</th>
                  <th class="hidden px-4 py-3 md:table-cell">Observaciones</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-100">
                {route.priceTable.rows.map((row) => (
                  <tr class="text-sm">
                    <td class="px-4 py-3 font-bold">{row.label}</td>
                    <td class="text-primary px-4 py-3 font-bold">{row.price}</td>
                    <td class="hidden px-4 py-3 text-gray-600 md:table-cell">{row.notes}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </Container>
      </Section>
    )
  }

  {/* FAQs */}
  {
    route.faqs.length > 0 && (
      <Section background="gray" spacing="lg">
        <Container size="narrow">
          <h2 class="font-heading mb-8 text-2xl font-bold md:text-3xl">
            Preguntas frecuentes — ruta Cusco ↔ {route.destination}
          </h2>
          <div class="space-y-3">
            {route.faqs.map((faq) => (
              <details class="group rounded-xl border border-gray-200 bg-white">
                <summary class="hover:text-primary flex cursor-pointer list-none items-center justify-between p-5 font-bold [&::-webkit-details-marker]:hidden">
                  <span>{faq.q}</span>
                  <svg
                    class="h-5 w-5 shrink-0 transition-transform group-open:rotate-180"
                    viewBox="0 0 20 20"
                    fill="currentColor"
                    aria-hidden="true"
                  >
                    <path
                      fill-rule="evenodd"
                      d="M5.23 7.21a.75.75 0 011.06.02L10 11.06l3.71-3.83a.75.75 0 111.08 1.04l-4.25 4.39a.75.75 0 01-1.08 0L5.21 8.27a.75.75 0 01.02-1.06z"
                      clip-rule="evenodd"
                    />
                  </svg>
                </summary>
                <div class="border-t border-gray-100 px-5 py-4 text-sm leading-relaxed text-gray-700">
                  <p set:html={faq.a} />
                </div>
              </details>
            ))}
          </div>
        </Container>
      </Section>
    )
  }

  <CTASection
    title={route.ctaTitle}
    whatsappMessage={route.ctaMessage}
    {...route.ctaSubtitle !== undefined ? { subtitle: route.ctaSubtitle } : {}}
  />
</BaseLayout>
